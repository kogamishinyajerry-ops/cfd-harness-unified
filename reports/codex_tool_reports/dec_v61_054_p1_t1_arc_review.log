     1	"""Metric ABC + MetricReport dataclass.
     2	
     3	Per METRICS_AND_TRUST_GATES v0.1 Draft (Notion) + accepting clause
     4	for VERSION_COMPATIBILITY_POLICY v1.0 §8.2.
     5	
     6	MVP scope (P1-T1): ABC + dataclass + enum. Individual metric classes
     7	ship with NotImplementedError placeholders; per-metric DECs (P1-T1a,
     8	P1-T1b, ...) will fill in concrete evaluation logic by wrapping
     9	existing extractors (result_comparator / cylinder_strouhal_fft /
    10	convergence_attestor / wall_gradient).
    11	"""
    12	
    13	from __future__ import annotations
    14	
    15	from abc import ABC
    16	from dataclasses import dataclass, field
    17	from enum import Enum
    18	from typing import Any, Dict, Optional
    19	
    20	
    21	class MetricClass(str, Enum):
    22	    """4 categories per METRICS_AND_TRUST_GATES §1 (Notion Draft v0.1)."""
    23	
    24	    POINTWISE = "pointwise"
    25	    """Single-point scalar extracted at a specific location / time."""
    26	
    27	    INTEGRATED = "integrated"
    28	    """Domain / boundary integral quantity (CL, CD, Nu, bulk temperature)."""
    29	
    30	    SPECTRAL = "spectral"
    31	    """Frequency-domain quantity derived via FFT (Strouhal, dominant modes)."""
    32	
    33	    RESIDUAL = "residual"
    34	    """Solver convergence residual or attestor-derived quality indicator."""
    35	
    36	
    37	class MetricStatus(str, Enum):
    38	    """Three-state TrustGate verdict per METRICS_AND_TRUST_GATES §2."""
    39	
    40	    PASS = "pass"
    41	    WARN = "warn"
    42	    FAIL = "fail"
    43	
    44	
    45	@dataclass
    46	class MetricReport:
    47	    """Result of a single Metric.evaluate() call.
    48	
    49	    Per METRICS_AND_TRUST_GATES §3 output schema. TrustGate consumes
    50	    `status` (three-state) + `deviation` to produce overall verdict;
    51	    version_metadata per VERSION_COMPATIBILITY_POLICY §2 provides the
    52	    four-tuple for drift check (aspirational until P1-T1 TaskRunner
    53	    pre-check hook lands, see VCP §3 DESIGN_ONLY note).
    54	    """
    55	
    56	    name: str
    57	    """Metric identifier, unique within MetricsRegistry."""
    58	
    59	    metric_class: MetricClass
    60	    """Category for dispatch + tolerance-policy lookup."""
    61	
    62	    value: Optional[float] = None
    63	    """Measured scalar (None when extraction failed; see `status`)."""
    64	
    65	    unit: str = "dimensionless"
    66	
    67	    reference_value: Optional[float] = None
    68	    """Gold standard reference (when applicable; None for residual metrics)."""
    69	
    70	    deviation: Optional[float] = None
    71	    """Relative deviation |value - reference| / |reference| (fraction, not %).
    72	    None when reference unavailable."""
    73	
    74	    tolerance_applied: Optional[float] = None
    75	    """The tolerance the Trust-Gate compared against (from CaseProfile
    76	    .tolerance_policy per VCP §8.2 → METRICS §4 delegation)."""
    77	
    78	    status: MetricStatus = MetricStatus.PASS
    79	    """PASS / WARN / FAIL per METRICS §2 three-state decision."""
    80	
    81	    provenance: Dict[str, Any] = field(default_factory=dict)
    82	    """Extraction provenance: source artifact paths, extractor version,
    83	    resampling grid, etc. Per KNOWLEDGE_OBJECT_MODEL §1 Provenance object
    84	    (when KNOWLEDGE v1.0 Active, will align with canonical schema)."""
    85	
    86	    version_metadata: Dict[str, str] = field(default_factory=dict)
    87	    """VCP v1.0 §2.1 four-tuple: solver_version / case_compatibility /
    88	    extractor_compatibility / schema_version. Populated by P2 executor when
    89	    ExecutionArtifacts carry it; placeholder empty-dict on today's MVP."""
    90	
    91	    notes: Optional[str] = None
    92	    """Free-form. Used by WARN / FAIL to surface the root cause to the UI."""
    93	
    94	
    95	class Metric(ABC):
    96	    """Base class for all metrics.
    97	
    98	    Subclasses (PointwiseMetric / IntegratedMetric / SpectralMetric /
    99	    ResidualMetric) declare `metric_class` + `delegate_to_module` and
   100	    implement `evaluate()`. MVP skeletons raise NotImplementedError until
   101	    per-metric DECs fill in the extractor wrappers.
   102	    """
   103	
   104	    metric_class: MetricClass
   105	    """Subclass-level attribute — set in each concrete subclass."""
   106	
   107	    delegate_to_module: Optional[str] = None
   108	    """Dot-path of the existing extractor this metric will wrap (for
   109	    traceability during the P1-T1 → per-metric DEC transition).
   110	    e.g. 'src.result_comparator' for point/integrated, 'src.cylinder_strouhal_fft'
   111	    for SpectralMetric, 'src.convergence_attestor' for ResidualMetric."""
   112	
   113	    def __init__(self, name: str, unit: str = "dimensionless") -> None:
   114	        self.name = name
   115	        self.unit = unit
   116	
   117	    def evaluate(
   118	        self,
   119	        artifacts: Dict[str, Any],
   120	        observable_def: Dict[str, Any],
   121	        tolerance_policy: Optional[Dict[str, Any]] = None,
   122	    ) -> MetricReport:
   123	        """Compute the metric value from artifacts + observable definition.
   124	
   125	        Args:
   126	            artifacts: ExecutionArtifacts (paths / in-memory handles) from
   127	                Execution Plane. The MVP does NOT import execution modules;
   128	                it only reads file-system artifacts per the plane contract.
   129	            observable_def: GoldStandard observable entry (per KNOWLEDGE
   130	                §1 draft): `{quantity, reference_values, tolerance, source, ...}`.
   131	            tolerance_policy: CaseProfile.tolerance_policy per VCP §8.2 →
   132	                METRICS §4 accepting clause. Overrides observable_def.tolerance
   133	                when present.
   134	
   135	        Returns:
   136	            MetricReport with status / deviation / provenance populated.
   137	
   138	        Raises:
   139	            NotImplementedError: Placeholder in P1-T1 MVP. Concrete
   140	                implementations land via per-metric-class DECs.
   141	        """
   142	        raise NotImplementedError(
   143	            f"Metric subclass {type(self).__name__} has no evaluate() "
   144	            f"implementation yet. Per-metric DECs (P1-T1a/b/c/d) will "
   145	            f"land the extractor wrappers."
   146	        )
   147	
   148	    def __repr__(self) -> str:
   149	        return (
   150	            f"{type(self).__name__}(name={self.name!r}, "
   151	            f"class={self.metric_class.value}, "
   152	            f"delegates={self.delegate_to_module})"
   153	        )

