    59	def _bbox_diagonal(points: list[tuple[float, float, float]]) -> float:
    60	    if not points:
    61	        return 0.0
    62	    xs = [p[0] for p in points]
    63	    ys = [p[1] for p in points]
    64	    zs = [p[2] for p in points]
    65	    dx = max(xs) - min(xs)
    66	    dy = max(ys) - min(ys)
    67	    dz = max(zs) - min(zs)
    68	    return (dx * dx + dy * dy + dz * dz) ** 0.5
