  7423	    def _copy_postprocess_fields(
  7424	        self, container: Any, case_cont_dir: str, case_host_dir: Path
  7425	    ) -> None:
  7426	        """从容器内复制 postProcess -func writeObjects 输出的场文件到宿主机。
  7427	
  7428	        postProcess 在 latestTime 目录写出 U, Cx, Cy, (T) 等场文件，
  7429	        将这些文件复制到宿主机的对应时间目录。
  7430	        """
  7431	        try:
  7432	            # Find numeric time directories (exclude '0' - initial condition).
  7433	            # DEC-V61-053 live-run fix (2026-04-24): `sort -t/ -k1 -n` fails
  7434	            # on adaptive-timestep directory names like "2.00032" "5.998936"
  7435	            # "10.000003" — field 1 (before first /) is empty on absolute
  7436	            # paths, so sort falls back to lexical comparison and picks
  7437	            # "5.9..." as "latest" over "10.0...". This silently skipped
  7438	            # writeObjects fields for pimpleFoam transient runs. Fixed by
  7439	            # tagging each line with its basename and numeric-sorting on
  7440	            # the tag instead.
  7441	            result = container.exec_run(
  7442	                cmd=[
  7443	                    "bash",
  7444	                    "-c",
  7445	                    f'find "{case_cont_dir}" -maxdepth 1 -type d -name "[0-9]*" 2>/dev/null | grep -v "/0$" | sed "s|/$||" | awk -F/ \'{{print $NF"\\t"$0}}\' | sort -k1,1 -n | tail -1 | cut -f2-',
  7446	                ],
  7447	            )
  7448	            latest_cont_dir = result.output.decode().strip()
  7449	
  7450	            if not latest_cont_dir:
  7451	                return
  7452	
  7453	            # Verify it's a directory, not a file
  7454	            path_check = container.exec_run(
  7455	                cmd=["bash", "-c", f'if [ ! -d "{latest_cont_dir}" ]; then echo not_dir; fi']
  7456	            )
  7457	            if path_check.output.decode().strip() == "not_dir":
  7458	                return
  7459	
  7460	            latest_time = Path(latest_cont_dir).name
  7461	
  7462	            # 场文件：U 和 Cx/Cy 必选，Cz/T 按 case 需要复制。
  7463	            # DEC-V61-052 round 2: include wallShearStress so BFS (and
  7464	            # any other case registering the wallShearStress FO) can run
  7465	            # tau_x-based extractors instead of Ux proxies. When the FO
  7466	            # is absent the file simply doesn't exist — skipped safely.
  7467	            field_files = ["U", "p", "Cx", "Cy", "Cz", "T", "wallShearStress", "yPlus"]
  7468	            host_time_dir = case_host_dir / latest_time
  7469	
  7470	            for field_file in field_files:
  7471	                actual_cont_path = f"{latest_cont_dir}/{field_file}"
  7472	                # Check if file exists in container before attempting copy (T is optional)
  7473	                check = container.exec_run(
  7474	                    cmd=["bash", "-c", f'[ -f "{actual_cont_path}" ] && echo exists || echo missing']
  7475	                )
  7476	                if check.output.decode().strip() == "missing":
  7477	                    continue
  7478	                host_path = host_time_dir / field_file
  7479	                self._copy_file_from_container(container, actual_cont_path, host_path)
  7480	        except Exception as e:
  7481	            import sys as _sys
  7482	            print(f"[WARN] _copy_postprocess_fields failed: {e}", file=_sys.stderr)
  7483	
  7484	    # ------------------------------------------------------------------
  7485	    # Phase 7a — field-artifact staging (VTK + sample CSV + residuals)
  7486	    # ------------------------------------------------------------------
  7487	
  7488	    def _capture_field_artifacts(
  7489	        self,
  7490	        container: Any,
  7491	        case_cont_dir: str,
  7492	        case_host_dir: Path,
  7493	        case_id: str,
  7494	        timestamp: str,
  7495	    ) -> Optional[Path]:
  7496	        """Phase 7a — stage OpenFOAM field artifacts out of the container
  7497	        before the finally-block tears down case_host_dir.
  7498	
  7499	        Mirrors _copy_postprocess_fields. Runs foamToVTK inside the container,
  7500	        then uses docker `get_archive` to pull VTK/, postProcessing/sample/,
  7501	        and postProcessing/residuals/ wholesale via a single tar stream.
  7502	        Also copies log.<solver> from the host case dir (already on host).
  7503	
  7504	        Returns the host-side artifact_dir on success, None on failure.
  7505	        Never raises — field capture is best-effort and must not fail the run
  7506	        (comparator scalar extraction still needs to succeed downstream).
  7507	        """
  7508	        import io as _io
  7509	        import sys as _sys
  7510	        import tarfile as _tarfile
  7511	
  7512	        repo_root = Path(__file__).resolve().parents[1]
  7513	        artifact_dir = repo_root / "reports" / "phase5_fields" / case_id / timestamp
  7514	        try:
  7515	            artifact_dir.mkdir(parents=True, exist_ok=True)
  7516	
  7517	            # (a) foamToVTK — -allPatches merges patches into a single file.
  7518	            #     -noFaceZones: DEC-V61-034 Tier C, circular_cylinder_wake uses
  7519	            #     createBaffles which leaves a cylinderBaffleZone faceZone; OF10
  7520	            #     foamToVTK SEGVs when interpolating surfScalarField phi onto
  7521	            #     the post-baffle faceZone (flux pointer inconsistent with
  7522	            #     split owner/neighbour patches of the same name). -noFaceZones
  7523	            #     skips the faceZone write, which is not required downstream
  7524	            #     (the cylinder wall is already emitted as a regular patch).
  7525	            #     No-op for the 9 cases that don't use faceZones.
  7526	            #     Fallback without -allPatches if it trips empty-patch
  7527	            #     assertions (07a-RESEARCH.md §3.2).
  7528	            ok, log = self._docker_exec(
  7529	                "foamToVTK -latestTime -noZero -allPatches -noFaceZones",
  7530	                case_cont_dir,
  7531	                120,
  7532	            )
  7533	            if not ok:
  7534	                print(
  7535	                    # Tail slice: SEGV stack traces + OF error strings are at
  7536	                    # end-of-log, not the banner. 200-char head truncation
  7537	                    # hid the cylinder_wake SEGV for a full diagnosis cycle.
  7538	                    f"[WARN] foamToVTK -allPatches failed, retrying without: {log[-400:]}",
  7539	                    file=_sys.stderr,
  7540	                )
  7541	                ok, log = self._docker_exec(
  7542	                    "foamToVTK -latestTime -noZero -noFaceZones", case_cont_dir, 120,
  7543	                )
  7544	            if not ok:
  7545	                print(
  7546	                    f"[WARN] foamToVTK failed, field capture skipped: {log[-400:]}",
  7547	                    file=_sys.stderr,
  7548	                )
  7549	                return None
  7550	
  7551	            # (b) Tar + get_archive the three subtrees. Missing subtrees are
  7552	            #     fine (e.g. postProcessing/residuals only exists if the
  7553	            #     residuals function object was emitted).
  7554	            for sub in ("VTK", "postProcessing/sample", "postProcessing/residuals"):
  7555	                src_in_cont = f"{case_cont_dir}/{sub}"
  7556	                probe = container.exec_run(
  7557	                    cmd=["bash", "-c", f'[ -e "{src_in_cont}" ] && echo y || echo n'],
  7558	                )
  7559	                if probe.output.decode().strip() != "y":
  7560	                    continue
  7561	                try:
  7562	                    bits, _ = container.get_archive(src_in_cont)
  7563	                    buf = _io.BytesIO(b"".join(bits))
  7564	                    with _tarfile.open(fileobj=buf) as tar:
  7565	                        tar.extractall(path=artifact_dir)
  7566	                except Exception as e:  # noqa: BLE001
  7567	                    print(
  7568	                        f"[WARN] staging {sub} failed: {e!r}", file=_sys.stderr,
  7569	                    )
  7570	
  7571	            # (c) log.<solver> — already on host after _docker_exec.
  7572	            for logname in (
  7573	                "log.simpleFoam",
  7574	                "log.icoFoam",
  7575	                "log.buoyantFoam",
  7576	                "log.pimpleFoam",
  7577	            ):
  7578	                src = case_host_dir / logname
  7579	                if src.is_file():
  7580	                    (artifact_dir / logname).write_bytes(src.read_bytes())
  7581	                    break
  7582	
  7583	            # (d) Derive residuals.csv from residuals/0/residuals.dat if present.
  7584	            #     Per user ratification #3 — structured ASCII, no log regex.
  7585	            #     NOTE: container.get_archive('.../postProcessing/residuals')
  7586	            #     tar-extracts under basename `residuals/`, not the full
  7587	            #     `postProcessing/residuals/` path. Same applies to `sample/`.
  7588	            residuals_dat_candidates = list(
  7589	                artifact_dir.glob("residuals/*/residuals.dat")
  7590	            )
  7591	            if residuals_dat_candidates:
  7592	                try:
  7593	                    self._emit_residuals_csv(
  7594	                        residuals_dat_candidates[0],
  7595	                        artifact_dir / "residuals.csv",
  7596	                    )
  7597	                except Exception as e:  # noqa: BLE001
  7598	                    print(
  7599	                        f"[WARN] residuals.csv derivation failed: {e!r}",
  7600	                        file=_sys.stderr,
  7601	                    )
  7602	
  7603	            return artifact_dir
  7604	        except Exception as e:  # noqa: BLE001
  7605	            print(
  7606	                f"[WARN] _capture_field_artifacts failed: {e!r}", file=_sys.stderr,
  7607	            )
  7608	            return None
  7609	
  7610	    @staticmethod
  7611	    def _emit_residuals_csv(dat_path: Path, csv_path: Path) -> None:
  7612	        """Convert OpenFOAM v10 residuals function-object output to CSV.
  7613	
  7614	        The .dat format is whitespace-separated with a header line starting
  7615	        with `#`. We passthrough as CSV (comma-separated) with an explicit
  7616	        header — downstream tools (Phase 7b render pipeline) consume this.
  7617	        """
  7618	        lines = dat_path.read_text(encoding="utf-8").splitlines()
  7619	        header: Optional[List[str]] = None
  7620	        rows: List[List[str]] = []
  7621	        for line in lines:
  7622	            line = line.strip()
  7623	            if not line:
  7624	                continue
  7625	            if line.startswith("#"):
  7626	                tokens = line.lstrip("#").split()
  7627	                if tokens:
  7628	                    header = tokens
  7629	                continue
  7630	            rows.append(line.split())
  7631	        if not header or not rows:
  7632	            return
  7633	        with csv_path.open("w", encoding="utf-8") as fh:
  7634	            fh.write(",".join(header) + "\n")
  7635	            for r in rows:
  7636	                fh.write(",".join(r) + "\n")
  7637	
  7638	    # ------------------------------------------------------------------
  7639	    # Log parsing
  7640	    # ------------------------------------------------------------------
  7641	
  7642	    def _parse_solver_log(self, log_path: Path, solver_name: str = "icoFoam", task_spec: Optional[TaskSpec] = None) -> Tuple[Dict[str, float], Dict[str, Any]]:
  7643	        """解析 solver log 文件，提取最终（末次迭代）残差和关键物理量。
  7644	
  7645	        Args:
  7646	            log_path: log 文件路径
  7647	            solver_name: "icoFoam" 或 "simpleFoam" 或 "buoyantFoam"
  7648	            task_spec: 任务规格，用于 case-specific 物理量解释
  7649	
  7650	        Returns:
  7651	            (residuals, key_quantities)
  7652	        """
  7653	        if not log_path.exists():
  7654	            return {}, {}
  7655	
  7656	        text = log_path.read_text(encoding="utf-8", errors="replace")
  7657	
  7658	        residuals: Dict[str, float] = {}
  7659	        key_quantities: Dict[str, Any] = {}
  7660	
  7661	        if solver_name == "simpleFoam":
  7662	            # simpleFoam 格式:
  7663	            # "Solving for Ux, Initial residual = X, Final residual = Y, No Iterations Z"
  7664	            # 也可能有: "Solving for Ux, Initial residual = X, Final residual = Y"
  7665	            # 还有 turbulence: "Solving for k, Initial residual = X, Final residual = Y"
  7666	            pattern = re.compile(
  7667	                r"Solving for (\w+),.*?Initial residual\s*=\s*([\d.eE+-]+)"
  7668	            )
  7669	            for match in pattern.finditer(text):
  7670	                var = match.group(1)
  7671	                # 只保留最后一个匹配（最终迭代）
  7672	                residuals[var] = float(match.group(2))
  7673	
  7674	            # 从最终迭代提取速度分量残差用于 key_quantities
  7675	            ux_matches = list(re.finditer(
  7676	                r"Solving for Ux,.*?Initial residual\s*=\s*([\d.eE+-]+)", text
  7677	            ))
  7678	            uy_matches = list(re.finditer(
  7679	                r"Solving for Uy,.*?Initial residual\s*=\s*([\d.eE+-]+)", text
  7680	            ))
  7681	            if ux_matches and uy_matches:
  7682	                ux_res = float(ux_matches[-1].group(1))
  7683	                uy_res = float(uy_matches[-1].group(1))
  7684	                key_quantities["U_residual_magnitude"] = (ux_res ** 2 + uy_res ** 2) ** 0.5
  7685	
  7686	        else:
  7687	            # icoFoam 格式:
  7688	            # "Solving for <var>, Initial residual = X, Final residual = Y"
  7689	            for match in re.finditer(
  7690	                r"Solving for (\w+).*?Initial residual\s*=\s*([\d.eE+-]+)", text
  7691	            ):
  7692	                var = match.group(1)
  7693	                residuals[var] = float(match.group(2))
  7694	
