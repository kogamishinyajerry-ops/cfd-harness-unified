   622	                    "createBaffles -overwrite", case_cont_dir, self.BLOCK_MESH_TIMEOUT,
   623	                )
   624	                if not baffles_ok:
   625	                    return self._fail(
   626	                        f"createBaffles failed:\n{baffles_log}",
   627	                        time.monotonic() - t0,
   628	                        raw_output_path=raw_output_path,
   629	                    )
   630	
   631	            # 6. 执行求解器
   632	            solver_ok, solver_log = self._docker_exec(
   633	                solver_name, case_cont_dir, self._timeout,
   634	            )
   635	            if not solver_ok:
   636	                return self._fail(
   637	                    f"{solver_name} failed:\n{solver_log}",
   638	                    time.monotonic() - t0,
   639	                    raw_output_path=raw_output_path,
   640	                )
   641	
   642	            # 6.5. 执行 postProcess 提取完整场数据用于关键物理量计算
   643	            # writeObjects: 写出 U/p/phi 等场文件
   644	            # writeCellCentres: 写出 Cx/Cy/Cz cell center 坐标 (用于定位 probe 坐标)
   645	            # 注意: 用 -funcs '(...)' 而非 -func，OpenFOAM 才能识别多个 functionObject
   646	            post_ok, post_log = self._docker_exec(
   647	                "postProcess -funcs '(writeObjects writeCellCentres)' -latestTime", case_cont_dir, 120,
   648	            )
   649	            # postProcess 失败不阻塞主流程（后续解析会处理无数据的情况）
   650	
   651	            # 7. 复制 postProcess 输出的场文件到宿主机
   652	            # postProcess 写出到 latestTime 目录，需要复制回 host 才能解析
   653	            self._copy_postprocess_fields(container, case_cont_dir, case_host_dir)
   654	
   655	            # 7.5. [Phase 7a] Stage field artifacts (VTK + sample CSV + residuals)
   656	            #      BEFORE the finally-block tears down case_host_dir.
   657	            #      Best-effort: any failure MUST NOT fail the run — comparator
   658	            #      scalar extraction below still needs to succeed.
   659	            _phase7a_ts: Optional[str] = None
   660	            _phase7a_cid: Optional[str] = None
   661	            try:
   662	                _md = getattr(task_spec, "metadata", None) or {}
   663	                _phase7a_ts = _md.get("phase7a_timestamp")
   664	                _phase7a_cid = _md.get("phase7a_case_id") or task_spec.name
   665	            except Exception:
   666	                _phase7a_ts = None
   667	            if _phase7a_ts and _phase7a_cid:
   668	                self._capture_field_artifacts(
   669	                    container,
   670	                    case_cont_dir,
   671	                    case_host_dir,
   672	                    _phase7a_cid,
   673	                    _phase7a_ts,
   674	                )
   675	
   676	            # 8. 解析 log 文件
   677	            log_path = case_host_dir / f"log.{solver_name}"
   678	            residuals, key_quantities = self._parse_solver_log(log_path, solver_name, task_spec)
   679	
   680	            # 9. 从 writeObjects 输出的场文件提取 case-specific 关键物理量
   681	            key_quantities = self._parse_writeobjects_fields(
   682	                log_path.parent, solver_name, task_spec, key_quantities
   683	            )
   684	
   685	            elapsed = time.monotonic() - t0
   686	            return ExecutionResult(
   687	                success=True,
   688	                is_mock=False,
   689	                residuals=residuals,
   690	                key_quantities=key_quantities,
   691	                execution_time_s=elapsed,
   692	                raw_output_path=raw_output_path,
   693	            )
   694	
   695	        finally:
   696	            # 清理临时 case 目录（Python 3.9 兼容，不使用 missing_ok）
   697	            try:
   698	                shutil.rmtree(case_host_dir)
   699	            except FileNotFoundError:
   700	                pass
