   122	      // cleanup atomic across React StrictMode double-invocations.
   123	    }
   124	    try {
   125	      mapper?.delete();
   126	    } catch {
   127	      // see above
   128	    }
   129	    try {
   130	      reader?.delete();
   131	    } catch {
   132	      // see above
   133	    }
   134	    try {
   135	      // GLTFImporter cascades dispose to its imported actors per
   136	      // vtk.js semantics, so deleting the importer here is sufficient
   137	      // for the glb path. If both stl and glb were ever attached on
   138	      // the same kernel (not currently exercised), each cleanup is
   139	      // independent.
   140	      importer?.delete();
   141	    } catch {
   142	      // see above
   143	    }
   144	    try {
   145	      grw.delete();
   146	    } catch {
   147	      // see above
   148	    }
   149	    try {
   150	      interactor.delete();
   151	    } catch {
   152	      // see above
   153	    }
   154	  }
   155	
   156	  return { setBackground, attachStl, attachGltf, resetCamera, dispose };
   157	}

