    35	
    36	_GLB_MAGIC = 0x46546C67          # 'glTF'
    37	_JSON_CHUNK_TYPE = 0x4E4F534A    # 'JSON'
    38	_BIN_CHUNK_TYPE = 0x004E4942     # 'BIN\0'
    39	
    40	# glTF accessor componentType values
    41	_COMPONENT_FLOAT = 5126           # FLOAT  (4 bytes)
    42	_COMPONENT_UNSIGNED_INT = 5125    # UNSIGNED_INT (4 bytes)
    43	
    44	# glTF buffer-view target values
    45	_TARGET_ARRAY_BUFFER = 34962
    46	_TARGET_ELEMENT_ARRAY_BUFFER = 34963
    47	
    48	# glTF primitive mode values
    49	_MODE_LINES = 1
    50	
    51	
    52	def _pad_to_4(payload: bytes, fill: bytes) -> bytes:
    53	    """Pad ``payload`` to a 4-byte boundary using ``fill``."""
    54	    rem = (4 - (len(payload) % 4)) % 4
    55	    if rem:
    56	        payload = payload + fill * rem
    57	    return payload
    58	
    59	
    60	def build_lines_glb(points: np.ndarray, edges: np.ndarray) -> bytes:
    61	    """Return a binary glTF (.glb) carrying the LINES primitive.
    62	
    63	    ``points``: ``(N, 3)`` float-compatible — coerced to float32.
    64	    ``edges``: ``(M, 2)`` uint-compatible — coerced to uint32. Each row
    65	    is a vertex-pair (start, end). The resulting primitive uses
    66	    ``mode: LINES``, which renders each consecutive index pair as a
    67	    discrete line segment.
    68	    """
    69	    if points.ndim != 2 or points.shape[1] != 3:
    70	        raise ValueError(f"points must be (N, 3); got {points.shape}")
    71	    if edges.ndim != 2 or edges.shape[1] != 2:
    72	        raise ValueError(f"edges must be (M, 2); got {edges.shape}")
    73	    if len(points) == 0 or len(edges) == 0:
    74	        raise ValueError("points and edges must each be non-empty")
    75	
    76	    points32 = np.ascontiguousarray(points, dtype=np.float32)
    77	    indices32 = np.ascontiguousarray(edges.reshape(-1), dtype=np.uint32)
    78	
    79	    points_bytes = points32.tobytes()
    80	    indices_bytes = indices32.tobytes()
    81	
    82	    # bufferViews are concatenated into one buffer; each view starts
    83	    # at a 4-byte boundary (both 5126 FLOAT and 5125 UINT are 4-byte
    84	    # aligned naturally, but pad defensively in case of future formats).
    85	    points_offset = 0
    86	    indices_offset = len(points_bytes)
    87	    if indices_offset % 4 != 0:
    88	        pad = (4 - (indices_offset % 4)) % 4
    89	        points_bytes = points_bytes + b"\x00" * pad
    90	        indices_offset = len(points_bytes)
    91	
    92	    buffer_payload = points_bytes + indices_bytes
    93	    total_buffer_len = len(buffer_payload)
    94	
    95	    p_min = points32.min(axis=0).tolist()
    96	    p_max = points32.max(axis=0).tolist()
    97	
    98	    gltf_json = {
    99	        "asset": {"version": "2.0", "generator": "cfd-harness M-RENDER-API"},
   100	        "scene": 0,
   101	        "scenes": [{"nodes": [0]}],
   102	        "nodes": [{"mesh": 0}],
   103	        "meshes": [
   104	            {
   105	                "primitives": [
   106	                    {
   107	                        "attributes": {"POSITION": 0},
   108	                        "indices": 1,
   109	                        "mode": _MODE_LINES,
   110	                    }
   111	                ]
   112	            }
   113	        ],
   114	        "buffers": [{"byteLength": total_buffer_len}],
   115	        "bufferViews": [
   116	            {
   117	                "buffer": 0,
   118	                "byteOffset": points_offset,
   119	                "byteLength": len(points32.tobytes()),
   120	                "target": _TARGET_ARRAY_BUFFER,
   121	            },
   122	            {
   123	                "buffer": 0,
   124	                "byteOffset": indices_offset,
   125	                "byteLength": len(indices_bytes),
   126	                "target": _TARGET_ELEMENT_ARRAY_BUFFER,
   127	            },
   128	        ],
   129	        "accessors": [
   130	            {
   131	                "bufferView": 0,
   132	                "componentType": _COMPONENT_FLOAT,
   133	                "count": len(points32),
   134	                "type": "VEC3",
   135	                "min": p_min,
   136	                "max": p_max,
   137	            },
   138	            {
   139	                "bufferView": 1,
   140	                "componentType": _COMPONENT_UNSIGNED_INT,
   141	                "count": len(indices32),
   142	                "type": "SCALAR",
   143	            },
   144	        ],
   145	    }
   146	
   147	    json_bytes = json.dumps(gltf_json, separators=(",", ":"), ensure_ascii=True).encode("ascii")
   148	    json_chunk = _pad_to_4(json_bytes, b" ")
   149	    bin_chunk = _pad_to_4(buffer_payload, b"\x00")
   150	
   151	    json_chunk_header = struct.pack("<II", len(json_chunk), _JSON_CHUNK_TYPE)
   152	    bin_chunk_header = struct.pack("<II", len(bin_chunk), _BIN_CHUNK_TYPE)
   153	
   154	    total_length = (
   155	        12  # GLB header
   156	        + 8 + len(json_chunk)
   157	        + 8 + len(bin_chunk)
   158	    )
   159	
   160	    glb_header = struct.pack("<III", _GLB_MAGIC, 2, total_length)
   161	
   162	    return (
   163	        glb_header
   164	        + json_chunk_header + json_chunk
   165	        + bin_chunk_header + bin_chunk
   166	    )

