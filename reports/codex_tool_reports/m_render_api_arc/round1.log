    24	
    25	export interface ViewportKernel {
    26	  setBackground(rgb: [number, number, number]): void;
    27	  attachStl(reader: vtkSTLReader): void;
    28	  /** glb path · adds the importer's actors to the renderer (M-RENDER-API). */
    29	  attachGltf(importer: vtkGLTFImporter): void;
