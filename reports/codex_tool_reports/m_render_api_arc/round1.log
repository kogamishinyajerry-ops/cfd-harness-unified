    31	  dispose(): void;
    32	}
    33	
    34	export interface KernelOptions {
    35	  background?: [number, number, number];
    36	}
    37	
    38	export function createKernel(
    39	  container: HTMLElement,
    40	  opts: KernelOptions = {},
    41	): ViewportKernel {
