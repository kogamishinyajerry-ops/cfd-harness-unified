   133	
   134	def extract_unique_edges(faces: list[list[int]]) -> np.ndarray:
   135	    """Return an ``(M, 2)`` uint32 array of unique vertex-pair edges.
   136	
   137	    Each face contributes its closed-ring edges (v0-v1, v1-v2, ...,
   138	    v_{n-1}-v0). Edges are deduplicated by sorted-pair so (a, b) and
   139	    (b, a) collapse into a single entry. The output ordering is
   140	    deterministic (sorted lexicographically) so cache hashes are
   141	    stable and tests can assert exact arrays.
   142	    """
   143	    seen: set[tuple[int, int]] = set()
   144	    for face in faces:
   145	        n = len(face)
   146	        for i in range(n):
   147	            a = face[i]
   148	            b = face[(i + 1) % n]
   149	            if a == b:
   150	                continue
   151	            key = (a, b) if a < b else (b, a)
   152	            seen.add(key)
   153	    if not seen:
   154	        raise PolyMeshParseError("face list produced zero edges")
   155	    edges = np.asarray(sorted(seen), dtype=np.uint32)
   156	    return edges

