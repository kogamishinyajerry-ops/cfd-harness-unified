    48	  // GenericRenderWindow.newInstance already installs a
    49	  // vtkInteractorStyleTrackballCamera on its interactor (see
    50	  // node_modules/@kitware/vtk.js/Rendering/Misc/GenericRenderWindow.js
    51	  // — `model.interactor.setInteractorStyle(vtkInteractorStyleTrackballCamera.newInstance())`).
    52	  // Earlier revisions of this kernel created and installed a second
    53	  // trackball style here, which (a) replaced the default style without
    54	  // freeing it and (b) was itself never delete()'d on dispose, leaking
    55	  // vtk objects on every preview mount (Codex round-3 P3 finding).
    56	  // We rely on the built-in default and skip the explicit install.
    57	  const interactor = grw.getInteractor();
