    59	  // Attached lazily when the STL or glb load resolves.
    60	  let mapper: ReturnType<typeof vtkMapper.newInstance> | undefined;
    61	  let actor: ReturnType<typeof vtkActor.newInstance> | undefined;
    62	  let reader: vtkSTLReader | undefined;
    63	  let importer: vtkGLTFImporter | undefined;
    64	
    65	  function attachStl(r: vtkSTLReader): void {
    66	    mapper = vtkMapper.newInstance();
    67	    mapper.setInputConnection(r.getOutputPort());
    68	    actor = vtkActor.newInstance();
    69	    actor.setMapper(mapper);
    70	    reader = r;
    71	
    72	    const renderer = grw.getRenderer();
    73	    renderer.addActor(actor);
    74	    renderer.resetCamera();
    75	    grw.getRenderWindow().render();
    76	  }
    77	
    78	  function attachGltf(imp: vtkGLTFImporter): void {
    79	    // GLTFImporter brings its own actors via importActors(); we just
    80	    // bind the renderer and let the importer populate it. The importer
    81	    // itself owns the actors so dispose only needs to delete the
    82	    // importer (cascades to its actors per vtk.js GLTFImporter semantics).
    83	    importer = imp;
    84	    imp.setRenderer(grw.getRenderer());
    85	    imp.importActors();
    86	
    87	    const renderer = grw.getRenderer();
    88	    renderer.resetCamera();
    89	    grw.getRenderWindow().render();
    90	  }
    91	
    92	  function resetCamera(): void {
    93	    grw.getRenderer().resetCamera();
    94	    grw.getRenderWindow().render();
    95	  }
    96	
    97	  function setBackground(rgb: [number, number, number]): void {
    98	    grw.setBackground(rgb);
    99	    grw.getRenderWindow().render();
   100	  }
   101	
   102	  function dispose(): void {
   103	    // Order matters: actor/mapper/reader first (consumers of the
   104	    // renderer), then `grw.delete()` BEFORE `interactor.delete()`.
   105	    //
   106	    // Why grw before interactor (Codex round-4 R4 #1 P2 finding):
   107	    // vtkGenericRenderWindow.delete is a macro chain that calls
   108	    // setContainer(undefined), which in turn calls
   109	    // `interactor.unbindEvents(model.container)` against the old
   110	    // container. If we delete the interactor first, its internal
   111	    // container ref is cleared and the subsequent unbindEvents
   112	    // becomes a no-op — DOM keyup/pointer listeners then accumulate
   113	    // across mount/unmount cycles.
