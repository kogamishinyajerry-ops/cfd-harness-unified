    83	      loadGlbFromUrl(sourceUrl, controller.signal)
    84	        .then(({ importer }) => {
    85	          if (cancelled) {
    86	            importer.delete();
    87	            return;
    88	          }
    89	          kernel.attachGltf(importer);
    90	          setLoadState({ status: "ready" });
    91	        })
    92	        .catch((err: unknown) => {
    93	          if ((err as { name?: string })?.name === "AbortError" || cancelled) return;
    94	          if (err instanceof GlbLoadError) {
    95	            setLoadState({ status: "error", message: err.message, kind: err.kind });
    96	          } else {
    97	            setLoadState({
    98	              status: "error",
    99	              message: (err as Error).message ?? "unknown error",
   100	              kind: "unknown",
   101	            });
   102	          }
   103	        });
   104	    } else {
   105	      loadStlFromUrl(sourceUrl, controller.signal)
   106	        .then(({ reader, triangleCount }) => {
   107	          if (cancelled) {
   108	            reader.delete();
   109	            return;
   110	          }
   111	          kernel.attachStl(reader);
   112	          setLoadState({ status: "ready", triangleCount });
   113	        })
   114	        .catch((err: unknown) => {
   115	          if ((err as { name?: string })?.name === "AbortError" || cancelled) return;
   116	          if (err instanceof StlLoadError) {
   117	            setLoadState({ status: "error", message: err.message, kind: err.kind });
   118	          } else {
   119	            setLoadState({
   120	              status: "error",
   121	              message: (err as Error).message ?? "unknown error",
   122	              kind: "unknown",
   123	            });
   124	          }
   125	        });
   126	    }
   127	
   128	    return () => {
   129	      cancelled = true;
   130	      controller.abort();
   131	      kernelRef.current?.dispose();
   132	      kernelRef.current = null;
   133	    };
   134	  }, [stlUrl, glbUrl, format, background]);
   135	
   136	  function onResetCamera() {
   137	    kernelRef.current?.resetCamera();
   138	  }
   139	
   140	  const loadingLabel = format === "glb" ? "Loading glb…" : "Loading STL…";
   141	
   142	  return (
   143	    <div className="rounded-md border border-surface-800 bg-surface-950/60 p-3">
   144	      <div className="mb-2 flex items-center justify-between">
   145	        <h3 className="text-xs font-mono uppercase tracking-wider text-surface-500">
