   213	def test_extract_unique_edges_cube_has_12():
   214	    """A cube has exactly 12 edges; per-face quads contribute 24 directed
   215	    edges that dedupe to 12 unique sorted-pair entries."""
   216	    faces = [
   217	        [0, 1, 2, 3],   # bottom
   218	        [4, 5, 6, 7],   # top
   219	        [0, 1, 5, 4],
   220	        [2, 3, 7, 6],
   221	        [1, 2, 6, 5],
   222	        [0, 3, 7, 4],
   223	    ]
   224	    edges = extract_unique_edges(faces)
   225	    assert edges.shape == (12, 2)
   226	    assert edges.dtype == np.uint32
   227	    # All edges should be sorted with a < b
   228	    assert np.all(edges[:, 0] < edges[:, 1])
   229	    # Sample a known edge
   230	    assert any((row == [0, 1]).all() for row in edges)
   231	    assert any((row == [6, 7]).all() for row in edges)
