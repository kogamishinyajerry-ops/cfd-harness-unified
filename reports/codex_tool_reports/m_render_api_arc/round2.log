    77	    if not m:
    78	        return text
    79	    open_idx = text.find("{", m.end())
    80	    if open_idx < 0:
    81	        return text
    82	    depth = 0
    83	    for i in range(open_idx, len(text)):
    84	        if text[i] == "{":
    85	            depth += 1
    86	        elif text[i] == "}":
    87	            depth -= 1
    88	            if depth == 0:
    89	                return text[i + 1 :]
    90	    return text
    91	
    92	
    93	def parse_points(points_path: Path) -> np.ndarray:
    94	    """Return an ``(N, 3)`` float64 array of vertex coordinates."""
    95	    raw = points_path.read_text(encoding="utf-8", errors="replace")
    96	    body = _strip_foamfile_header(_strip_comments(raw))
    97	    matches = _POINT_RE.findall(body)
    98	    if not matches:
    99	        raise PolyMeshParseError(
   100	            f"no point entries parsed from {points_path.name}"
   101	        )
   102	    arr = np.asarray(matches, dtype=np.float64)
   103	    return arr
   104	
   105	
   106	def parse_faces(faces_path: Path) -> list[list[int]]:
   107	    """Return a list of faces; each face is a list of vertex indices.
   108	
   109	    OpenFOAM faces are general polygons (3+ vertices). We do NOT require
   110	    triangles or quads.
   111	    """
   112	    raw = faces_path.read_text(encoding="utf-8", errors="replace")
   113	    body = _strip_foamfile_header(_strip_comments(raw))
   114	    faces: list[list[int]] = []
   115	    for count_str, payload in _FACE_RE.findall(body):
   116	        verts = [int(v) for v in payload.split() if v]
   117	        if int(count_str) != len(verts):
   118	            raise PolyMeshParseError(
   119	                f"face count {count_str} did not match payload length {len(verts)} "
   120	                f"in {faces_path.name}"
   121	            )
   122	        if len(verts) < 3:
   123	            raise PolyMeshParseError(
   124	                f"face with <3 vertices in {faces_path.name}"
   125	            )
   126	        faces.append(verts)
   127	    if not faces:
   128	        raise PolyMeshParseError(
   129	            f"no face entries parsed from {faces_path.name}"
   130	        )
   131	    return faces
   132	
   133	
   134	def validate_face_indices(faces: list[list[int]], n_points: int) -> None:
   135	    """Raise PolyMeshParseError if any face references a point ID outside [0, n_points).
   136	
   137	    Round-2 Finding 4: ``parse_faces`` only enforces face arity against
   138	    its count prefix. A malformed face like ``4(0 1 2 999)`` (with
   139	    n_points = 8) survived parsing; downstream the indices accessor
   140	    in the LINES glTF would point past the POSITION buffer. This
   141	    validator runs after ``parse_points`` + ``parse_faces`` so callers
   142	    have ``n_points`` available for the bound check.
   143	
   144	    Negative indices (which can't appear via the regex but could appear
   145	    if the parser is ever extended) are also rejected.
   146	    """
   147	    if n_points <= 0:
   148	        raise PolyMeshParseError(
   149	            f"refusing to validate faces against n_points={n_points}"
   150	        )
   151	    for face_idx, verts in enumerate(faces):
   152	        for v in verts:
   153	            if v < 0 or v >= n_points:
   154	                raise PolyMeshParseError(
   155	                    f"face {face_idx} references vertex {v} but only "
   156	                    f"{n_points} points were parsed"
   157	                )
   158	
   159	
   160	def extract_unique_edges(faces: list[list[int]]) -> np.ndarray:
   161	    """Return an ``(M, 2)`` uint32 array of unique vertex-pair edges.
   162	
   163	    Each face contributes its closed-ring edges (v0-v1, v1-v2, ...,
   164	    v_{n-1}-v0). Edges are deduplicated by sorted-pair so (a, b) and
   165	    (b, a) collapse into a single entry. The output ordering is
   166	    deterministic (sorted lexicographically) so cache hashes are
   167	    stable and tests can assert exact arrays.
   168	    """
   169	    seen: set[tuple[int, int]] = set()
   170	    for face in faces:
   171	        n = len(face)
   172	        for i in range(n):
   173	            a = face[i]
   174	            b = face[(i + 1) % n]
   175	            if a == b:
   176	                continue
   177	            key = (a, b) if a < b else (b, a)
   178	            seen.add(key)
   179	    if not seen:
   180	        raise PolyMeshParseError("face list produced zero edges")
   181	    edges = np.asarray(sorted(seen), dtype=np.uint32)
   182	    return edges

