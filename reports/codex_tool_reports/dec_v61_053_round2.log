   164	    # so "0.5" means "skip the first half of the PHYSICAL time range".
   165	    t_min = time_dirs[0][0]
   166	    t_max = time_dirs[-1][0]
   167	    t_trim = t_min + window_start_fraction * (t_max - t_min)
   168	    windowed = [(t, p) for t, p in time_dirs if t >= t_trim]
   169	    if len(windowed) < min_samples:
   170	        return {}
   171	    # Assert a minimum physical averaging duration regardless of count.
   172	    window_duration = windowed[-1][0] - windowed[0][0]
   173	    if window_duration < MIN_AVERAGING_WINDOW_SECONDS:
   174	        return {}
   175	
   176	    file_suffix = f"{set_name}_{field}.xy"
   177	    # Collect per-time values at each gold station.
   178	    # station_values[x_D] = list of u_x at that station across time-steps
   179	    station_values: Dict[float, List[float]] = {
   180	        x_D: [] for x_D in GOLD_STATIONS_X_OVER_D
   181	    }
   182	    for t, t_dir in windowed:
   183	        sample_path = t_dir / file_suffix
   184	        rows = _parse_sample_file(sample_path)
   185	        if not rows:
   186	            continue
   187	        for row in rows:
   188	            x, y, z, ux, _uy, _uz = row
   189	            if not np.isfinite(ux):
   190	                continue
   191	            # Codex round-1 MED-3 fix: enforce centerline (y≈0 AND z≈0)
   192	            # before accepting the row. An off-axis snap point would bias
   193	            # u_x for a centerline observable.
   194	            if abs(y) > CENTERLINE_YZ_TOLERANCE_M:
   195	                continue
   196	            if abs(z) > CENTERLINE_YZ_TOLERANCE_M:
   197	                continue
   198	            for x_D in GOLD_STATIONS_X_OVER_D:
   199	                expected_x = x_D * D
   200	                if abs(x - expected_x) <= XY_MATCH_TOLERANCE_M:
   201	                    station_values[x_D].append(ux)
   202	                    break
   203	
   204	    # Fail closed if any station has < min_samples hits.
   205	    if any(len(v) < min_samples for v in station_values.values()):
   206	        return {}
   207	
   208	    t_window_start = windowed[0][0]
   209	    t_window_end = windowed[-1][0]
   210	    n_samples = min(len(v) for v in station_values.values())
   211	
   212	    out: Dict[str, float] = {
   213	        "u_deficit_n_samples_averaged": float(n_samples),
   214	        "u_deficit_t_window_start_s": float(t_window_start),
   215	        "u_deficit_t_window_end_s": float(t_window_end),
   216	    }
   217	    for x_D in GOLD_STATIONS_X_OVER_D:
   218	        values = np.asarray(station_values[x_D], dtype=float)
   219	        finite_mask = np.isfinite(values)
   220	        if finite_mask.sum() < min_samples:
   221	            return {}
   222	        values_finite = values[finite_mask]
