    81	def compute_streamfunction_from_vtk(
    82	    vtk_path: Path,
    83	    nx: int = 129,
    84	    ny: int = 129,
    85	    bounds: Optional[tuple[float, float, float, float, float]] = None,
    86	) -> Optional[tuple[np.ndarray, np.ndarray, np.ndarray]]:
    87	    """Return (psi, xs, ys) on a uniform nx × ny grid, or None on failure.
    88	
    89	    psi.shape == (ny, nx) in physical m²/s.
    90	    xs, ys in physical m (uniform).
    91	    bounds: optional explicit (xmin, xmax, ymin, ymax, z_mid). If None,
    92	    derived from mesh.bounds with z at the midplane (2D slab convention).
    93	
    94	    Returns None when pyvista is unavailable, the VTK is unreadable,
    95	    or the mesh lacks a U vector field.
    96	    """
    97	    if not vtk_path.is_file():
    98	        return None
    99	
   100	    # Cache schema version — bump when the on-disk npz layout changes.
   101	    CACHE_SCHEMA_VERSION = 2
   102	    cache_dir = vtk_path.parent
   103	    cache_file = cache_dir / f".psi_cache_{nx}x{ny}.npz"
   104	    stat = vtk_path.stat()
   105	    vtk_mtime_ns = int(stat.st_mtime_ns)
   106	    vtk_size = int(stat.st_size)
   107	    # Codex round 1 MED #3: prior cache key was {nx, ny, st_mtime float,
   108	    # 1e-6 tol}; this misses APFS sub-µs updates and ext4 same-second
   109	    # overwrites, and also ignored `bounds`. Use mtime_ns (integer, exact)
   110	    # + size (catches content change when mtime is reused) + bounds
   111	    # (explicit-bounds call shouldn't be served cached-default result) +
   112	    # schema version (invalidates when this serialization format changes).
   113	    bounds_key = tuple(bounds) if bounds is not None else None
   114	    # Cache hit path is deliberately pyvista-free so a backend whose
   115	    # python interpreter lacks a working pyvista/vtk install can still
   116	    # serve ψ-derived dimensions as long as the cache was populated
   117	    # out-of-band (e.g. by python3.11 via this module's __main__).
   118	    if cache_file.is_file():
   119	        try:
   120	            cached = np.load(cache_file, allow_pickle=True)
   121	            cached_schema = int(cached["schema_version"]) if "schema_version" in cached else 1
   122	            cached_mtime_ns = int(cached["vtk_mtime_ns"]) if "vtk_mtime_ns" in cached else None
   123	            cached_size = int(cached["vtk_size"]) if "vtk_size" in cached else None
   124	            cached_bounds = cached["bounds"].item() if "bounds" in cached else None
   125	            if (
   126	                cached_schema == CACHE_SCHEMA_VERSION
   127	                and cached_mtime_ns == vtk_mtime_ns
   128	                and cached_size == vtk_size
   129	                and cached_bounds == bounds_key
   130	            ):
   131	                return cached["psi"], cached["xs"], cached["ys"]
   132	        except Exception:
   133	            pass  # cache miss → recompute below
   134	
   135	    try:
   136	        import pyvista as pv
   137	    except ImportError:
   138	        return None
   139	
   140	    try:
   141	        grid = pv.read(str(vtk_path))
   142	    except Exception:
   143	        return None
   144	
   145	    point_fields = set(grid.point_data.keys()) if hasattr(grid, "point_data") else set()
   146	    cell_fields = set(grid.cell_data.keys()) if hasattr(grid, "cell_data") else set()
   147	
   148	    if "U" not in point_fields and "U" in cell_fields:
   149	        try:
   150	            grid = grid.cell_data_to_point_data()
   151	            point_fields = set(grid.point_data.keys())
   152	        except Exception:
   153	            return None
   154	    if "U" not in point_fields:
   155	        return None
   156	
   157	    if bounds is None:
   158	        xmin, xmax, ymin, ymax, zmin, zmax = grid.bounds
   159	        z_mid = 0.5 * (zmin + zmax)
   160	    else:
   161	        xmin, xmax, ymin, ymax, z_mid = bounds
   162	
   163	    if xmax <= xmin or ymax <= ymin:
   164	        return None
   165	
   166	    xs = np.linspace(xmin, xmax, nx)
   167	    ys = np.linspace(ymin, ymax, ny)
   168	    XX, YY = np.meshgrid(xs, ys)  # shape (ny, nx)
   169	    points = np.column_stack([
   170	        XX.ravel(),
   171	        YY.ravel(),
   172	        np.full(XX.size, z_mid),
   173	    ])
   174	    probe = pv.PolyData(points).sample(grid)
   175	    U = np.asarray(probe["U"])
   176	    if U.ndim != 2 or U.shape[1] < 2:
   177	        return None
   178	    U_x = U[:, 0].reshape(YY.shape)
   179	
   180	    # ψ(x, y) = ∫₀^y U_x(x, y') dy', trapezoidal along axis 0 (y).
   181	    dy = ys[1] - ys[0] if ny > 1 else 0.0
   182	    psi = np.zeros_like(U_x)
   183	    for i in range(1, ny):
   184	        psi[i, :] = psi[i - 1, :] + 0.5 * (U_x[i - 1, :] + U_x[i, :]) * dy
   185	
   186	    try:
   187	        np.savez(
   188	            cache_file,
   189	            psi=psi, xs=xs, ys=ys,
   190	            vtk_mtime_ns=np.array([vtk_mtime_ns]),
   191	            vtk_size=np.array([vtk_size]),
   192	            bounds=np.array(bounds_key, dtype=object),
   193	            schema_version=np.array([CACHE_SCHEMA_VERSION]),
   194	        )
   195	    except Exception:
   196	        pass  # cache write best-effort
   197	
   198	    return psi, xs, ys
   199	
   200	
   201	def psi_wall_closure_residuals(
   202	    psi: np.ndarray,
   203	    xs: np.ndarray,
   204	    ys: np.ndarray,
   205	    u_ref: float = 1.0,
   206	) -> Optional[dict]:
   207	    """Return max |ψ| on each of the 4 walls, normalized by U_ref·L.
   208	
   209	    For LDC with no-slip everywhere except the lid, the stream function
   210	    should satisfy ψ = 0 on all 4 walls. Numerical integration along
   211	    columns plus resampling interpolation leak some residual. These
   212	    residuals bound the credibility of derived observables:
   213	      - primary vortex ψ_min ≈ 0.1 → residual O(1e-3) is fine
   214	      - secondary eddies ψ ≈ 1e-6 to 1e-5 → residual must be << those
   215	        or the match is coincidence, not physics.
   216	
   217	    Introduced (Codex round 1 MED on DEC-V61-050 batch 4): caller can
   218	    compare these residuals against observable scales and warn/fail.
   219	
   220	    Returns {left, right, bottom, top, max, L} (all dimensionless, ψ/UL)
   221	    or None if inputs invalid.
   222	    """
   223	    if xs.size == 0 or ys.size == 0 or psi.shape != (ys.size, xs.size):
   224	        return None
   225	    L = float(xs[-1]) if xs[-1] > 0 else 1.0
   226	    denom = max(u_ref * L, 1e-12)
   227	    left = float(np.max(np.abs(psi[:, 0]))) / denom
   228	    right = float(np.max(np.abs(psi[:, -1]))) / denom
   229	    bottom = float(np.max(np.abs(psi[0, :]))) / denom
   230	    top = float(np.max(np.abs(psi[-1, :]))) / denom
   231	    return {
   232	        "left": left,
   233	        "right": right,
   234	        "bottom": bottom,
   235	        "top": top,
   236	        "max": max(left, right, bottom, top),
   237	        "L": L,
   238	    }
