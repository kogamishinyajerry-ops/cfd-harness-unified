   788	                            actual_f = float(measured)
   789	                            dev_pct = (actual_f - gold_deficit) / gold_deficit * 100 if gold_deficit else 0.0
   790	                            station_rows.append({
   791	                                "x_D": x_D,
   792	                                "actual": actual_f,
   793	                                "expected": gold_deficit,
   794	                                "deviation_pct": dev_pct,
   795	                                "within_tolerance": abs(dev_pct) <= gold_centerline["tolerance"] * 100.0,
   796	                            })
   797	                    if station_rows:
   798	                        tol_pct = gold_centerline["tolerance"] * 100.0
   799	                        all_pass = all(r["within_tolerance"] for r in station_rows)
   800	                        metrics_u_centerline = {
