   241	def find_vortex_core(
   242	    psi: np.ndarray,
   243	    xs: np.ndarray,
   244	    ys: np.ndarray,
   245	    x_window_norm: tuple[float, float] = (0.0, 1.0),
   246	    y_window_norm: tuple[float, float] = (0.0, 1.0),
   247	    mode: str = "min",
   248	    u_ref: float = 1.0,
   249	) -> Optional[tuple[float, float, float]]:
   250	    """Find local extremum of ψ inside the normalized (x/L, y/L) window.
   251	
   252	    Returns (x_c_norm, y_c_norm, psi_ghia) where:
   253	        x_c_norm, y_c_norm ∈ [0, 1] are normalized by L = xs[-1].
   254	        psi_ghia = ψ / (U_ref · L) follows Ghia's non-dimensionalization
   255	                   (matches Table III convention).
   256	    Returns None if the window is empty or has no cells.
   257	
   258	    Conventions for LDC Re=100 (Ghia 1982 Table III):
   259	        primary  : window=(0,1)×(0,1),       mode='min'  (clockwise → ψ_min)
   260	        BL eddy  : window=(0,0.25)×(0,0.25), mode='max'  (counter-rotate → ψ_max)
