   741	
   742	                # D-Cd, D-Cl · secondary_scalars path (Batch C schema)
   743	                for sec_name, metrics_var_name, paper_var_name, symbol in [
   744	                    ("cd_mean", "metrics_cd_mean", "paper_cd_mean", "C_d"),
