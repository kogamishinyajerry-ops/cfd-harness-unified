   768	                                "short": "Williamson 1996",
   769	                                "tolerance_pct": tol_pct,
   770	                            }
   771	                            if metrics_var_name == "metrics_cd_mean":
   772	                                metrics_cd_mean = _metrics_block
   773	                                paper_cd_mean = _paper_block
   774	                            else:
   775	                                metrics_cl_rms = _metrics_block
   776	                                paper_cl_rms = _paper_block
   777	
   778	                # D-u_centerline · 4-station profile from deficit_x_over_D_* keys
   779	                gold_centerline = _load_cylinder_centerline_gold()
   780	                if gold_centerline is not None:
