   858	def build_report_context(case_id: str, run_label: str = "audit_real_run", *, for_pdf: bool = False) -> dict:
   859	    """Assemble all template variables. Raises ReportError on missing data.
   860	
   861	    for_pdf: when True, the `renders.*_png` fields carry repo-relative
   862	    paths (e.g. reports/phase5_renders/...) that WeasyPrint resolves
   863	    against base_url=_REPO_ROOT. When False (default), those fields
   864	    carry absolute HTTP URLs to the /api/cases/.../renders/{file}
   865	    route so the HTML served at /api/cases/.../comparison-report
   866	    actually displays images in a browser — without this, img srcs
   867	    were resolved against the report URL and 404'd (2026-04-23
   868	    user-reported bug).
   869	    """
   870	    if case_id not in _REPORT_SUPPORTED_CASES:
   871	        raise ReportError(
   872	            f"case_id={case_id!r} not in Phase 7 report scope. "
   873	            f"Supported: {sorted(_REPORT_SUPPORTED_CASES)}."
   874	        )
