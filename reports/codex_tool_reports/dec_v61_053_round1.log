    40	) -> None:
    41	    """Write one <time>/wakeCenterline_U.xy file with 4 rows.
    42	
    43	    u_values maps x_D → u_x (float). Missing stations are skipped (produces
    44	    a file with < 4 rows, simulating a partial-sample failure).
    45	    """
    46	    t_dir = case_dir / "postProcessing" / fo_name / f"{t:g}"
    47	    t_dir.mkdir(parents=True, exist_ok=True)
    48	    rows = []
    49	    rows.append("# x y z u_x u_y u_z")
    50	    for x_D in GOLD_STATIONS_X_OVER_D:
    51	        if x_D not in u_values:
    52	            continue
    53	        x = x_D * D
    54	        ux = u_values[x_D]
    55	        rows.append(f"{x:.6f}  0.000000  0.000000  {ux:.6f}  0.000000  0.000000")
    56	    (t_dir / f"{set_name}_U.xy").write_text("\n".join(rows) + "\n")
