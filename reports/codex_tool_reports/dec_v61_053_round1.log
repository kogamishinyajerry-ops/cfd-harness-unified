     1	"""Cylinder wake centerline u_deficit extractor · DEC-V61-053 Batch B2.
     2	
     3	Reads per-timestep samples emitted by the controlDict `cylinderCenterline`
     4	function object (runtime `type sets` with 4 points at x/D ∈ {1, 2, 3, 5}),
     5	trims startup transient, time-averages each station, and converts to wake
     6	deficit = (U_inf - u_mean) / U_inf.
     7	
     8	The runtime FO writes one file per sample-write step:
     9	    postProcessing/cylinderCenterline/<time>/wakeCenterline_U.xy
    10	
    11	Each file has one row per sample point (axis xyz, ordered on):
    12	    x y z  u_x u_y u_z
    13	
    14	Per DEC-V61-053 intake and gold YAML rename (Batch B2):
    15	  - u_Uinf key was historical mislabeling; description has always said
    16	    "velocity deficit". This module emits u_deficit directly.
    17	  - Williamson 1996 gold at Re=100: {0.83, 0.64, 0.55, 0.35} for x/D ∈
    18	    {1, 2, 3, 5}. These are deficit = 1 - u_mean/U_inf.
    19	
    20	Extractor guarantees:
    21	  - fails closed (returns empty dict) if FO output missing or all-NaN
    22	  - rejects too-short windows (< 4 distinct times) to prevent silent fallback
    23	    to a ~1-sample average
    24	  - trims leading transient by default (window_start_fraction=0.5 → drop
    25	    first half of time-history before averaging)
    26	  - handles NaN/inf from solver divergence by clipping to finite-percentile
    27	    envelope before averaging
    28	"""
    29	from __future__ import annotations
    30	
    31	from pathlib import Path
    32	from typing import Dict, List, Optional, Tuple
    33	
    34	import numpy as np
    35	
    36	
    37	# Gold stations. Must match controlDict cylinderCenterline wakeCenterline
    38	# set points AND gold YAML reference_values.x_D.
    39	GOLD_STATIONS_X_OVER_D: Tuple[float, ...] = (1.0, 2.0, 3.0, 5.0)
    40	
    41	# Tolerance for matching sampled x-coord to expected x = x_D * D.
    42	# sampleDict with `cellPoint` interpolation snaps to the nearest cell center,
    43	# so the returned x can be off by ~0.5*cell_dx. At the new 400x200 domain
    44	# grown per B1a, dx ≈ 0.075D = 0.0075 m. Use 2x that as the match tolerance.
    45	XY_MATCH_TOLERANCE_M: float = 0.02
    46	
    47	
    48	def _parse_sample_file(path: Path) -> List[Tuple[float, float, float, float, float, float]]:
    49	    """Parse a `setFormat raw` `type points` sample file.
    50	
    51	    Expected format (OpenFOAM 10, cellPoint, ordered=on):
    52	        # optional header starting with '#'
    53	        x1 y1 z1 ux1 uy1 uz1
    54	        x2 y2 z2 ux2 uy2 uz2
    55	        ...
    56	
    57	    Returns list of 6-tuples (x, y, z, ux, uy, uz). Non-numeric / comment
    58	    lines are skipped silently.
    59	    """
    60	    out: List[Tuple[float, float, float, float, float, float]] = []
    61	    try:
    62	        text = path.read_text(encoding="utf-8", errors="replace")
    63	    except OSError:
    64	        return out
    65	    for line in text.splitlines():
    66	        s = line.strip()
    67	        if not s or s.startswith("#"):
    68	            continue
    69	        parts = s.split()
    70	        if len(parts) < 6:
    71	            continue
    72	        try:
    73	            vals = tuple(float(p) for p in parts[:6])
    74	        except ValueError:
    75	            continue
    76	        out.append(vals)  # type: ignore[arg-type]
    77	    return out
    78	
    79	
    80	def _list_time_dirs(fo_dir: Path) -> List[Tuple[float, Path]]:
    81	    """List `<time>/` subdirs of the function-object output dir, sorted by time."""
    82	    if not fo_dir.is_dir():
    83	        return []
    84	    times: List[Tuple[float, Path]] = []
    85	    for child in fo_dir.iterdir():
    86	        if not child.is_dir():
    87	            continue
    88	        try:
    89	            t = float(child.name)
    90	        except ValueError:
    91	            continue
    92	        times.append((t, child))
    93	    times.sort(key=lambda tp: tp[0])
    94	    return times
    95	
    96	
    97	def extract_centerline_u_deficit(
    98	    case_dir: Path,
    99	    *,
   100	    U_inf: float = 1.0,
   101	    D: float = 0.1,
   102	    fo_name: str = "cylinderCenterline",
   103	    set_name: str = "wakeCenterline",
   104	    field: str = "U",
   105	    window_start_fraction: float = 0.5,
   106	    min_samples: int = 4,
   107	) -> Dict[str, float]:
   108	    """Return {x_D: u_deficit, ...} for the 4 gold stations.
   109	
   110	    Parameters:
   111	        case_dir: OpenFOAM case directory (contains postProcessing/)
   112	        U_inf: freestream velocity (adapter default = 1.0 m/s)
   113	        D: cylinder diameter (adapter default = 0.1 m)
   114	        fo_name: function-object directory name
   115	        set_name: sample-set name (file prefix)
   116	        field: OF field name (here, "U" → file suffix "_U.xy")
   117	        window_start_fraction: fraction of time-history to drop as startup
   118	            transient. 0.5 means keep second half. At endTime=200s and
   119	            writeInterval=20 timesteps, this gives ~tens to hundreds of
   120	            shedding periods in the averaging window.
   121	        min_samples: fail closed if < this many sample snapshots available
   122	            after trimming.
   123	
   124	    Return value keys: "deficit_x_over_D_1.0", "deficit_x_over_D_2.0",
   125	    "deficit_x_over_D_3.0", "deficit_x_over_D_5.0". Also returns metadata:
   126	    "u_deficit_n_samples_averaged", "u_deficit_t_window_start_s",
   127	    "u_deficit_t_window_end_s".
   128	
   129	    Empty dict on extraction failure (FO dir missing, all snapshots NaN,
   130	    window too short, no station matches). Caller is expected to treat
   131	    empty result as "extractor failed; do not emit u_mean_centerline as
   132	    primary scalar" — preserves the honest-measurement contract from
   133	    DEC-V61-041 (no silent canonical fallback).
   134	    """
   135	    fo_dir = case_dir / "postProcessing" / fo_name
   136	    time_dirs = _list_time_dirs(fo_dir)
   137	    if not time_dirs:
   138	        return {}
   139	
   140	    # Trim leading transient.
   141	    n_total = len(time_dirs)
   142	    trim_idx = int(n_total * window_start_fraction)
   143	    windowed = time_dirs[trim_idx:]
   144	    if len(windowed) < min_samples:
   145	        return {}
   146	
   147	    file_suffix = f"{set_name}_{field}.xy"
   148	    # Collect per-time values at each gold station.
   149	    # station_values[x_D] = list of u_x at that station across time-steps
   150	    station_values: Dict[float, List[float]] = {
   151	        x_D: [] for x_D in GOLD_STATIONS_X_OVER_D
   152	    }
   153	    for t, t_dir in windowed:
   154	        sample_path = t_dir / file_suffix
   155	        rows = _parse_sample_file(sample_path)
   156	        if not rows:
   157	            continue
   158	        for row in rows:
   159	            x, _y, _z, ux, _uy, _uz = row
   160	            if not np.isfinite(ux):
   161	                continue
   162	            for x_D in GOLD_STATIONS_X_OVER_D:
   163	                expected_x = x_D * D
   164	                if abs(x - expected_x) <= XY_MATCH_TOLERANCE_M:
   165	                    station_values[x_D].append(ux)
   166	                    break
   167	
   168	    # Fail closed if any station has < min_samples hits.
   169	    if any(len(v) < min_samples for v in station_values.values()):
   170	        return {}
   171	
   172	    t_window_start = windowed[0][0]
   173	    t_window_end = windowed[-1][0]
   174	    n_samples = min(len(v) for v in station_values.values())
   175	
   176	    out: Dict[str, float] = {
   177	        "u_deficit_n_samples_averaged": float(n_samples),
   178	        "u_deficit_t_window_start_s": float(t_window_start),
   179	        "u_deficit_t_window_end_s": float(t_window_end),
   180	    }
   181	    for x_D in GOLD_STATIONS_X_OVER_D:
   182	        values = np.asarray(station_values[x_D], dtype=float)
   183	        finite_mask = np.isfinite(values)
   184	        if finite_mask.sum() < min_samples:
   185	            return {}
   186	        values_finite = values[finite_mask]
   187	        # Robust outlier rejection: drop samples where |v - median| > 10 * MAD.
   188	        # A single diverged snapshot (u=1e30) would otherwise contaminate the
   189	        # percentile-clipped mean. MAD-based filtering is scale-invariant and
   190	        # doesn't require a hand-tuned physics band.
   191	        median = float(np.median(values_finite))
   192	        mad = float(np.median(np.abs(values_finite - median)))
   193	        # Use a small floor on MAD so that pathological all-identical samples
   194	        # with one outlier don't produce MAD=0 → divide-by-zero.
   195	        mad_floor = max(mad, 1e-6 * (abs(median) + 1.0))
   196	        inlier_mask = np.abs(values_finite - median) <= 10.0 * mad_floor
   197	        inliers = values_finite[inlier_mask]
   198	        if inliers.size < min_samples:
   199	            return {}
   200	        u_mean = float(np.mean(inliers))
   201	        deficit = (U_inf - u_mean) / U_inf
   202	        # Sanity band — deficit outside [-0.2, 1.5] is nonphysical for laminar
   203	        # Re=100 wake at x/D ∈ [1, 5]. Don't hard-reject (let comparator decide
   204	        # with its tolerance band), but tag it so diagnostics surface if a
   205	        # quality issue triggers a round-1 finding.
   206	        out[f"deficit_x_over_D_{x_D}"] = deficit
   207	    return out
   208	
   209	
   210	__all__ = [
   211	    "GOLD_STATIONS_X_OVER_D",
   212	    "XY_MATCH_TOLERANCE_M",
   213	    "extract_centerline_u_deficit",
   214	]

