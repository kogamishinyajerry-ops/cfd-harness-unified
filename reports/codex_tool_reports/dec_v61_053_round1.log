    12	import yaml
    13	from jsonschema import Draft7Validator
    14	
    15	
    16	def load_schema(schema_path: Path) -> Dict[str, Any]:
    17	    """Load the JSON schema."""
    18	    return json.loads(schema_path.read_text(encoding="utf-8"))
    19	
    20	
    21	def load_gold_standard_payload(yaml_path: Path) -> Any:
    22	    """Load a gold standard YAML file as either a structured dict or legacy doc list."""
    23	    docs = list(yaml.safe_load_all(yaml_path.read_text(encoding="utf-8")))
    24	    if not docs:
    25	        raise ValueError("Empty YAML file")
    26	    if len(docs) == 1 and isinstance(docs[0], dict) and "observables" in docs[0]:
    27	        return docs[0]
    28	    return docs
    29	
    30	
    31	def _format_error(error) -> str:  # noqa: ANN001
    32	    path = "/".join(str(item) for item in error.absolute_path)
    33	    if path:
    34	        return f"{path}: {error.message}"
    35	    return error.message
    36	
    37	
    38	def validate_gold_standard(yaml_path: Path, schema: Dict[str, Any]) -> Tuple[bool, List[str]]:
    39	    """Validate one Gold Standard YAML file against the schema."""
    40	    try:
    41	        payload = load_gold_standard_payload(yaml_path)
    42	    except Exception as exc:
    43	        return False, [f"load_error: {exc}"]
    44	
    45	    validator = Draft7Validator(schema)
    46	    errors = sorted(
    47	        (_format_error(error) for error in validator.iter_errors(payload)),
    48	        key=str,
    49	    )
    50	    return len(errors) == 0, list(errors)
    51	
    52	
    53	def validate_directory(gold_dir: Path, schema_path: Path) -> Dict[str, Tuple[bool, List[str]]]:
    54	    """Validate all YAML files in a directory."""
    55	    schema = load_schema(schema_path)
    56	    results: Dict[str, Tuple[bool, List[str]]] = {}
    57	    for yaml_path in sorted(gold_dir.glob("*.yaml")):
    58	        results[yaml_path.name] = validate_gold_standard(yaml_path, schema)
    59	    return results
    60	
    61	
