  2201	function ConvergenceSparkline({
  2202	  series,
  2203	  goldRef,
  2204	  tolPct,
  2205	  activeIdx,
  2206	}: {
  2207	  series: { idx: number; label: string; value: number | null | undefined; status: ContractStatus }[];
  2208	  goldRef: number | undefined;
  2209	  tolPct: number | undefined;
  2210	  activeIdx: number;
  2211	}) {
  2212	  const W = 600;
  2213	  const H = 180;
  2214	  const padX = 40;
  2215	  const padY = 20;
  2216	
  2217	  const values = series
  2218	    .map((s) => s.value)
  2219	    .filter((v): v is number => v != null && Number.isFinite(v));
  2220	  if (goldRef == null || !Number.isFinite(goldRef) || values.length === 0) {
  2221	    return (
  2222	      <div className="h-[180px] rounded border border-surface-800 bg-surface-950/40 p-3 text-[11px] text-surface-500">
  2223	        等待后端数据…
  2224	      </div>
  2225	    );
  2226	  }
  2227	  const allVals = [...values, goldRef];
  2228	  if (tolPct != null) {
  2229	    allVals.push(goldRef * (1 + tolPct), goldRef * (1 - tolPct));
  2230	  }
  2231	  const yMin = Math.min(...allVals);
  2232	  const yMax = Math.max(...allVals);
  2233	  const yRange = yMax - yMin || Math.abs(goldRef) * 0.2 || 1;
  2234	  const yPad = yRange * 0.15;
  2235	  const yLo = yMin - yPad;
  2236	  const yHi = yMax + yPad;
  2237	
  2238	  const xStep = series.length > 1 ? (W - 2 * padX) / (series.length - 1) : 0;
  2239	  const toX = (i: number) => padX + i * xStep;
  2240	  const toY = (v: number) => padY + (H - 2 * padY) * (1 - (v - yLo) / (yHi - yLo));
  2241	
  2242	  const goldY = toY(goldRef);
  2243	  const upperY = tolPct != null ? toY(goldRef * (1 + tolPct)) : null;
  2244	  const lowerY = tolPct != null ? toY(goldRef * (1 - tolPct)) : null;
  2245	
  2246	  const points = series
  2247	    .map((s) =>
  2248	      s.value == null || !Number.isFinite(s.value)
  2249	        ? null
  2250	        : `${toX(s.idx)},${toY(s.value)}`,
  2251	    )
  2252	    .filter((p): p is string => p != null)
  2253	    .join(" ");
  2254	
  2255	  const statusColor: Record<ContractStatus, string> = {
  2256	    PASS: "#4ade80",
  2257	    HAZARD: "#fbbf24",
  2258	    FAIL: "#f87171",
  2259	    UNKNOWN: "#9ca3af",
  2260	  };
  2261	
  2262	  return (
  2263	    <div className="rounded border border-surface-800 bg-surface-950/40 p-3">
  2264	      <svg viewBox={`0 0 ${W} ${H}`} className="w-full" role="img">
  2265	        {/* tolerance band */}
  2266	        {upperY != null && lowerY != null && (
  2267	          <rect
  2268	            x={padX - 6}
  2269	            y={Math.min(upperY, lowerY)}
  2270	            width={W - 2 * padX + 12}
  2271	            height={Math.abs(upperY - lowerY)}
  2272	            fill="#4ade80"
  2273	            opacity={0.08}
  2274	          />
  2275	        )}
  2276	        {/* gold line */}
  2277	        <line
  2278	          x1={padX - 6}
  2279	          x2={W - padX + 6}
  2280	          y1={goldY}
  2281	          y2={goldY}
  2282	          stroke="#4ade80"
  2283	          strokeWidth={1.4}
  2284	          strokeDasharray="4 3"
  2285	        />
  2286	        <text x={W - padX + 10} y={goldY + 3} fontSize="10" fill="#4ade80">
  2287	          gold {formatNumber(goldRef)}
  2288	        </text>
  2289	        {/* connecting line */}
  2290	        <polyline
  2291	          points={points}
  2292	          fill="none"
  2293	          stroke="#60a5fa"
  2294	          strokeWidth={1.5}
  2295	          opacity={0.6}
  2296	        />
  2297	        {/* density anchor points */}
  2298	        {series.map((s) => {
  2299	          if (s.value == null || !Number.isFinite(s.value)) return null;
  2300	          const cx = toX(s.idx);
  2301	          const cy = toY(s.value);
  2302	          const r = s.idx === activeIdx ? 6 : 4;
  2303	          return (
  2304	            <g key={s.idx}>
  2305	              <circle
  2306	                cx={cx}
  2307	                cy={cy}
  2308	                r={r}
  2309	                fill={statusColor[s.status]}
  2310	                stroke="#0a0e14"
  2311	                strokeWidth={1.5}
  2312	              />
  2313	              <text
  2314	                x={cx}
  2315	                y={H - 4}
  2316	                textAnchor="middle"
  2317	                fontSize="10"
  2318	                fill={s.idx === activeIdx ? "#e5e7eb" : "#6b7280"}
  2319	              >
  2320	                {s.label}
  2321	              </text>
  2322	            </g>
  2323	          );
  2324	        })}
  2325	      </svg>
  2326	    </div>
  2327	  );
  2328	}
  2329	
  2330	function formatNumber(v: number | undefined | null): string {
  2331	  if (v == null || !Number.isFinite(v)) return "—";
  2332	  const abs = Math.abs(v);
  2333	  if (abs === 0) return "0";
  2334	  if (abs < 0.001) return v.toExponential(2);
  2335	  if (abs < 1) return v.toFixed(4);
  2336	  if (abs < 100) return v.toFixed(3);
  2337	  return v.toFixed(1);
  2338	}
