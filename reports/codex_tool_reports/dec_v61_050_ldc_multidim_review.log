   320	def _load_cylinder_centerline_gold() -> dict | None:
   321	    """Load the u_mean_centerline profile gold (4 x_D points, u_deficit).
   322	
   323	    DEC-V61-053 Batch D: returns {
   324	        "stations": [{x_D: 1.0, deficit: 0.83}, ...],
   325	        "tolerance": 0.05,
   326	        "source": "Williamson 1996",
   327	    } or None. Ref_value key is `u_Uinf` for back-compat (per B2 resolution;
   328	    semantic is wake deficit per description field).
   329	    """
   330	    gold_path = _GOLD_ROOT / "circular_cylinder_wake.yaml"
   331	    if not gold_path.is_file():
   332	        return None
   333	    try:
   334	        docs = list(yaml.safe_load_all(gold_path.read_text(encoding="utf-8")))
   335	    except yaml.YAMLError:
   336	        return None
   337	    doc = next(
   338	        (d for d in docs if isinstance(d, dict) and d.get("quantity") == "u_mean_centerline"),
   339	        None,
   340	    )
   341	    if doc is None:
   342	        return None
   343	    refs = doc.get("reference_values") or []
   344	    stations: list[dict] = []
   345	    for entry in refs:
   346	        if not isinstance(entry, dict):
   347	            continue
   348	        x_D = entry.get("x_D")
   349	        deficit = entry.get("u_Uinf")  # historical key name; value IS deficit
   350	        if isinstance(x_D, (int, float)) and isinstance(deficit, (int, float)):
   351	            stations.append({"x_D": float(x_D), "deficit": float(deficit)})
   352	    if not stations:
   353	        return None
   354	    return {
   355	        "stations": stations,
   356	        "tolerance": float(doc.get("tolerance", 0.05)),
   357	        "source": doc.get("source", "Williamson 1996"),
   358	        "literature_doi": doc.get("literature_doi", "10.1146/annurev.fl.28.010196.002421"),
   359	    }
