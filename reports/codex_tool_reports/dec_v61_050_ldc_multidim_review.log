+        ),
+        "  ",
+    ))
+    print(f"\n[populate] {n_pass}/{len(GHIA_V)} gold points within ±5% tolerance")
+    print(f"[populate] max |dev| = {dev_pct.max():.2f}%  · L2 = {np.sqrt(np.mean((measured_v - GHIA_V)**2)):.5f}")
+    return 0
+
