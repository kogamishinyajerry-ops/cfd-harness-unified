+    top = float(np.max(np.abs(psi[-1, :]))) / denom
+    return {
+        "left": left,
+        "right": right,
+        "bottom": bottom,
+        "top": top,
+        "max": max(left, right, bottom, top),
+        "L": L,
+    }
+
