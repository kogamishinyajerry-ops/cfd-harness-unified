   563	def _get_commit_sha() -> str:
   564	    try:
   565	        r = subprocess.run(
   566	            ["git", "rev-parse", "--short", "HEAD"],
   567	            capture_output=True, text=True, cwd=_REPO_ROOT, timeout=5,
   568	        )
   569	        return r.stdout.strip() or "unknown"
   570	    except (subprocess.SubprocessError, OSError):
   571	        return "unknown"
