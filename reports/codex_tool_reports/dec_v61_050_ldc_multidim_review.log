   579	def _build_visual_only_context(
   580	    case_id: str, run_label: str, timestamp: str, artifact_dir: Path,
   581	    *, for_pdf: bool = False,
   582	) -> dict:
   583	    """Tier C reduced context (DEC-V61-034): real contour + residuals PNGs from
   584	    the captured OpenFOAM artifacts, no gold overlay / verdict / GCI. The
   585	    frontend + template detect ``visual_only: True`` and suppress the
   586	    gold-dependent sections.
   587	    """
   588	    renders_manifest = _load_renders_manifest(case_id, run_label)
   589	    renders_dir = _RENDERS_ROOT / case_id / timestamp
   590	
   591	    def _rel(key: str, default: str = "") -> str:
   592	        candidate: Optional[str] = None
   593	        if renders_manifest:
   594	            raw = renders_manifest.get("outputs", {}).get(key)
   595	            if isinstance(raw, str):
   596	                validated = _safe_rel_under(raw, _RENDERS_ROOT)
   597	                if validated:
   598	                    candidate = validated
   599	        if candidate is None and default:
   600	            guess = renders_dir / default
   601	            if guess.is_file():
   602	                try:
   603	                    rel = str(guess.resolve().relative_to(_REPO_ROOT.resolve()))
   604	                    if _safe_rel_under(rel, _RENDERS_ROOT):
   605	                        candidate = rel
   606	                except ValueError:
   607	                    pass
   608	        return candidate or ""
   609	
   610	    # _rel = repo-relative path (PDF base_url=_REPO_ROOT resolves it).
   611	    # _url = browser URL (HTML served at /api/... needs an absolute path
   612	    # that hits the working renders route — repo-relative paths would
   613	    # otherwise resolve against the /api/cases/... URL and 404).
   614	    def _url(basename: str) -> str:
   615	        return f"/api/cases/{case_id}/runs/{run_label}/renders/{basename}"
   616	
   617	    renders = {
   618	        "contour_png_rel": _rel("contour_u_magnitude_png", "contour_u_magnitude.png"),
   619	        "residuals_png_rel": _rel("residuals_png", "residuals.png"),
   620	        "contour_png_url": _url("contour_u_magnitude.png"),
   621	        "residuals_png_url": _url("residuals.png"),
   622	        # Unified field read by the template — PDF mode gets repo-rel
   623	        # paths (WeasyPrint base_url resolves them); HTML browser mode
   624	        # gets API URLs that the /renders/ route serves.
   625	        "contour_png": _rel("contour_u_magnitude_png", "contour_u_magnitude.png") if for_pdf else _url("contour_u_magnitude.png"),
   626	        "residuals_png": _rel("residuals_png", "residuals.png") if for_pdf else _url("residuals.png"),
   627	    }
   628	
   629	    # Detect solver name from which log.<solver> file exists in artifact dir.
   630	    solver = "unknown"
   631	    for cand in ("simpleFoam", "icoFoam", "pimpleFoam", "buoyantFoam"):
   632	        if (artifact_dir / f"log.{cand}").is_file():
   633	            solver = cand
   634	            break
   635	    commit_sha = _get_commit_sha()
   636	
   637	    # DEC-V61-052 Batch D: BFS scalar-anchor Xr/H comparison. Reads the
   638	    # audit measurement + gold anchor and emits a compact scalar block
   639	    # that the frontend Compare tab renders as a card (mirrors LDC D7
   640	    # primary-vortex shape). Fail-soft: any missing piece → None, card
   641	    # silently hides. Other visual-only cases (plane_channel_flow,
   642	    # turbulent_flat_plate, etc.) see None here until their own anchors
   643	    # are wired — this is intentionally narrow scope.
   644	    metrics_reattachment: Optional[dict] = None
   645	    paper_reattachment: Optional[dict] = None
   646	    if case_id == "backward_facing_step":
   647	        try:
   648	            meas_path = (_REPO_ROOT / "ui/backend/tests/fixtures/runs"
   649	                         / case_id / f"{run_label}_measurement.yaml")
   650	            if meas_path.is_file():
   651	                meas = yaml.safe_load(meas_path.read_text(encoding="utf-8")) or {}
   652	                m = meas.get("measurement", {}) or {}
   653	                actual = m.get("value")
   654	                # DEC-V61-052 Codex r3 #3: prefer the explicit extractor
   655	                # method key (wall_shear_tau_x_zero_crossing / near_wall_
   656	                # tau_x_proxy_via_Ux) over the generic extraction_source
   657	                # (key_quantities_direct / comparator_deviation / ...),
   658	                # so the Compare tab can tell authoritative wall-shear
   659	                # success from proxy fallback.
   660	                method = m.get("reattachment_method") or m.get("extraction_source")
   661	                if actual is not None:
   662	                    gold = _load_bfs_reattachment_gold()
   663	                    if gold is not None:
   664	                        actual_f = float(actual)
   665	                        expected = gold["value"]
   666	                        dev_pct = (actual_f - expected) / expected * 100 if expected else 0.0
   667	                        tol_pct = gold["tolerance"] * 100.0
   668	                        metrics_reattachment = {
   669	                            "quantity": "reattachment_length",
   670	                            "symbol": "Xr/H",
   671	                            "actual": actual_f,
   672	                            "expected": expected,
   673	                            "deviation_pct": dev_pct,
   674	                            "tolerance_pct": tol_pct,
   675	                            "within_tolerance": abs(dev_pct) <= tol_pct,
   676	                            "method": method,
   677	                        }
   678	                        paper_reattachment = {
   679	                            "source": gold["source"],
   680	                            "doi": gold.get("literature_doi", ""),
   681	                            "short": "Driver 1985 / LMK 1997",
   682	                            "tolerance_pct": tol_pct,
   683	                        }
   684	        except (OSError, yaml.YAMLError, ValueError, TypeError):
   685	            metrics_reattachment = None
   686	            paper_reattachment = None
   687	
   688	    # DEC-V61-053 Batch D: cylinder 4-scalar anchor cards (Type I case).
   689	    # Mirrors BFS single-scalar pattern above × 4 observables:
   690	    #   D-St   (strouhal_number, headline gate)
   691	    #   D-Cd   (cd_mean)
   692	    #   D-Cl   (cl_rms)
   693	    #   D-u@4  (u_mean_centerline profile, 4 x_D stations)
   694	    # Emission path: measurement.value is the headline St; cd_mean / cl_rms
   695	    # / deficit_x_over_D_* come from measurement.secondary_scalars (Batch C
   696	    # schema). Until a live solver run regenerates the fixture with the
   697	    # new primary+secondary surface, all 4 return None (silently hidden).
   698	    metrics_strouhal: Optional[dict] = None
   699	    paper_strouhal: Optional[dict] = None
   700	    metrics_cd_mean: Optional[dict] = None
   701	    paper_cd_mean: Optional[dict] = None
   702	    metrics_cl_rms: Optional[dict] = None
   703	    paper_cl_rms: Optional[dict] = None
   704	    metrics_u_centerline: Optional[dict] = None
   705	    paper_u_centerline: Optional[dict] = None
   706	    if case_id == "circular_cylinder_wake":
   707	        try:
   708	            meas_path = (_REPO_ROOT / "ui/backend/tests/fixtures/runs"
   709	                         / case_id / f"{run_label}_measurement.yaml")
   710	            if meas_path.is_file():
   711	                meas = yaml.safe_load(meas_path.read_text(encoding="utf-8")) or {}
   712	                m = meas.get("measurement", {}) or {}
   713	                primary_quantity = m.get("quantity")
   714	                primary_value = m.get("value")
   715	                secondary = m.get("secondary_scalars") or {}
   716	
   717	                # D-St · primary-scalar path
   718	                if primary_quantity == "strouhal_number" and primary_value is not None:
   719	                    gold = _load_cylinder_scalar_gold("strouhal_number")
   720	                    if gold is not None:
   721	                        actual_f = float(primary_value)
   722	                        expected = gold["value"]
   723	                        dev_pct = (actual_f - expected) / expected * 100 if expected else 0.0
   724	                        tol_pct = gold["tolerance"] * 100.0
   725	                        metrics_strouhal = {
   726	                            "quantity": "strouhal_number",
   727	                            "symbol": "St",
   728	                            "actual": actual_f,
   729	                            "expected": expected,
   730	                            "deviation_pct": dev_pct,
   731	                            "tolerance_pct": tol_pct,
   732	                            "within_tolerance": abs(dev_pct) <= tol_pct,
   733	                            "method": m.get("extraction_source"),
   734	                        }
   735	                        paper_strouhal = {
   736	                            "source": gold["source"],
   737	                            "doi": gold.get("literature_doi", ""),
   738	                            "short": "Williamson 1996",
   739	                            "tolerance_pct": tol_pct,
   740	                        }
   741	
   742	                # D-Cd, D-Cl · secondary_scalars path (Batch C schema)
   743	                for sec_name, metrics_var_name, paper_var_name, symbol in [
   744	                    ("cd_mean", "metrics_cd_mean", "paper_cd_mean", "C_d"),
   745	                    ("cl_rms", "metrics_cl_rms", "paper_cl_rms", "C_l,rms"),
   746	                ]:
   747	                    sec_val = secondary.get(sec_name)
   748	                    if isinstance(sec_val, (int, float)):
   749	                        gold = _load_cylinder_scalar_gold(sec_name)
   750	                        if gold is not None:
   751	                            actual_f = float(sec_val)
   752	                            expected = gold["value"]
   753	                            dev_pct = (actual_f - expected) / expected * 100 if expected else 0.0
   754	                            tol_pct = gold["tolerance"] * 100.0
   755	                            _metrics_block = {
   756	                                "quantity": sec_name,
   757	                                "symbol": symbol,
   758	                                "actual": actual_f,
   759	                                "expected": expected,
   760	                                "deviation_pct": dev_pct,
   761	                                "tolerance_pct": tol_pct,
   762	                                "within_tolerance": abs(dev_pct) <= tol_pct,
   763	                                "method": "forceCoeffs_time_average",
   764	                            }
   765	                            _paper_block = {
   766	                                "source": gold["source"],
   767	                                "doi": gold.get("literature_doi", ""),
   768	                                "short": "Williamson 1996",
   769	                                "tolerance_pct": tol_pct,
   770	                            }
   771	                            if metrics_var_name == "metrics_cd_mean":
   772	                                metrics_cd_mean = _metrics_block
   773	                                paper_cd_mean = _paper_block
   774	                            else:
   775	                                metrics_cl_rms = _metrics_block
   776	                                paper_cl_rms = _paper_block
   777	
   778	                # D-u_centerline · 4-station profile from deficit_x_over_D_* keys
   779	                gold_centerline = _load_cylinder_centerline_gold()
   780	                if gold_centerline is not None:
   781	                    station_rows: list[dict] = []
   782	                    for gs in gold_centerline["stations"]:
   783	                        x_D = gs["x_D"]
