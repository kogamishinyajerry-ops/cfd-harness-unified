   164	def _load_ldc_v_gold() -> tuple[list[float], list[float], dict] | None:
   165	    """Load the v_centerline gold block from lid_driven_cavity.yaml.
   166	
   167	    DEC-V61-050 batch 1: returns (xs, vs, doc) for the Ghia 1982 Table II
   168	    Re=100 native 17-point non-uniform x grid + v values. Returns None if
   169	    the block is missing, empty, or still uses the legacy y-indexed shape
   170	    (silent degrade — caller treats absence as "v_centerline not
   171	    exercised for this case"). Reads the SAME multi-doc YAML as
   172	    _load_ldc_gold so both share a single IO.
   173	    """
   174	    gold_path = _GOLD_ROOT / "lid_driven_cavity.yaml"
   175	    if not gold_path.is_file():
   176	        return None
   177	    docs = list(yaml.safe_load_all(gold_path.read_text(encoding="utf-8")))
   178	    v_doc = next(
   179	        (d for d in docs if isinstance(d, dict) and d.get("quantity") == "v_centerline"),
   180	        None,
   181	    )
   182	    if v_doc is None:
   183	        return None
   184	    xs: list[float] = []
   185	    vs: list[float] = []
   186	    for entry in v_doc.get("reference_values", []):
   187	        if not isinstance(entry, dict):
   188	            continue
   189	        # Post-DEC-V61-050-batch-1 shape: {x: float, v: float}. Old shape
   190	        # pre-batch-1 was {y: float, v: float} (axis-label bug). Accept
   191	        # the new shape only — the old shape's values were unusable even
   192	        # if read, so silently return None rather than degrade to garbage.
   193	        x = entry.get("x")
   194	        v = entry.get("value") or entry.get("v")
   195	        if x is not None and v is not None:
   196	            xs.append(float(x))
   197	            vs.append(float(v))
   198	    if not xs:
   199	        return None
   200	    return xs, vs, v_doc
   201	
