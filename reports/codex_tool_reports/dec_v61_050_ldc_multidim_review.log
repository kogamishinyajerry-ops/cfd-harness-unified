   203	def _load_ldc_vortex_gold() -> dict | None:
   204	    """Load the primary_vortex_location gold block from lid_driven_cavity.yaml.
   205	
   206	    DEC-V61-050 batch 3: returns the dict with {vortex_center_x,
   207	    vortex_center_y, psi_min, position_tolerance, psi_tolerance, source}
   208	    extracted from the reference_values entries. Returns None if the
   209	    block is missing or still has the pre-batch-3 shape (x=0.5, y=0.7650).
   210	    """
   211	    gold_path = _GOLD_ROOT / "lid_driven_cavity.yaml"
   212	    if not gold_path.is_file():
   213	        return None
   214	    docs = list(yaml.safe_load_all(gold_path.read_text(encoding="utf-8")))
   215	    pv_doc = next(
   216	        (d for d in docs if isinstance(d, dict) and d.get("quantity") == "primary_vortex_location"),
   217	        None,
   218	    )
   219	    if pv_doc is None:
   220	        return None
   221	    rvs = {
   222	        entry.get("name"): entry.get("value")
   223	        for entry in pv_doc.get("reference_values", [])
   224	        if isinstance(entry, dict)
   225	    }
   226	    # Require all three Ghia Table III fields. Pre-batch-3 block had
   227	    # u_min instead of psi_min — we refuse to load that and silently
   228	    # return None so the comparator degrades rather than reporting
   229	    # garbage against the wrong reference.
   230	    if "vortex_center_x" not in rvs or "vortex_center_y" not in rvs or "psi_min" not in rvs:
   231	        return None
   232	    return {
   233	        "vortex_center_x": float(rvs["vortex_center_x"]),
   234	        "vortex_center_y": float(rvs["vortex_center_y"]),
   235	        "psi_min": float(rvs["psi_min"]),
   236	        "position_tolerance": float(pv_doc.get("position_tolerance", 0.02)),
   237	        "psi_tolerance": float(pv_doc.get("psi_tolerance", 0.05)),
   238	        "source": pv_doc.get("source", "Ghia 1982 Table III"),
   239	        "literature_doi": pv_doc.get("literature_doi", "10.1016/0021-9991(82)90058-4"),
   240	    }
