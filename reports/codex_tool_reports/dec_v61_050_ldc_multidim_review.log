   436	
   437	def _compute_metrics(
   438	    y_sim: np.ndarray, u_sim: np.ndarray,
   439	    y_gold: list[float], u_gold: list[float],
   440	    tolerance_pct: float,
   441	) -> dict[str, Any]:
   442	    """Compute L2/Linf/RMS + per-point |dev|% + pass count."""
   443	    y_sim_norm = y_sim / max(float(y_sim.max()), 1e-12)
   444	    u_sim_interp = np.interp(np.array(y_gold), y_sim_norm, u_sim)
   445	    u_gold_arr = np.array(u_gold)
   446	    diff = u_sim_interp - u_gold_arr
   447	
   448	    denom = np.where(np.abs(u_gold_arr) < 1e-9, 1e-9, np.abs(u_gold_arr))
   449	    dev_pct = 100.0 * np.abs(diff) / denom
   450	    n_total = len(u_gold_arr)
   451	    n_pass = int((dev_pct < tolerance_pct).sum())
   452	
   453	    return {
   454	        "l2": float(np.sqrt(np.mean(diff ** 2))),
   455	        "linf": float(np.max(np.abs(diff))),
   456	        "rms": float(np.sqrt(np.mean(diff ** 2))),  # alias
   457	        "max_dev_pct": float(dev_pct.max()) if n_total else 0.0,
   458	        "n_pass": n_pass,
   459	        "n_total": n_total,
   460	        "per_point_dev_pct": dev_pct.tolist(),
   461	    }
   462	
   463	
   464	def _parse_residuals_csv(path: Path) -> dict[str, Any]:
   465	    if not path.is_file():
   466	        return {"total_iter": 0, "final_ux": None, "note": None}
   467	    lines = path.read_text(encoding="utf-8").splitlines()
   468	    if len(lines) < 2:
   469	        return {"total_iter": 0, "final_ux": None, "note": None}
   470	    header = [c.strip() for c in lines[0].split(",")]
   471	    last = None
   472	    count = 0
   473	    for ln in lines[1:]:
   474	        parts = [c.strip() for c in ln.split(",")]
   475	        if len(parts) != len(header):
   476	            continue
   477	        last = parts
   478	        count += 1
   479	    final_ux = None
   480	    if last is not None and len(last) > 1 and last[1].upper() != "N/A":
   481	        try:
   482	            final_ux = float(last[1])
   483	        except ValueError:
   484	            pass
   485	    note = None
   486	    if final_ux is not None and final_ux > 1e-3:
   487	        note = (f"注意：Ux 终值 {final_ux:.2e} 大于 1e-3 — "
   488	                f"收敛可能未达稳态。建议增加 endTime 或降低 residualControl。")
   489	    return {"total_iter": count, "final_ux": final_ux, "note": note}
   490	
   491	
   492	def _load_grid_convergence(case_id: str, gold_y: list[float], gold_u: list[float]) -> tuple[list[dict], str]:
   493	    """Read mesh_20/40/80/160_measurement.yaml fixtures, build table rows."""
   494	    rows: list[dict] = []
   495	    # LDC fixtures compare at y≈0.0625 (first gold point >0).
   496	    sample_y = 0.0625
   497	    try:
   498	        sample_gold = next(u for y, u in zip(gold_y, gold_u) if abs(y - sample_y) < 1e-3)
   499	    except StopIteration:
   500	        sample_gold = gold_u[1] if len(gold_u) > 1 else 0.0
   501	
   502	    case_dir = _FIXTURE_ROOT / case_id
   503	    meshes = [("mesh_20", 20), ("mesh_40", 40), ("mesh_80", 80), ("mesh_160", 160)]
   504	    for name, _n in meshes:
   505	        path = case_dir / f"{name}_measurement.yaml"
   506	        if not path.is_file():
   507	            continue
   508	        doc = yaml.safe_load(path.read_text(encoding="utf-8"))
   509	        meas = doc.get("measurement", {}) if isinstance(doc, dict) else {}
   510	        val = meas.get("value")
   511	        if val is None:
   512	            continue
   513	        try:
   514	            val_f = float(val)
   515	        except (ValueError, TypeError):
   516	            continue
   517	        denom = abs(sample_gold) if abs(sample_gold) > 1e-9 else 1e-9
   518	        dev_pct = 100.0 * abs(val_f - sample_gold) / denom
   519	        if dev_pct < 5.0:
   520	            verdict, cls = "PASS", "pass"
   521	        elif dev_pct < 10.0:
   522	            verdict, cls = "WARN", "warn"
   523	        else:
   524	            verdict, cls = "FAIL", "fail"
   525	        rows.append({
   526	            "mesh": name,
   527	            "value": val_f,
   528	            "dev_pct": dev_pct,
   529	            "verdict": verdict,
   530	            "verdict_class": cls,
   531	        })
   532	    if len(rows) < 2:
   533	        return rows, "insufficient mesh data"
   534	    devs = [r["dev_pct"] for r in rows]
   535	    monotone = all(devs[i] >= devs[i + 1] for i in range(len(devs) - 1))
   536	    note = "单调递减 ✓" if monotone else "非严格单调 — 检查 fixture"
   537	    return rows, note
   538	
