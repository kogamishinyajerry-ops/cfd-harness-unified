  2427	function ResidualsPreview() {
  2428	  const SERIES = useMemo(() => {
  2429	    const makeSeries = (decay: number, noise: number, seed: number) => {
  2430	      const pts: [number, number][] = [];
  2431	      let val = 1;
  2432	      for (let i = 0; i <= 60; i++) {
  2433	        val *= decay;
  2434	        const jitter = Math.sin(i * 0.7 + seed) * noise * val;
  2435	        pts.push([i, Math.max(val + jitter, 1e-6)]);
  2436	      }
  2437	      return pts;
  2438	    };
  2439	    return [
  2440	      { key: "p", color: "#60a5fa", pts: makeSeries(0.9, 0.2, 0.1) },
  2441	      { key: "Ux", color: "#a78bfa", pts: makeSeries(0.91, 0.22, 1.3) },
  2442	      { key: "Uy", color: "#f472b6", pts: makeSeries(0.92, 0.18, 2.1) },
  2443	    ];
  2444	  }, []);
  2445	
  2446	  const W = 560;
  2447	  const H = 160;
  2448	  const PADL = 36;
  2449	  const PADR = 12;
  2450	  const PADT = 8;
  2451	  const PADB = 22;
  2452	
  2453	  const xToPx = (x: number) => PADL + (x / 60) * (W - PADL - PADR);
  2454	  const yToPx = (y: number) => {
  2455	    // log scale from 1 down to 1e-6
  2456	    const logY = Math.log10(Math.max(y, 1e-6));
  2457	    const frac = (0 - logY) / 6; // 0 at top, 1 at bottom
  2458	    return PADT + frac * (H - PADT - PADB);
  2459	  };
