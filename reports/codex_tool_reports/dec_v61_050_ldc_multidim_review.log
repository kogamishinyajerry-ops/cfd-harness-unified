   393	def _load_sample_xy(path: Path, value_col: int = 1) -> tuple[np.ndarray, np.ndarray]:
   394	    """Load an OpenFOAM raw-xy sample file. Returns (coord, value) arrays.
   395	
   396	    OpenFOAM's lineUniform function object writes either 2-col files
   397	    (coord + single-field-scalar) or 5-col files (coord + U_x + U_y + U_z
   398	    + p) depending on fields requested. Col 0 is always the sampling axis
   399	    coordinate. For u_centerline (sampled along y, U_x is the observable)
   400	    value_col=1 is correct. For v_centerline (sampled along x, U_y is the
   401	    observable) value_col=2.
   402	
   403	    DEC-V61-050 batch 1: value_col parameter added so a single helper
   404	    services both LDC observables without duplicating parser code.
   405	    """
   406	    rows = []
   407	    for line in path.read_text(encoding="utf-8").splitlines():
   408	        s = line.strip()
   409	        if not s or s.startswith("#"):
   410	            continue
   411	        parts = s.split()
   412	        try:
   413	            if value_col >= len(parts):
   414	                continue
   415	            rows.append([float(parts[0]), float(parts[value_col])])
   416	        except (ValueError, IndexError):
   417	            continue
   418	    if not rows:
   419	        raise ReportError(f"empty sample: {path}")
   420	    arr = np.array(rows)
   421	    return arr[:, 0], arr[:, 1]
   422	
   423	
   424	def _latest_sample_iter(artifact_dir: Path) -> Path:
   425	    sample_root = artifact_dir / "sample"
   426	    if not sample_root.is_dir():
   427	        raise ReportError(f"sample/ missing under {artifact_dir}")
   428	    iters = sorted(
   429	        (d for d in sample_root.iterdir() if d.is_dir() and d.name.isdigit()),
   430	        key=lambda d: int(d.name),
   431	    )
   432	    if not iters:
   433	        raise ReportError(f"no sample iter dirs under {sample_root}")
   434	    return iters[-1]
