   102	def mesh_imported_case(
   103	    case_id: str,
   104	    *,
   105	    mesh_mode: MeshMode = "beginner",
   106	    container_name: str | None = None,
   107	) -> MeshResult:
   108	    """Run the full M6.0 pipeline for the given imported case_id.
   109	
   110	    Raises :class:`MeshPipelineError` whose ``failing_check`` attribute
   111	    is one of :data:`FailingCheck`. The route maps each value to an
   112	    HTTP 4xx response.
   113	    """
   114	    case_dir, stl_path = _resolve_imported_case(case_id)
   115	    msh_path = case_dir / "imported.msh"
   116	
   117	    try:
   118	        gmsh_result: GmshRunResult = run_gmsh_on_imported_case(
   119	            stl_path=stl_path,
   120	            output_msh_path=msh_path,
   121	            mesh_mode=mesh_mode,
   122	        )
   123	    except GmshMeshGenerationError as exc:
   124	        raise MeshPipelineError(str(exc), "gmsh_diverged") from exc
   125	    # Other exception types (ModuleNotFoundError when [workbench] isn't
   126	    # installed, OSError on disk failure) are backend / configuration
   127	    # faults — let those bubble as 5xx instead of misattributing them
   128	    # as user-geometry rejections. gmsh_runner is responsible for
   129	    # converting raw gmsh-binding errors into GmshMeshGenerationError.
   130	
   131	    verdict: BudgetVerdict = classify_cell_count(gmsh_result.cell_count, mesh_mode)
   132	    if not verdict.ok:
   133	        # Drop the stale .msh so the next attempt is not confused by a
   134	        # leftover oversized mesh file. Codex Round 8 Finding 2: collapse
   135	        # the exists()→unlink() TOCTTOU window via missing_ok=True so a
   136	        # concurrent deletion can't leak a raw FileNotFoundError 500
   137	        # ahead of the structured cap_exceeded rejection.
   138	        msh_path.unlink(missing_ok=True)
   139	        raise MeshPipelineError(
   140	            verdict.rejection_reason or "cell budget exceeded",
   141	            "cell_cap_exceeded",
   142	        )
   143	
   144	    try:
   145	        if container_name:
   146	            foam_result = run_gmsh_to_foam(
   147	                case_host_dir=case_dir,
   148	                container_name=container_name,
   149	            )
   150	        else:
   151	            foam_result = run_gmsh_to_foam(case_host_dir=case_dir)
   152	    except GmshToFoamError as exc:
   153	        raise MeshPipelineError(str(exc), "gmshToFoam_failed") from exc
   154	    # Host-side failures escaping run_gmsh_to_foam (tarfile errors,
   155	    # PermissionError, disk full) are not docker / container faults —
   156	    # surface them as 5xx so diagnosis is not misdirected. to_foam.py
   157	    # is responsible for wrapping all docker SDK calls itself.
   158	
   159	    return MeshResult(
   160	        case_id=case_id,
   161	        mesh_mode=mesh_mode,
   162	        cell_count=gmsh_result.cell_count,
   163	        face_count=gmsh_result.face_count,
   164	        point_count=gmsh_result.point_count,
   165	        polyMesh_path=foam_result.polyMesh_dir,
   166	        msh_path=msh_path,
   167	        generation_time_s=gmsh_result.generation_time_s,
   168	        warning=verdict.warning,
   169	    )

