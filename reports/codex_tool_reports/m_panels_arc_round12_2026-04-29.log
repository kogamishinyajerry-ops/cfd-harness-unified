     1	"""POST /api/import/{case_id}/mesh — M6.0 gmsh meshing route.
     2	
     3	Consumes the M5.0 imported case scaffold (triSurface + STL on disk),
     4	runs gmsh + gmshToFoam, and writes ``constant/polyMesh/`` so the M6.1
     5	trust-core executor patch can skip ``blockMesh``.
     6	"""
     7	from __future__ import annotations
     8	
     9	from fastapi import APIRouter, HTTPException
    10	
    11	from ui.backend.schemas.mesh_imported import (
    12	    MeshRejection,
    13	    MeshRequest,
    14	    MeshSuccessResponse,
    15	    MeshSummary,
    16	)
    17	from ui.backend.services.meshing_gmsh import MeshResult, mesh_imported_case
    18	from ui.backend.services.meshing_gmsh.pipeline import (
    19	    FailingCheck,
    20	    MeshPipelineError,
    21	)
    22	
    23	
    24	router = APIRouter()
    25	
    26	
    27	# Map pipeline failing_check enum → HTTP status. case_not_found is the
    28	# only 404; the rest are 4xx user errors (geometry quality / sizing).
    29	_STATUS_FOR_FAILING_CHECK: dict[FailingCheck, int] = {
    30	    "case_not_found": 404,
    31	    "source_not_imported": 400,
    32	    "gmsh_diverged": 422,
    33	    "cell_cap_exceeded": 422,
    34	    "gmshToFoam_failed": 502,  # downstream container-side failure
    35	}
    36	
    37	
    38	def _result_to_response(result: MeshResult) -> MeshSuccessResponse:
    39	    return MeshSuccessResponse(
    40	        case_id=result.case_id,
    41	        mesh_summary=MeshSummary(
    42	            cell_count=result.cell_count,
    43	            face_count=result.face_count,
    44	            point_count=result.point_count,
    45	            mesh_mode_used=result.mesh_mode,
    46	            polyMesh_path=str(result.polyMesh_path),
    47	            msh_path=str(result.msh_path),
    48	            generation_time_s=result.generation_time_s,
    49	            warning=result.warning,
    50	        ),
    51	    )
    52	
    53	
    54	@router.post(
    55	    "/import/{case_id}/mesh",
    56	    response_model=MeshSuccessResponse,
    57	)
    58	def mesh_imported_route(
    59	    case_id: str,
    60	    request: MeshRequest,
    61	) -> MeshSuccessResponse:
    62	    # Intentionally synchronous: gmsh + gmshToFoam can take 30-300s on
    63	    # real geometry. An async handler would block the FastAPI event
    64	    # loop for that whole window and starve unrelated routes
    65	    # (/api/health, SSE streams). Synchronous routes run in FastAPI's
    66	    # default threadpool, so a long mesh blocks one worker thread but
    67	    # leaves the event loop free.
    68	    try:
    69	        result = mesh_imported_case(case_id, mesh_mode=request.mesh_mode)
    70	    except MeshPipelineError as exc:
    71	        rejection = MeshRejection(
    72	            reason=str(exc),
    73	            failing_check=exc.failing_check,
    74	        )
    75	        raise HTTPException(
    76	            status_code=_STATUS_FOR_FAILING_CHECK.get(exc.failing_check, 400),
    77	            detail=rejection.model_dump(),
    78	        ) from exc
    79	
    80	    return _result_to_response(result)

