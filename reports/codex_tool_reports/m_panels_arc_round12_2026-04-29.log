    78	    dest_dir.mkdir(parents=True, exist_ok=True)
    79	    buf = io.BytesIO(stream_bytes)
    80	    with tarfile.open(fileobj=buf, mode="r") as tar:
    81	        tar.extractall(path=dest_dir, filter="data")
