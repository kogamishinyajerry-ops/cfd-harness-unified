    62	def _make_tarball(host_dir: Path) -> bytes:
    63	    """Pack ``host_dir`` recursively into an in-memory tarball, retagged
    64	    for the cfd-openfoam container's UID/GID so gmshToFoam can write
    65	    polyMesh + log files into the staged case dir.
    66	    """
    67	    buf = io.BytesIO()
    68	    with tarfile.open(fileobj=buf, mode="w") as tar:
    69	        tar.add(str(host_dir), arcname=host_dir.name, filter=_retag_for_container)
    70	    return buf.getvalue()
