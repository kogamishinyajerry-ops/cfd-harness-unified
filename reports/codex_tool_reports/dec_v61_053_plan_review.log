   659	    def _turbulence_model_for_solver(
   660	        self, solver_name: str, geometry_type: GeometryType, Re: Optional[float] = None
   661	    ) -> str:
   662	        """Auto-select turbulence model based on solver family.
   663	
   664	        Core rule: buoyantFoam family -> kEpsilon (avoids OF10 kOmegaSST dimension bug);
   665	        SIMPLE_GRID laminar -> laminar; others -> kOmegaSST.
   666	        """
   667	        if "buoyant" in solver_name:
   668	            return "kEpsilon"
   669	        if geometry_type == GeometryType.SIMPLE_GRID and Re is not None and Re < 2300:
   670	            return "laminar"
   671	        return "kOmegaSST"
