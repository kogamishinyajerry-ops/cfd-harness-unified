    75	    def evaluate_all(
    76	        self,
    77	        artifacts: Dict[str, Any],
    78	        observable_defs: Dict[str, Dict[str, Any]],
    79	        tolerance_policy: Optional[Dict[str, Any]] = None,
    80	    ) -> List[MetricReport]:
    81	        """Evaluate every registered metric that has a matching observable def.
    82	
    83	        Args:
    84	            artifacts: ExecutionArtifacts bundle (file paths / in-memory data).
    85	                Read-only from the Metric's perspective (Evaluation ↛ Execution
    86	                per ADR-001).
    87	            observable_defs: mapping from metric name → observable definition
    88	                (per KNOWLEDGE §1 draft; typically loaded from gold YAML).
    89	            tolerance_policy: CaseProfile.tolerance_policy per VCP §8.2 →
    90	                METRICS §4 accepting clause. May override
    91	                observable_def.tolerance on a per-name basis.
    92	
    93	        Returns:
    94	            List of MetricReport in registered-name sort order. Metrics
    95	            lacking a matching observable_def are skipped silently (not an
    96	            error — registry can be broader than a given case's expected
    97	            observables).
    98	        """
    99	        reports: List[MetricReport] = []
   100	        for name in self.names():
   101	            metric = self._metrics[name]
   102	            obs_def = observable_defs.get(name)
   103	            if obs_def is None:
   104	                continue
   105	            # Per-metric dispatch: only the named entry (observable name key)
   106	            # applies. Do NOT fall back to the whole policy dict — that would
   107	            # leak a top-level `tolerance` override into unrelated metrics
   108	            # (Codex DEC-V61-054 R1 finding #2). Documented semantics per
   109	            # METRICS_AND_TRUST_GATES §4: `tolerance_policy[<observable_name>]`.
   110	            per_metric_tol = (
   111	                tolerance_policy.get(name) if tolerance_policy is not None else None
   112	            )
   113	            reports.append(metric.evaluate(artifacts, obs_def, per_metric_tol))
   114	        return reports

