    19	    tolerance_policy:       # P1-T3 (NEW · optional block)
    20	      <observable_name>:
    21	        tolerance: <float>  # relative tolerance 0..1 (e.g. 0.05 = 5%)
    22	      <observable_name>:
    23	        tolerance: <float>
    24	      ...
    25	
    26	Absent `tolerance_policy` block or absent case file ⇒ empty dict
    27	(downstream MetricsRegistry falls through to observable_def.tolerance).
    28	
    29	Plane: Evaluation. Reads YAML via file I/O (not module import) —
    30	ADR-001 plane contracts govern Python import graph, not file reads.
    31	Allowed to read from `.planning/case_profiles/` (repo-relative config).
    32	"""
    33	
    34	from __future__ import annotations
    35	
    36	from pathlib import Path
    37	from typing import Any, Dict, Optional
    38	
    39	import yaml
    40	
    41	
    42	# Repo-root-relative path. Resolved lazily so tests can override.
    43	_DEFAULT_CASE_PROFILES_DIR = Path(".planning/case_profiles")
    44	
    45	
    46	class CaseProfileError(Exception):
    47	    """Raised when a CaseProfile YAML file is malformed beyond
    48	    recoverable defaults (e.g. YAML syntax error, unexpected top-level
    49	    type, tolerance_policy not a dict)."""
    50	
    51	
    52	def _resolve_case_profiles_dir(override: Optional[Path]) -> Path:
    53	    if override is not None:
    54	        return override
    55	    # Walk up from this module's file to find the repo root (where
    56	    # .planning lives). Falls back to cwd-relative if structure changes.
    57	    here = Path(__file__).resolve()
    58	    for parent in [here.parent, *here.parents]:
    59	        candidate = parent / ".planning" / "case_profiles"
    60	        if candidate.is_dir():
    61	            return candidate
    62	    return _DEFAULT_CASE_PROFILES_DIR
    63	
    64	
    65	def load_case_profile(
    66	    case_id: str,
    67	    *,
    68	    case_profiles_dir: Optional[Path] = None,
    69	) -> Optional[Dict[str, Any]]:
    70	    """Return the full parsed CaseProfile dict, or None if the file is absent.
    71	
    72	    Used mainly by `load_tolerance_policy`; exposed for callers that need
    73	    other sections (risk_flags, last_assessed, etc.).
    74	
    75	    Raises CaseProfileError on malformed YAML.
    76	    """
    77	    root = _resolve_case_profiles_dir(case_profiles_dir)
    78	    path = root / f"{case_id}.yaml"
    79	    if not path.is_file():
    80	        return None
    81	    try:
    82	        with path.open("r", encoding="utf-8") as fh:
    83	            parsed = yaml.safe_load(fh)
    84	    except yaml.YAMLError as exc:
    85	        raise CaseProfileError(
    86	            f"CaseProfile YAML malformed for {case_id!r} at {path}: {exc}"
    87	        ) from exc
    88	
    89	    if parsed is None:
    90	        # Empty file — treat as missing sections rather than error.
    91	        return {}
    92	    if not isinstance(parsed, dict):
    93	        raise CaseProfileError(
    94	            f"CaseProfile {case_id!r} top-level must be a mapping; got "
    95	            f"{type(parsed).__name__} at {path}"
    96	        )
    97	    return parsed
    98	
    99	
   100	def load_tolerance_policy(
   101	    case_id: str,
   102	    *,
   103	    case_profiles_dir: Optional[Path] = None,
   104	) -> Dict[str, Dict[str, Any]]:
   105	    """Load `tolerance_policy` for `case_id` in the shape that
   106	    `MetricsRegistry.evaluate_all` accepts.
   107	
   108	    Returns an empty dict when:
   109	    - Case file is absent
   110	    - File is empty / present but no tolerance_policy block
   111	
   112	    Raises CaseProfileError when:
   113	    - YAML is malformed
   114	    - `tolerance_policy` exists but is not a mapping
   115	    - A per-observable entry exists but is not a mapping
   116	    - A `tolerance` field is present but is not a finite number
   117	    """
   118	    profile = load_case_profile(case_id, case_profiles_dir=case_profiles_dir)
   119	    if not profile:
   120	        return {}
   121	
   122	    raw = profile.get("tolerance_policy")
   123	    if raw is None:
   124	        return {}
   125	    if not isinstance(raw, dict):
   126	        raise CaseProfileError(
   127	            f"CaseProfile {case_id!r} tolerance_policy must be a mapping; "
   128	            f"got {type(raw).__name__}"
   129	        )
   130	
   131	    normalized: Dict[str, Dict[str, Any]] = {}
   132	    for obs_name, entry in raw.items():
   133	        if not isinstance(obs_name, str) or not obs_name.strip():
   134	            raise CaseProfileError(
   135	                f"CaseProfile {case_id!r} tolerance_policy key must be a "
   136	                f"non-empty string; got {obs_name!r}"
   137	            )
   138	        if not isinstance(entry, dict):
   139	            raise CaseProfileError(
   140	                f"CaseProfile {case_id!r} tolerance_policy[{obs_name!r}] "
   141	                f"must be a mapping; got {type(entry).__name__}"
   142	            )
   143	        tol = entry.get("tolerance")
   144	        if tol is not None:
   145	            if not isinstance(tol, (int, float)) or isinstance(tol, bool):
   146	                raise CaseProfileError(
   147	                    f"CaseProfile {case_id!r} tolerance_policy[{obs_name!r}]."
   148	                    f"tolerance must be a number; got {type(tol).__name__}"
   149	                )
   150	            if tol != tol:  # NaN guard (float('nan') != itself)
   151	                raise CaseProfileError(
   152	                    f"CaseProfile {case_id!r} tolerance_policy[{obs_name!r}]."
   153	                    f"tolerance is NaN"
   154	                )
   155	        normalized[obs_name] = dict(entry)  # defensive copy
   156	
   157	    return normalized

