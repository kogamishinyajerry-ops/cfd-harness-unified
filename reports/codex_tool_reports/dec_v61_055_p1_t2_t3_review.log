     1	"""TrustGate overall-verdict reducer · P1-T2.
     2	
     3	Consumes `MetricsRegistry.evaluate_all()` output (List[MetricReport])
     4	and produces a single `TrustGateReport` carrying the worst-wins
     5	aggregated status plus per-metric breakdown and non-PASS notes.
     6	
     7	Aggregation rule (three-state worst-wins per
     8	METRICS_AND_TRUST_GATES §2 → TrustGate §5 accepting clause):
     9	  - any FAIL   → FAIL
    10	  - else any WARN → WARN
    11	  - else       → PASS  (includes empty input = vacuously PASS)
    12	
    13	MVP scope: no policy-driven escalation (e.g. "≥N WARNs = FAIL") —
    14	that ships in a later DEC if case-profile data warrants it. The
    15	reducer is policy-free; consumers can wrap additional logic around it.
    16	
    17	Plane: Evaluation. Pure function over MetricReport values; no I/O,
    18	no plane boundary crossing, no extractor delegate.
    19	"""
    20	
    21	from __future__ import annotations
    22	
    23	from dataclasses import dataclass, field
    24	from typing import Dict, List
    25	
    26	from .base import MetricReport, MetricStatus
    27	
    28	
    29	@dataclass(frozen=True)
    30	class TrustGateReport:
    31	    """Aggregated trust-gate output for a set of metric evaluations.
    32	
    33	    Attributes
    34	    ----------
    35	    overall
    36	        Worst-wins verdict across all input reports. Empty input → PASS.
    37	    reports
    38	        Per-metric MetricReport list in the order provided to the reducer
    39	        (defensive copy — consumers may mutate their original list safely).
    40	    count_by_status
    41	        Histogram keyed by MetricStatus. All three keys always present
    42	        (zero-filled when absent) so consumers can index without KeyError.
    43	    notes
    44	        Aggregated non-PASS notes in report order, formatted
    45	        `"{metric_name} [{status}]: {notes}"` for UI display. Reports
    46	        with status=PASS or notes=None are skipped.
    47	    """
    48	
    49	    overall: MetricStatus
    50	    reports: List[MetricReport]
    51	    count_by_status: Dict[MetricStatus, int]
    52	    notes: List[str] = field(default_factory=list)
    53	
    54	    @property
    55	    def passed(self) -> bool:
    56	        return self.overall is MetricStatus.PASS
    57	
    58	    @property
    59	    def has_failures(self) -> bool:
    60	        return self.count_by_status.get(MetricStatus.FAIL, 0) > 0
    61	
    62	    @property
    63	    def has_warnings(self) -> bool:
    64	        return self.count_by_status.get(MetricStatus.WARN, 0) > 0
    65	
    66	    def summary(self) -> str:
    67	        """Human-readable one-liner for logs / dashboards."""
    68	        parts = [f"TrustGate: {self.overall.value.upper()}"]
    69	        counts = [
    70	            f"PASS={self.count_by_status.get(MetricStatus.PASS, 0)}",
    71	            f"WARN={self.count_by_status.get(MetricStatus.WARN, 0)}",
    72	            f"FAIL={self.count_by_status.get(MetricStatus.FAIL, 0)}",
    73	        ]
    74	        parts.append(" ".join(counts))
    75	        parts.append(f"n={len(self.reports)}")
    76	        return " | ".join(parts)
    77	
    78	
    79	def reduce_reports(reports: List[MetricReport]) -> TrustGateReport:
    80	    """Worst-wins reduction of per-metric reports.
    81	
    82	    Parameters
    83	    ----------
    84	    reports
    85	        Iterable of MetricReport (typically from MetricsRegistry.evaluate_all).
    86	        Empty list is valid → PASS (vacuously true, no metrics registered
    87	        or no observable defs matched).
    88	
    89	    Returns
    90	    -------
    91	    TrustGateReport
    92	        Aggregated verdict + histogram + formatted notes.
    93	    """
    94	    reports_list = list(reports)
    95	
    96	    counts: Dict[MetricStatus, int] = {
    97	        MetricStatus.PASS: 0,
    98	        MetricStatus.WARN: 0,
    99	        MetricStatus.FAIL: 0,
   100	    }
   101	    for rep in reports_list:
   102	        counts[rep.status] = counts.get(rep.status, 0) + 1
   103	
   104	    if counts[MetricStatus.FAIL] > 0:
   105	        overall = MetricStatus.FAIL
   106	    elif counts[MetricStatus.WARN] > 0:
   107	        overall = MetricStatus.WARN
   108	    else:
   109	        overall = MetricStatus.PASS
   110	
   111	    notes = [
   112	        f"{rep.name} [{rep.status.value}]: {rep.notes}"
   113	        for rep in reports_list
   114	        if rep.status is not MetricStatus.PASS and rep.notes
   115	    ]
   116	
   117	    return TrustGateReport(
   118	        overall=overall,
   119	        reports=reports_list,
   120	        count_by_status=counts,
   121	        notes=notes,
   122	    )

