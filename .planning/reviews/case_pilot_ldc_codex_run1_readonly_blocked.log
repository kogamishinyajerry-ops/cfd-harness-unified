  7814	    @staticmethod
  7815	    def _populate_ij_nusselt_from_sampledict(
  7816	        case_dir: Path,
  7817	        task_spec: TaskSpec,
  7818	        key_quantities: Dict[str, Any],
  7819	    ) -> Dict[str, Any]:
  7820	        """If postProcessing/sets/.../plateProbes_T.xy is present, derive
  7821	        Nu from T at the probe points 1mm above the impingement plate.
  7822	
  7823	        Nu = |T_probe - T_plate| · D / (Δz · ΔT_ref)
  7824	
  7825	        where ΔT_ref = T_inlet - T_plate = 20K and Δz = 0.001m match the
  7826	        generator constants (see _generate_impinging_jet). The stagnation
  7827	        probe (smallest r) populates `nusselt_number`; the full profile
  7828	        populates `nusselt_number_profile`.
  7829	
  7830	        Sign convention: absolute value — Nu is a magnitude in all common
  7831	        impinging-jet conventions, regardless of heat-flux direction.
  7832	        """
  7833	        points = _try_load_sampledict_output(case_dir, "plateProbes", "T")
  7834	        if not points:
  7835	            return key_quantities
  7836	        # DEC-V61-042 round-1 FLAG: read BC metadata from task_spec
  7837	        # instead of hard-coding T_plate=290/T_inlet=310/D=0.05 — keeps
  7838	        # this dormant second measurement path consistent with the
  7839	        # primary _extract_jet_nusselt, so if the sampleDict path is
  7840	        # ever reactivated (DEC-V61-044 plans to wire it into
  7841	        # controlDict functions{}) it uses the same ground truth.
  7842	        bc = task_spec.boundary_conditions or {}
  7843	        D_nozzle = bc.get("D_nozzle", 0.05)
  7844	        T_plate = bc.get("T_plate", 290.0)
  7845	        T_inlet = bc.get("T_inlet", 310.0)
  7846	        delta_T_ref = float(T_inlet) - float(T_plate)
  7847	        delta_z = 0.001  # probe offset above the plate; matches sampleDict generator
  7848	        if delta_T_ref <= 0.0 or delta_z <= 0.0:
  7849	            return key_quantities
  7850	        try:
  7851	            sorted_pts = sorted(points, key=lambda p: p[0][0])
  7852	        except (IndexError, TypeError):
  7853	            return key_quantities
  7854	        nu_profile: List[float] = []
  7855	        for coords, values in sorted_pts:
  7856	            if not values:
  7857	                continue
  7858	            try:
  7859	                T_probe = float(values[0])
  7860	            except (ValueError, TypeError):
  7861	                continue
  7862	            d_T = abs(T_probe - float(T_plate))
  7863	            nu_local = (d_T * float(D_nozzle)) / (delta_z * delta_T_ref)
  7864	            nu_profile.append(nu_local)
  7865	        if not nu_profile:
  7866	            return key_quantities
  7867	        key_quantities["nusselt_number"] = nu_profile[0]  # stagnation (smallest r)
  7868	        key_quantities["nusselt_number_profile"] = nu_profile
  7869	        key_quantities["nusselt_number_source"] = "sampleDict_direct"
  7870	        # DEC-V61-042 round-1 FLAG (consistency with volume-cell path):
  7871	        # surface a HAZARD flag on unphysical magnitudes instead of
  7872	        # silently clamping to [0, 500].
  7873	        if not (0.0 <= nu_profile[0] <= 500.0):
  7874	            key_quantities["nusselt_number_unphysical_magnitude"] = True
  7875	        return key_quantities
