    73	class ResultComparator:
    74	    """对比 ExecutionResult 与 Gold Standard
    75	
    76	    支持标量比较（单个数值）和向量比较（列表，取最大偏差）。
    77	    """
    78	
    79	    def __init__(self, threshold: float = 0.10) -> None:
