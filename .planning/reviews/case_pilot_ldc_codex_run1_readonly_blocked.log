   224	        # so comparator silently produced zero deviations and PASSed.
   225	        # Added u_plus (DNS profile) + other known gold-dict scalar keys
   226	        # per Codex DEC-036 round-1 B2 finding.
   227	        _REF_SCALAR_KEYS = ("u", "u_plus", "value", "Nu", "Cp", "Cf", "f", "St")
   228	
   229	        def _pick_ref_scalar(r: Dict[str, Any]) -> Optional[float]:
   230	            for k in _REF_SCALAR_KEYS:
   231	                v = r.get(k)
   232	                if v is not None:
   233	                    return v
   234	            return None
