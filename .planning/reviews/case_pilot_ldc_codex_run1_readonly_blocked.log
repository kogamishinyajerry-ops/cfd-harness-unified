   174	        for ref in reference_values:
   175	            _v = ref.get("value")
   176	            if _v is None: _v = ref.get("Nu")
   177	            if _v is None: _v = ref.get("Cp")
   178	            if _v is None: _v = ref.get("Cf")
   179	            if _v is None: _v = ref.get("u_plus")
   180	            if _v is None: _v = ref.get("f")
