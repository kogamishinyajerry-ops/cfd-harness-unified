  7877	    def _try_populate_from_c3_sampledict(
  7878	        self,
  7879	        case_dir: Path,
  7880	        task_spec: TaskSpec,
  7881	        key_quantities: Dict[str, Any],
  7882	        solver_name: str,
  7883	    ) -> Dict[str, Any]:
  7884	        """Dispatcher called at the end of _extract_case_results.
  7885	
  7886	        Runs after the volume-cell extractors so that when a C3 sampleDict
  7887	        output is present, it OVERWRITES the interpolated value. When no
  7888	        output exists (MOCK executor, pre-C3 case, failed run), the
  7889	        volume-cell value stays. Dispatch by case identity (LDC / NACA /
  7890	        IJ) — all other cases are untouched.
  7891	        """
  7892	        name_lower = (task_spec.name or "").lower()
  7893	        if self._is_lid_driven_cavity_case(task_spec, solver_name):
  7894	            key_quantities = self._populate_ldc_centerline_from_sampledict(
  7895	                case_dir, task_spec, key_quantities
  7896	            )
  7897	        if task_spec.geometry_type == GeometryType.AIRFOIL or "airfoil" in name_lower or "naca" in name_lower:
  7898	            key_quantities = self._populate_naca_cp_from_sampledict(
  7899	                case_dir, task_spec, key_quantities
  7900	            )
  7901	        if task_spec.geometry_type == GeometryType.IMPINGING_JET or "impinging" in name_lower:
  7902	            key_quantities = self._populate_ij_nusselt_from_sampledict(
  7903	                case_dir, task_spec, key_quantities
  7904	            )
  7905	        return key_quantities
