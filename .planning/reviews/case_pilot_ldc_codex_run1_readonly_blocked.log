  1074	
  1075	function MeshTab({ caseId }: { caseId: string }) {
  1076	  const sweep = GRID_CONVERGENCE_CASES[caseId];
  1077	
  1078	  // Unconditionally create state + queries so the hook call count stays
  1079	  // stable regardless of whether this case has a sweep. (React will
  1080	  // throw if hook count varies between renders.)
  1081	  const densities = sweep?.densities ?? [];
  1082	  const [idx, setIdx] = useState(densities.length > 1 ? 2 : 0);
