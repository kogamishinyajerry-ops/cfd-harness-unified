   475	def _find_latest_vtk(artifact_dir: Path) -> Optional[Path]:
   476	    """Return the highest-iteration VTK volume file (not the allPatches one)."""
   477	    vtk_root = artifact_dir / "VTK"
   478	    if not vtk_root.is_dir():
   479	        return None
   480	    # Volume VTK files are at VTK/*.vtk (direct children); boundary data is under VTK/allPatches/.
   481	    candidates = sorted(
