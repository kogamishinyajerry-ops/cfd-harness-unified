   984	function ToleranceBand({
   985	  goldValue,
   986	  lower,
   987	  upper,
   988	  measured,
   989	}: {
   990	  goldValue: number;
   991	  tolerancePct: number;
   992	  lower: number;
   993	  upper: number;
   994	  measured: number | null;
   995	}) {
   996	  // Compute a display range that includes gold, both tolerance bounds,
   997	  // and measured — with sensible margin. Clamp width to avoid division
   998	  // by zero for PASS cases where measured ≈ gold.
   999	  const values = [lower, upper, goldValue, measured].filter(
  1000	    (v): v is number => v !== null && Number.isFinite(v),
  1001	  );
  1002	  const rawMin = Math.min(...values);
  1003	  const rawMax = Math.max(...values);
  1004	  const span = Math.max(rawMax - rawMin, Math.abs(goldValue) * 0.3, 0.01);
  1005	  const padding = span * 0.2;
  1006	  const displayMin = rawMin - padding;
  1007	  const displayMax = rawMax + padding;
  1008	  const toPct = (v: number) =>
  1009	    ((v - displayMin) / (displayMax - displayMin)) * 100;
  1010	
  1011	  const goldX = toPct(goldValue);
  1012	  const lowerX = toPct(lower);
  1013	  const upperX = toPct(upper);
  1014	  const measuredX = measured !== null ? toPct(measured) : null;
  1015	  const measuredInside = measured !== null && measured >= lower && measured <= upper;
  1016	
  1017	  return (
  1018	    <div className="relative mt-1">
  1019	      {/* Track */}
  1020	      <div className="relative h-2 rounded-full bg-surface-800">
  1021	        {/* Tolerance band shading */}
  1022	        <div
  1023	          className="absolute top-0 h-2 rounded-full bg-sky-600/30"
  1024	          style={{ left: `${lowerX}%`, width: `${upperX - lowerX}%` }}
  1025	        />
  1026	      </div>
  1027	      {/* Gold marker */}
  1028	      <div
  1029	        className="absolute -top-1 flex h-4 -translate-x-1/2 flex-col items-center"
  1030	        style={{ left: `${goldX}%` }}
  1031	      >
  1032	        <div className="h-4 w-px bg-surface-300" />
  1033	      </div>
  1034	      <div
  1035	        className="absolute top-5 -translate-x-1/2 mono text-[10px] text-surface-400"
  1036	        style={{ left: `${goldX}%` }}
  1037	      >
  1038	        gold
  1039	      </div>
  1040	      {/* Measurement marker (only if present) */}
  1041	      {measuredX !== null && (
  1042	        <>
  1043	          <div
  1044	            className="absolute -top-2 h-6 w-0.5 -translate-x-1/2 rounded-full"
  1045	            style={{
  1046	              left: `${Math.max(0, Math.min(100, measuredX))}%`,
  1047	              background: measuredInside ? "#4ade80" : "#f87171",
  1048	            }}
  1049	          />
  1050	          <div
  1051	            className="absolute top-5 -translate-x-1/2 mono text-[10px]"
  1052	            style={{
  1053	              left: `${Math.max(0, Math.min(100, measuredX))}%`,
  1054	              color: measuredInside ? "#4ade80" : "#f87171",
  1055	            }}
  1056	          >
  1057	            measured
  1058	          </div>
  1059	        </>
  1060	      )}
  1061	      {/* Out-of-range indicator */}
  1062	      {measuredX !== null && (measuredX < 0 || measuredX > 100) && (
  1063	        <div
  1064	          className={`absolute -top-3 mono text-[10px] ${measuredX < 0 ? "left-0" : "right-0"} text-contract-fail`}
  1065	        >
  1066	          {measuredX < 0 ? "← 远低于" : "远高于 →"}
  1067	        </div>
  1068	      )}
  1069	    </div>
  1070	  );
  1071	}
