   487	def _render_structured_contour(
   488	    case_id: str, Ux: np.ndarray, Uy: np.ndarray, Cx: np.ndarray, Cy: np.ndarray,
   489	    out: Path,
   490	) -> Optional[Path]:
   491	    """Fast path for structured square grids (LDC). Returns Path on success, None on fail."""
   492	    n = Ux.shape[0]
   493	    side = int(round(n ** 0.5))
   494	    if side * side != n:
   495	        return None
   496	    order = np.lexsort((Cx, Cy))
   497	    try:
   498	        Ux_r = Ux[order].reshape(side, side)
   499	        Uy_r = Uy[order].reshape(side, side)
   500	        x = Cx[order].reshape(side, side)
   501	        y = Cy[order].reshape(side, side)
   502	    except ValueError:
   503	        return None
   504	    mag = np.sqrt(Ux_r ** 2 + Uy_r ** 2)
   505	    lid = max(float(y.max()), 1e-12)
   506	    xn, yn = x / lid, y / lid
   507	    x_min, x_max = float(xn.min()), float(xn.max())
   508	    y_min, y_max = float(yn.min()), float(yn.max())
   509	    x1d = np.linspace(x_min, x_max, side)
   510	    y1d = np.linspace(y_min, y_max, side)
   511	    fig, ax = plt.subplots(figsize=(6.5, 6))
   512	    cf = ax.contourf(x1d, y1d, mag, levels=20, cmap="viridis")
   513	    ax.streamplot(x1d, y1d, Ux_r, Uy_r, density=1.1, color="white",
   514	                  linewidth=0.6, arrowsize=0.8)
