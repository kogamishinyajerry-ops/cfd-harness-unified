  7907	    @staticmethod
  7908	    def _extract_ldc_centerline(
  7909	        cxs: List[float],
  7910	        cys: List[float],
  7911	        u_vecs: List[Tuple],
  7912	        task_spec: TaskSpec,
  7913	        key_quantities: Dict[str, Any],
  7914	    ) -> Dict[str, Any]:
  7915	        """LDC: 提取 x=0.5 中心线速度剖面，对应 Ghia 1982 标准值。
  7916	
  7917	        Cavity mesh: x∈[0,0.1], y∈[0,0.1]
  7918	        Ghia 1982 标准: x_norm=0.5 → x_actual=0.05m
  7919	        Mesh-derived tolerance: selects the pair of cells straddling x=0.05,
  7920	        so the averaged profile reflects the true centerline. Prior hardcoded
  7921	        tolerance (0.006) was half-cell-width for the legacy 20x20 mesh and
  7922	        silently averaged a thick slab on the Phase 5b 129x129 mesh
  7923	        (Codex round HIGH finding 2026-04-21).
  7924	        """
  7925	        # x=0.05m = normalized x=0.5
  7926	        x_target = 0.05
  7927	
  7928	        from collections import defaultdict
  7929	        unique_cxs = sorted({round(cx, 6) for cx in cxs})
  7930	        if len(unique_cxs) >= 2:
  7931	            dx_typical = min(
  7932	                unique_cxs[i + 1] - unique_cxs[i]
  7933	                for i in range(len(unique_cxs) - 1)
  7934	            )
  7935	        else:
  7936	            dx_typical = 0.005  # fallback for degenerate mesh
  7937	        x_tol = 0.6 * dx_typical  # strictly narrower than one full cell width
  7938	
  7939	        y_groups: Dict[float, List[float]] = defaultdict(list)
  7940	
  7941	        for i in range(len(cxs)):
  7942	            if abs(cxs[i] - x_target) < x_tol:
  7943	                yr = round(cys[i], 4)
  7944	                y_groups[yr].append(u_vecs[i][0])  # Ux component
  7945	
  7946	        if not y_groups:
  7947	            return key_quantities
  7948	
  7949	        # 建立 [y_norm, avg_Ux] profile，插值到 Ghia 1982 位置
  7950	        ghia_y = [0.0000, 0.0625, 0.1250, 0.1875, 0.2500, 0.3125, 0.3750,
  7951	                  0.4375, 0.5000, 0.5625, 0.6250, 0.6875, 0.7500, 0.8125,
  7952	                  0.8750, 0.9375, 1.0000]
  7953	
  7954	        sorted_y = sorted(y_groups.keys())
  7955	        profile = [(yr / 0.1, sum(y_groups[yr]) / len(y_groups[yr])) for yr in sorted_y]
  7956	
  7957	        # 线性插值到 Ghia y 位置
  7958	        u_centerline = []
  7959	        for g_y in ghia_y:
  7960	            p_below = None
  7961	            p_above = None
  7962	            for p_y, p_u in profile:
  7963	                if p_y <= g_y:
  7964	                    p_below = (p_y, p_u)
  7965	                if p_y >= g_y and p_above is None:
  7966	                    p_above = (p_y, p_u)
  7967	            if p_below and p_above and p_above[0] != p_below[0]:
  7968	                frac = (g_y - p_below[0]) / (p_above[0] - p_below[0])
  7969	                sim_u = p_below[1] + frac * (p_above[1] - p_below[1])
  7970	            elif p_below:
  7971	                sim_u = p_below[1]
  7972	            elif p_above:
  7973	                sim_u = p_above[1]
  7974	            else:
  7975	                sim_u = 0.0
  7976	            u_centerline.append(sim_u)
  7977	
  7978	        key_quantities["u_centerline"] = u_centerline
  7979	        key_quantities["u_centerline_y"] = ghia_y
  7980	        return key_quantities
  7981	
