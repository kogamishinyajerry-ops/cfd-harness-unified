   165	    def _compare_scalar(
   166	        self,
   167	        quantity: str,
   168	        actual: float,
   169	        reference_values: List[Dict[str, Any]],
   170	        tolerance: float,
   171	    ) -> List[DeviationDetail]:
   172	        """标量比较：从 reference_values 取第一个 value"""
