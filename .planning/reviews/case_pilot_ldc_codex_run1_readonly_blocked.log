  7336	                                    key_quantities[f"{set_name}_y"] = y_coords
  7337	
  7338	        # Case-specific interpretation: 映射 sample 输出到 Gold Standard 期望的 quantity 名称
  7339	        if task_spec is not None:
  7340	            geom = task_spec.geometry_type
  7341	
  7342	            # LDC: uCenterline -> u_centerline (Gold Standard 格式)
  7343	            # Covers: icoFoam+SIMPLE_GRID (explicit), name-based SIMPLE_GRID/CUSTOM, Re<2300
  7344	            if self._is_lid_driven_cavity_case(task_spec, solver_name):
  7345	                if "uCenterline" in key_quantities:
  7346	                    key_quantities["u_centerline"] = key_quantities["uCenterline"]
  7347	                    del key_quantities["uCenterline"]
  7348	                    if "uCenterline_y" in key_quantities:
  7349	                        key_quantities["u_centerline_y"] = key_quantities["uCenterline_y"]
  7350	                        del key_quantities["uCenterline_y"]
  7351	
  7352	            # BFS: 从 wallProfile 计算再附着长度 Xr/H
  7353	            elif geom == GeometryType.BACKWARD_FACING_STEP:
  7354	                if "wallProfile" in key_quantities:
  7355	                    x_coords = key_quantities.get("wallProfile_x", [])
  7356	                    ux_vals = key_quantities.get("wallProfile", [])
  7357	                    if x_coords and ux_vals and len(x_coords) == len(ux_vals):
  7358	                        # 找再附着点: Ux 从负变正的第一个位置
  7359	                        reattachment_x = None
  7360	                        for i in range(1, len(ux_vals)):
  7361	                            if ux_vals[i-1] < 0 and ux_vals[i] >= 0:
  7362	                                # 线性插值找精确零交点
  7363	                                x1, x2 = x_coords[i-1], x_coords[i]
  7364	                                u1, u2 = ux_vals[i-1], ux_vals[i]
  7365	                                if u2 != u1:
  7366	                                    reattachment_x = x1 - u1 * (x2 - x1) / (u2 - u1)
  7367	                                else:
  7368	                                    reattachment_x = x1
  7369	                                break
  7370	                        # P6-TD-001: same physical-plausibility guard as
  7371	                        # _extract_bfs_reattachment — reject upstream (x ≤ 0)
  7372	                        # detections from under-converged solvers.
  7373	                        if reattachment_x is not None and reattachment_x > 0:
  7374	                            H = 1.0  # step height
  7375	                            key_quantities["reattachment_length"] = reattachment_x / H
  7376	                        elif reattachment_x is not None:
  7377	                            key_quantities["reattachment_detection_upstream_artifact"] = True
  7378	                            key_quantities["reattachment_detection_rejected_x"] = reattachment_x
  7379	                    # 清理中间数据
  7380	                    for k in list(key_quantities.keys()):
  7381	                        if k.startswith("wallProfile"):
  7382	                            del key_quantities[k]
  7383	
  7384	            # DEC-V61-042: removed secondary NC-Cavity Nu computation path
  7385	            # that differenced two cells of the midPlaneT profile (silent
  7386	            # substitution risk — would overwrite the proper wall-gradient
  7387	            # result from _extract_nc_nusselt if midPlaneT happened to be
  7388	            # populated by a parallel sample FO). The authoritative path
  7389	            # is now _extract_nc_nusselt via _parse_writeobjects_fields,
  7390	            # which uses the 3-point one-sided stencil on the hot wall.
  7391	            elif geom == GeometryType.NATURAL_CONVECTION_CAVITY:
  7392	                pass  # no-op — handled in _parse_writeobjects_fields
  7393	
  7394	        return residuals, key_quantities
  7395	
  7396	    # ------------------------------------------------------------------
  7397	    # writeObjects field extraction
  7398	    # ------------------------------------------------------------------
  7399	
  7400	    def _parse_writeobjects_fields(
  7401	        self,
  7402	        case_dir: Path,
  7403	        solver_name: str,
  7404	        task_spec: Optional[TaskSpec],
  7405	        key_quantities: Dict[str, Any],
  7406	    ) -> Dict[str, Any]:
  7407	        """从 postProcess writeObjects 输出的场文件提取 case-specific 关键物理量。
  7408	
  7409	        postProcess -func writeObjects -latestTime 在最新时间目录写出:
  7410	        - U: vector field (Ux, Uy, Uz) for each cell
  7411	        - Cx, Cy, Cz: cell centre coordinates
  7412	        - p: pressure field
  7413	        这些文件格式为 OpenFOAM internalField nonuniform List<...>。
  7414	
  7415	        Returns:
  7416	            key_quantities updated with u_centerline, reattachment_length, nusselt_number
  7417	        """
  7418	        if task_spec is None:
  7419	            return key_quantities
  7420	
  7421	        # 找到最新时间目录
  7422	        time_dirs = []
  7423	        for item in case_dir.iterdir():
  7424	            if item.is_dir():
  7425	                try:
  7426	                    t = float(item.name)
  7427	                    time_dirs.append((t, item))
  7428	                except ValueError:
  7429	                    pass
  7430	        if not time_dirs:
  7431	            return key_quantities
  7432	
  7433	        latest_t, latest_dir = max(time_dirs, key=lambda x: x[0])
  7434	
  7435	        # 检查是否有 U 和 Cx/Cy 文件
  7436	        u_path = latest_dir / "U"
  7437	        cx_path = latest_dir / "Cx"
  7438	        cy_path = latest_dir / "Cy"
  7439	        if not all(p.exists() for p in [u_path, cx_path, cy_path]):
  7440	            return key_quantities
  7441	
  7442	        # 读取场数据
  7443	        cxs = self._read_openfoam_scalar_field(cx_path)
  7444	        cys = self._read_openfoam_scalar_field(cy_path)
  7445	        cz_path = latest_dir / "Cz"
  7446	        czs = self._read_openfoam_scalar_field(cz_path) if cz_path.exists() else None
  7447	        u_vecs = self._read_openfoam_vector_field(u_path, len(cxs))
  7448	
  7449	        if len(cxs) != len(cys) or len(cxs) != len(u_vecs):
  7450	            return key_quantities
  7451	        if czs is not None and len(czs) != len(cxs):
  7452	            czs = None
  7453	
  7454	        geom = task_spec.geometry_type
  7455	        name_lower = task_spec.name.lower()
  7456	
  7457	        # LDC / CUSTOM: 提取 x=0.5 (normalized) 的中心线速度剖面
  7458	        # Covers: icoFoam+SIMPLE_GRID (explicit), name-based SIMPLE_GRID/CUSTOM, Re<2300
  7459	        if self._is_lid_driven_cavity_case(task_spec, solver_name):
  7460	            key_quantities = self._extract_ldc_centerline(
  7461	                cxs, cys, u_vecs, task_spec, key_quantities
  7462	            )
  7463	
  7464	        # BFS: 提取 y=0.5 (wall) 的速度剖面找再附着长度
  7465	        elif geom == GeometryType.BACKWARD_FACING_STEP:
  7466	            key_quantities = self._extract_bfs_reattachment(
  7467	                cxs, cys, u_vecs, task_spec, key_quantities
  7468	            )
  7469	
  7470	        # NC Cavity: 提取 mid-plane 温度剖面算 Nusselt number
  7471	        elif geom == GeometryType.NATURAL_CONVECTION_CAVITY:
  7472	            # buoyantFoam writes T (temperature) to disk; read it directly
  7473	            t_path = latest_dir / "T"
  7474	            if t_path.exists():
  7475	                t_vals = self._read_openfoam_scalar_field(t_path)
  7476	                key_quantities = self._extract_nc_nusselt(
  7477	                    cxs, cys, t_vals, task_spec, key_quantities
  7478	                )
  7479	
  7480	        # Plane Channel Flow DNS: BODY_IN_CHANNEL + INTERNAL -> u_mean_profile
  7481	        elif geom == GeometryType.BODY_IN_CHANNEL and task_spec.flow_type == FlowType.INTERNAL:
  7482	            # DEC-V61-043: pass case_dir so the extractor can prefer the
  7483	            # wallShearStress+uLine FO emitter output over cell-centre
  7484	            # U_max fallback. case_dir is the absolute case directory;
  7485	            # FoamAgentExecutor ran postProcess -funcs here.
  7486	            key_quantities = self._extract_plane_channel_profile(
  7487	                cxs, cys, u_vecs, task_spec, key_quantities,
  7488	                case_dir=case_dir,
  7489	            )
  7490	
  7491	        # Circular Cylinder Wake: BODY_IN_CHANNEL + EXTERNAL -> strouhal_number
  7492	        elif geom == GeometryType.BODY_IN_CHANNEL and task_spec.flow_type == FlowType.EXTERNAL:
  7493	            p_path = latest_dir / "p"
  7494	            p_vals: List[float] = []
  7495	            if p_path.exists():
  7496	                p_vals = self._read_openfoam_scalar_field(p_path)
  7497	            # DEC-V61-041: pass case_dir so the extractor can read the
  7498	            # forceCoeffs FO output (postProcessing/forceCoeffs1/) for
  7499	            # the real FFT-based Strouhal measurement.
  7500	            key_quantities = self._extract_cylinder_strouhal(
  7501	                cxs, cys, p_vals, task_spec, key_quantities,
  7502	                case_dir=case_dir,
  7503	            )
  7504	
  7505	        # Turbulent Flat Plate: SIMPLE_GRID + Re>=2300 -> cf_skin_friction
  7506	        # P6-TD-002 guard: exclude duct_flow (also SIMPLE_GRID + Re>=2300).
  7507	        # Canonical observable for duct is Darcy-Weisbach friction_factor,
  7508	        # NOT skin-friction Cf. Before this guard, duct_flow fell through
  7509	        # to _extract_flat_plate_cf and the Spalding fallback
  7510	        # (0.0576/Re_x^0.2 with Re_x=0.5*Re) returned a Cf that depends
  7511	        # only on Re — identical to 10 decimals for any case sharing Re
  7512	        # with flat plate. §5d Part-2 acceptance observed TFP and duct_flow
  7513	        # both returning cf=0.007600365566051871 (Re=50000 for both).
  7514	        #
  7515	        # Round-8 correction: classification uses _is_duct_flow_case()
  7516	        # which prefers canonical task name identity and falls back to
  7517	        # hydraulic_diameter. This closes the list_whitelist_cases() path
  7518	        # where hydraulic_diameter stays under `parameters` and never
  7519	        # migrates into boundary_conditions.
  7520	        elif (
  7521	            self._is_duct_flow_case(task_spec)
  7522	            and task_spec.Re is not None
  7523	            and task_spec.Re >= 2300
  7524	        ):
  7525	            # Duct flow detected; no dedicated extractor yet (queued as
  7526	            # P6-TD-003). Emit producer flags so audit surfaces can
  7527	            # distinguish "duct pending" from "flat plate Spalding".
  7528	            key_quantities["duct_flow_extractor_pending"] = True
  7529	            hd = (task_spec.boundary_conditions or {}).get("hydraulic_diameter")
  7530	            if hd is not None:
  7531	                key_quantities["duct_flow_hydraulic_diameter"] = hd
  7532	            else:
  7533	                # Duct-identified via name but missing hydraulic_diameter
  7534	                # in BCs (list_whitelist_cases() path). Flag fail-closed so
  7535	                # downstream audit sees malformed-input explicitly rather
  7536	                # than a silent-reroute masquerading as a valid measurement.
  7537	                key_quantities["duct_flow_hydraulic_diameter_missing"] = True
  7538	        elif (
  7539	            geom == GeometryType.SIMPLE_GRID
  7540	            and task_spec.Re is not None
  7541	            and task_spec.Re >= 2300
  7542	        ):
  7543	            key_quantities = self._extract_flat_plate_cf(
  7544	                cxs, cys, u_vecs, task_spec, key_quantities
  7545	            )
  7546	
  7547	        # Impinging Jet: IMPINGING_JET -> nusselt_number
  7548	        elif geom == GeometryType.IMPINGING_JET:
  7549	            t_path = latest_dir / "T"
  7550	            if t_path.exists():
  7551	                t_vals = self._read_openfoam_scalar_field(t_path)
  7552	                key_quantities = self._extract_jet_nusselt(
  7553	                    cxs, cys, t_vals, task_spec, key_quantities
  7554	                )
  7555	
  7556	        # Airfoil: AIRFOIL -> pressure_coefficient
  7557	        elif geom == GeometryType.AIRFOIL:
  7558	            p_path = latest_dir / "p"
  7559	            if p_path.exists():
  7560	                p_vals = self._read_openfoam_scalar_field(p_path)
  7561	                key_quantities = self._extract_airfoil_cp(
  7562	                    cxs,
  7563	                    czs if czs is not None else cys,
  7564	                    p_vals,
  7565	                    task_spec,
  7566	                    key_quantities,
  7567	                )
  7568	
  7569	        # C3 result-harvest side: overwrite standard keys with gold-anchored
  7570	        # sampleDict output when present. No-op for MOCK / pre-C3 cases.
  7571	        if task_spec is not None:
  7572	            key_quantities = self._try_populate_from_c3_sampledict(
  7573	                case_dir, task_spec, key_quantities, solver_name
  7574	            )
  7575	
  7576	        return key_quantities
  7577	
  7578	    @staticmethod
  7579	    def _read_openfoam_scalar_field(filepath: Path) -> List[float]:
  7580	        """解析 OpenFOAM internalField nonuniform List<scalar> 文件。"""
  7581	        with filepath.open() as f:
  7582	            lines = f.readlines()
  7583	        # 找 count 行（紧跟在 internalField nonuniform List<scalar> 之后）
  7584	        count_line = None
  7585	        for i, line in enumerate(lines):
  7586	            stripped = line.strip()
  7587	            if stripped and stripped[0].isdigit():
  7588	                count_line = i
  7589	                n = int(stripped.rstrip(';'))
  7590	                break
  7591	        if count_line is None:
  7592	            return []
  7593	        # count 后第一个非空行是 '('，数据从下一行开始
  7594	        data_start = count_line + 2
  7595	        data_end = data_start + n
  7596	        vals = []
  7597	        for j in range(n):
  7598	            line = lines[data_start + j].strip()
  7599	            if not line or line == ')':
  7600	                break
  7601	            try:
  7602	                vals.append(float(line.rstrip(';')))
  7603	            except ValueError:
  7604	                break
  7605	        return vals
  7606	
  7607	    @staticmethod
  7608	    def _read_openfoam_vector_field(filepath: Path, n_expected: int) -> List[Tuple]:
  7609	        """解析 OpenFOAM internalField nonuniform List<vector> 文件。"""
  7610	        with filepath.open() as f:
  7611	            lines = f.readlines()
  7612	        # 找 count 行
  7613	        count_line = None
  7614	        for i, line in enumerate(lines):
  7615	            stripped = line.strip()
  7616	            if stripped and stripped[0].isdigit():
  7617	                count_line = i
  7618	                break
  7619	        if count_line is None:
  7620	            return []
  7621	        # 数据从 count + 2 行开始 (跳过 '(')
  7622	        data_start = count_line + 2
  7623	        vecs = []
  7624	        for j in range(min(n_expected, 100000)):
  7625	            line = lines[data_start + j].strip()
  7626	            if not line or line in (')', 'boundaryField'):
  7627	                break
  7628	            inner = line.strip('();')
  7629	            parts = inner.split()
  7630	            if len(parts) >= 3:
  7631	                try:
  7632	                    vecs.append((float(parts[0]), float(parts[1]), float(parts[2])))
  7633	                except ValueError:
  7634	                    break
  7635	        return vecs
  7636	
  7637	    @staticmethod
  7638	    def _is_duct_flow_case(task_spec: TaskSpec) -> bool:
  7639	        """Detect if task is a duct_flow case via canonical identity.
  7640	
  7641	        P6-TD-002 round-8 correction: use task-name-as-case-identity rather
  7642	        than relying on `hydraulic_diameter` presence alone. Two construction
  7643	        paths exist for TaskSpec and only one normalizes whitelist
  7644	        `parameters` into `boundary_conditions` (src/task_runner.py:232-243);
  7645	        the other (src/knowledge_db.py:60-80) leaves them separate. A
  7646	        name-based primary signal closes the resulting silent-reroute hole.
  7647	        Hydraulic-diameter presence is kept as a secondary signal covering
  7648	        future duct cases whose names may differ.
  7649	        """
  7650	        if task_spec.geometry_type != GeometryType.SIMPLE_GRID:
  7651	            return False
  7652	        name_key = task_spec.name.lower().replace("-", "_").replace(" ", "_")
  7653	        if "duct" in name_key:
  7654	            return True
  7655	        return "hydraulic_diameter" in (task_spec.boundary_conditions or {})
  7656	
  7657	    @staticmethod
  7658	    def _is_lid_driven_cavity_case(task_spec: TaskSpec, solver_name: str) -> bool:
  7659	        """Detect if task is a Lid-Driven Cavity case by canonical name.
  7660	
  7661	        Phase 5b (post-Codex MEDIUM): removed the `solver_name == "icoFoam"`
  7662	        back-compat shortcut — it was solver-specific and would misclassify
  7663	        any future SIMPLE_GRID laminar case routed through icoFoam as LDC.
  7664	        LDC is now identified strictly by canonical name match (matches both
  7665	        the icoFoam legacy route and the simpleFoam Phase 5b route).
  7666	        """
  7667	        if task_spec.geometry_type not in (GeometryType.SIMPLE_GRID, GeometryType.CUSTOM):
  7668	            return False
  7669	        name_key = task_spec.name.lower().replace("-", "_").replace(" ", "_")
  7670	        return "lid" in name_key and "cavity" in name_key
  7671	
  7672	    @staticmethod
  7673	    # ------------------------------------------------------------------
  7674	    # C3 result-harvest side: gold-anchored sampleDict → comparator keys
  7675	    # ------------------------------------------------------------------
  7676	
  7677	    @staticmethod
  7678	    def _populate_ldc_centerline_from_sampledict(
  7679	        case_dir: Path,
  7680	        task_spec: TaskSpec,
  7681	        key_quantities: Dict[str, Any],
  7682	    ) -> Dict[str, Any]:
  7683	        """If postProcessing/sets/.../uCenterline_U.xy is present, overwrite
  7684	        `u_centerline` with Ux values at the gold y-points.
  7685	
  7686	        Output ordering follows ascending y (matches whitelist sort).
  7687	        Idempotent when output is absent — legacy cell-based extractor's
  7688	        value survives unchanged.
  7689	        """
  7690	        points = _try_load_sampledict_output(case_dir, "uCenterline", "U")
  7691	        if not points:
  7692	            return key_quantities
  7693	        try:
  7694	            sorted_pts = sorted(
  7695	                points,
  7696	                key=lambda p: p[0][1] if len(p[0]) >= 2 else p[0][0],
  7697	            )
  7698	            u_values = [float(p[1][0]) for p in sorted_pts]
  7699	        except (IndexError, ValueError, TypeError):
  7700	            return key_quantities
  7701	        if not u_values:
  7702	            return key_quantities
  7703	        key_quantities["u_centerline"] = u_values
  7704	        key_quantities["u_centerline_source"] = "sampleDict_direct"
  7705	        # Preserve companion y-axis for comparator visibility
  7706	        try:
  7707	            y_values = [
  7708	                float(p[0][1]) if len(p[0]) >= 2 else float(p[0][0])
  7709	                for p in sorted_pts
  7710	            ]
  7711	            key_quantities["u_centerline_y"] = y_values
  7712	        except (IndexError, ValueError, TypeError):
  7713	            pass
  7714	        return key_quantities
  7715	
  7716	    @staticmethod
  7717	    def _populate_naca_cp_from_sampledict(
  7718	        case_dir: Path,
  7719	        task_spec: TaskSpec,
  7720	        key_quantities: Dict[str, Any],
  7721	    ) -> Dict[str, Any]:
  7722	        """NACA Cp profile: prefer in-solver `surfaces` FO output,
  7723	        fall back to legacy point-based sampleDict, finally to
  7724	        volume-cell band averaging.
  7725	
  7726	        DEC-V61-044 migration path:
  7727	        1. Read postProcessing/airfoilSurface/<t>/p_aerofoil.raw (the
  7728	           `surfaces` FO on patches=(aerofoil) emitted by the current
  7729	           generator). This is THE source of truth for Cp.
  7730	        2. If the FO output is absent (MOCK run / legacy case / pre-DEC
  7731	           case not regenerated), fall through to the old point-based
  7732	           sampleDict path (`airfoilCp_p.xy`). That path was orphaned
  7733	           at runtime pre-DEC (executor didn't invoke `sample`), but
  7734	           we keep the parser for backward compat.
  7735	        3. Legacy volume-cell band averaging (`_extract_airfoil_cp`)
  7736	           is dispatched BEFORE this method and populates the default
  7737	           scalar. If neither FO path produces output, the band-
  7738	           averaged value stays — honest PASS_WITH_DEVIATIONS is
  7739	           preferable to refusing a run entirely, and the source flag
  7740	           tells the UI which path fired.
  7741	
  7742	        Malformed FO output fails loud via
  7743	        AirfoilSurfaceSamplerError — matches DEC-V61-040 round-2
  7744	        pattern: corruption must surface, not silently degrade.
  7745	        """
  7746	        bc = task_spec.boundary_conditions or {}
  7747	        chord = float(bc.get("chord_length", 1.0))
  7748	        U_inf = float(bc.get("U_inf", 1.0))
  7749	        rho = float(bc.get("rho", 1.0))
  7750	        p_inf = float(bc.get("p_inf", 0.0))
  7751	
  7752	        # Primary path: in-solver surfaces FO.
  7753	        try:
  7754	            from src.airfoil_surface_sampler import (
  7755	                emit_cp_profile,
  7756	                AirfoilSurfaceSamplerError,
  7757	            )
  7758	            emitted = emit_cp_profile(
  7759	                case_dir,
  7760	                chord=chord,
  7761	                U_inf=U_inf,
  7762	                rho=rho,
  7763	                p_inf=p_inf,
  7764	            )
  7765	        except AirfoilSurfaceSamplerError as exc:
  7766	            # Codex DEC-V61-044 round-1 BLOCKER closure: FO corruption
  7767	            # MUST invalidate the upstream band-averaged scalar so
  7768	            # DEC-V61-036 G1 MISSING_TARGET_QUANTITY fires at the
  7769	            # comparator — don't let the stale legacy value stand.
  7770	            key_quantities["pressure_coefficient_emitter_error"] = str(exc)
  7771	            for stale in (
  7772	                "pressure_coefficient",
  7773	                "pressure_coefficient_x",
  7774	                "pressure_coefficient_profile",
  7775	                "pressure_coefficient_source",
  7776	            ):
  7777	                key_quantities.pop(stale, None)
  7778	            return key_quantities
  7779	        if emitted is not None:
  7780	            key_quantities.update(emitted)
  7781	            return key_quantities
  7782	
  7783	        # Fallback: legacy point-based sampleDict (orphaned at runtime
  7784	        # pre-DEC-044, but preserved for back-compat with any case
  7785	        # that still uses the old generator output).
  7786	        points = _try_load_sampledict_output(case_dir, "airfoilCp", "p")
  7787	        if not points:
  7788	            return key_quantities
  7789	        q_ref = 0.5 * rho * U_inf * U_inf
  7790	        if q_ref <= 0.0 or chord <= 0.0:
  7791	            return key_quantities
  7792	        # Codex DEC-V61-044 round-1 FLAG closure: emit as parallel
  7793	        # scalar + axis lists (not list[dict]). The comparator treats
  7794	        # pressure_coefficient as numeric vector data and would
  7795	        # TypeError on list[dict].
  7796	        cp_pairs: List[Tuple[float, float]] = []
  7797	        for coords, values in points:
  7798	            if len(coords) < 3 or not values:
  7799	                continue
