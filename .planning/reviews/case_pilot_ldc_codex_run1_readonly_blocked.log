    10	logger = logging.getLogger(__name__)
    11	
    12	
    13	# Canonical → aliases map for the ACTUAL side of comparison.
    14	#
    15	# Problem: gold_standards declare quantities by canonical name (e.g. "friction_factor"),
    16	# but the solver / postProcessing layer writes under various historical names
    17	# ("f", "fDarcy", etc.). Without this table, ResultComparator returned
    18	# "Quantity 'friction_factor' not found in execution result" and flagged the
    19	# correction as COMPARATOR_SCHEMA_MISMATCH (see knowledge/corrections/ —
    20	# 4× pipe friction_factor, 6× u_mean_profile, etc.).
    21	#
    22	# Governance: this is *naming-layer* infrastructure (src/ turf, autonomous per
    23	# DEC-V61-003). Does NOT modify knowledge/gold_standards/ or knowledge/whitelist.yaml.
    24	# Each alias set should be defensible from published solver/postProcessing
    25	# conventions — do not paper over real physics mismatches here.
    26	CANONICAL_ALIASES: Dict[str, Tuple[str, ...]] = {
    27	    # Darcy friction factor: solver may emit "f" (single letter),
    28	    # "fDarcy" (OpenFOAM turbulence function object), or "fFanning" (4× smaller).
    29	    # Do NOT include fFanning here — unit conversion is not an alias.
    30	    "friction_factor":    ("f", "fDarcy", "darcy_f", "darcyFrictionFactor"),
    31	    # Skin friction: OpenFOAM wallShearStress function object typically yields "Cf".
    32	    "cf_skin_friction":   ("Cf", "cf", "skin_friction", "skinFriction"),
    33	    # Pressure coefficient: Cp / cp / p_coeff all seen in the wild.
    34	    "pressure_coefficient": ("Cp", "cp", "p_coeff", "pressureCoefficient"),
    35	    # Nusselt: averaged over a patch is often "Nu_avg" / "averageNu".
    36	    "nusselt_number":     ("Nu", "Nu_avg", "Nu_mean", "averageNu", "nu_avg"),
    37	    # Strouhal: sometimes derived post-run and named "St" or "strouhal".
    38	    "strouhal_number":    ("St", "strouhal", "shedding_St"),
    39	    # Reattachment length in BFS: case-specific shorthand.
    40	    "reattachment_length": ("Xr_over_H", "reattachment_x", "xr_H"),
    41	    # Lid-driven cavity u-profile: legacy sampleDict set name "uCenterline".
    42	    # (adapter already does this rename for LDC specifically — redundancy is safe
    43	    # and covers solvers that bypass the adapter's case-specific branch.)
    44	    "u_centerline":       ("uCenterline", "U_centerline", "u_profile_centerline"),
    45	    # DNS channel u+ profile.
    46	    "u_mean_profile":     ("u_plus", "u_plus_profile", "u_plus_mean", "uPlusProfile"),
    47	}
    48	
    49	
    50	def _lookup_with_alias(
    51	    key_quantities: Dict[str, Any],
    52	    canonical: str,
    53	) -> Tuple[Optional[Any], Optional[str]]:
    54	    """Return (value, key_used). Canonical name wins; fall through aliases.
    55	
    56	    Returns (None, None) when no match — caller should report the *canonical*
    57	    name in error messages so users see what gold expected, not what adapter emitted.
    58	    """
    59	    direct = key_quantities.get(canonical)
    60	    if direct is not None:
    61	        return direct, canonical
    62	    for alias in CANONICAL_ALIASES.get(canonical, ()):
    63	        if alias in key_quantities:
    64	            value = key_quantities[alias]
    65	            if value is not None:
    66	                logger.debug(
    67	                    "ResultComparator: resolved %r via alias %r", canonical, alias
    68	                )
    69	                return value, alias
    70	    return None, None
