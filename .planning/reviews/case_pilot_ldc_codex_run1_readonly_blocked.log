   267	                    deviations.append(DeviationDetail(
   268	                        quantity=f"{quantity}[{axis_name}={coord_text}]",
   269	                        expected=ref_u,
   270	                        actual=sim_u,
   271	                        relative_error=err,
   272	                        tolerance=tolerance,
   273	                    ))
   274	        else:
   275	            # Fallback: positional matching
   276	            for i, (act, ref) in enumerate(zip(actual_list, ref_scalars)):
