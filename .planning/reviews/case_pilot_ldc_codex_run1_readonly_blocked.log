   236	        ref_scalars = [_pick_ref_scalar(r) for r in reference_values]
   237	        ref_axis = reference_coords or [None for _ in reference_values]
   238	
   239	        # 坐标感知插值比较：只有当 actual_coords 可用且 reference 有同轴坐标时才启用
   240	        use_interp = (
   241	            actual_coords is not None
   242	            and len(actual_coords) == len(actual_list)
   243	            and all(coord is not None for coord in ref_axis)
