function formatNumber(v: number | undefined | null): string {
  if (v == null || !Number.isFinite(v)) return "—";
  const abs = Math.abs(v);
  if (abs === 0) return "0";
  if (abs < 0.001) return v.toExponential(2);
  if (abs < 1) return v.toFixed(4);
  if (abs < 100) return v.toFixed(3);
  return v.toFixed(1);
}

