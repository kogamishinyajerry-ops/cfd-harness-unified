  const resolvedRun = runs.find((r) => r.run_id === measurement?.run_id)
    ?? runs.find((r) => activeRunId ? r.run_id === activeRunId : r.category === "audit_real_run")
    ?? runs.find((r) => r.category === "reference")
    ?? runs[0];

