    33	export function PreconditionList({ preconditions }: Props) {
    34	  if (!preconditions.length) {
    35	    return (
    36	      <div className="card">
    37	        <div className="card-header">
    38	          <h3 className="card-title">Physics Preconditions</h3>
    39	        </div>
    40	        <p className="px-4 py-6 text-sm text-surface-400">
    41	          No physics preconditions declared for this case.
    42	        </p>
    43	      </div>
    44	    );
    45	  }
    46	  // DEC-V61-046 round-3 R3-B1: tri-state. partial and unmet are both honesty
    47	  // signals but mean different things; the header count separates them.
    48	  const counts = preconditions.reduce(
    49	    (acc, p) => {
    50	      acc[toneFor(p.satisfied)] += 1;
    51	      return acc;
    52	    },
    53	    { pass: 0, partial: 0, fail: 0 } as Record<Tone, number>,
    54	  );
    55	  const headerTone =
    56	    counts.fail > 0
    57	      ? "text-contract-hazard"
    58	      : counts.partial > 0
    59	      ? "text-amber-300"
    60	      : "text-contract-pass";
    61	  const headerParts = [`${counts.pass}/${preconditions.length} satisfied`];
    62	  if (counts.partial) headerParts.push(`${counts.partial} partial`);
    63	  if (counts.fail) headerParts.push(`${counts.fail} unmet`);
    64	  return (
    65	    <div className="card">
    66	      <div className="card-header flex items-center justify-between">
    67	        <h3 className="card-title">Physics Preconditions</h3>
    68	        <span className={`text-xs ${headerTone}`}>
    69	          {headerParts.join(" · ")}
    70	        </span>
    71	      </div>
    72	      <ul className="divide-y divide-surface-700">
    73	        {preconditions.map((p, idx) => {
    74	          const tone = toneFor(p.satisfied);
    75	          return (
    76	            <li key={idx} className="px-4 py-3">
    77	              <div className="flex items-start gap-3">
    78	                <span
    79	                  className={`mt-0.5 inline-block h-2 w-2 shrink-0 rounded-full ${DOT[tone]}`}
    80	                  aria-hidden
    81	                />
    82	                <div className="flex-1">
    83	                  <p className="text-sm text-surface-100">{p.condition}</p>
    84	                  {p.evidence_ref && (
    85	                    <p className="mt-1 text-[11px] text-surface-400">
    86	                      <span className="font-semibold text-surface-300">
    87	                        Evidence:
    88	                      </span>{" "}
    89	                      {p.evidence_ref}
    90	                    </p>
    91	                  )}
    92	                  {tone !== "pass" && p.consequence_if_unsatisfied && (
    93	                    <p
    94	                      className={`mt-1 text-[11px] ${tone === "partial" ? "text-amber-300" : "text-contract-hazard"}`}
    95	                    >
    96	                      <span className="font-semibold">Consequence:</span>{" "}
    97	                      {p.consequence_if_unsatisfied}
    98	                    </p>
    99	                  )}
   100	                </div>
   101	                <span
   102	                  className={`mono text-[10px] font-semibold uppercase ${LABEL_TONE[tone]}`}
   103	                >
   104	                  {LABEL[tone]}
   105	                </span>
   106	              </div>
   107	            </li>
   108	          );
   109	        })}
   110	      </ul>
   111	    </div>
   112	  );
   113	}

