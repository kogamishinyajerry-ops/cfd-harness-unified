     1	"""Validation-report assembly — reads YAML, builds the Screen 4 payload.
     2	
     3	Phase 0 scope:
     4	    - list_cases()              → GET /api/cases
     5	    - load_case_detail(id)      → GET /api/cases/{id}
     6	    - build_validation_report() → GET /api/validation-report/{id}
     7	
     8	Phase 0 measurement sourcing strategy (in order):
     9	    1. ui/backend/tests/fixtures/{case_id}_measurement.yaml
    10	       (committed alongside the backend for deterministic demo data)
    11	    2. None (returns MeasuredValue=None; UI renders "no run yet")
    12	
    13	Phase 3 will extend this to pull from reports/**/slice_metrics.yaml
    14	once live-run streaming is integrated.
    15	"""
    16	
    17	from __future__ import annotations
    18	
    19	from functools import lru_cache
    20	from pathlib import Path
    21	from typing import TYPE_CHECKING, Any, Literal
    22	
    23	import yaml
    24	
    25	from ui.backend.schemas.validation import (
    26	    AttestorCheck,
    27	    AttestorVerdict,
    28	    AuditConcern,
    29	    CaseDetail,
    30	    CaseIndexEntry,
    31	    ContractStatus,
    32	    DecisionLink,
    33	    GoldStandardReference,
    34	    MeasuredValue,
    35	    Precondition,
    36	    RunDescriptor,
    37	    RunSummary,
    38	    ValidationReport,
    39	)
    40	
    41	if TYPE_CHECKING:
    42	    from src.convergence_attestor import Thresholds
    43	
    44	
    45	# ---------------------------------------------------------------------------
    46	# Path resolution (repo-root relative)
    47	# ---------------------------------------------------------------------------
    48	# Layout:
    49	#   <repo>/
    50	#     knowledge/whitelist.yaml
    51	#     knowledge/gold_standards/{case_id}.yaml
    52	#     ui/backend/services/validation_report.py  ← this file
    53	#     ui/backend/tests/fixtures/{case_id}_measurement.yaml
    54	_HERE = Path(__file__).resolve()
    55	REPO_ROOT = _HERE.parents[3]
    56	WHITELIST_PATH = REPO_ROOT / "knowledge" / "whitelist.yaml"
    57	GOLD_STANDARDS_DIR = REPO_ROOT / "knowledge" / "gold_standards"
    58	FIXTURE_DIR = _HERE.parents[1] / "tests" / "fixtures"
    59	
    60	
    61	# ---------------------------------------------------------------------------
    62	# YAML loaders (cached — Phase 0 content is stable during a server lifetime)
    63	# ---------------------------------------------------------------------------
    64	@lru_cache(maxsize=1)
    65	def _load_whitelist() -> dict[str, dict[str, Any]]:
    66	    """Return {case_id: case_def} from knowledge/whitelist.yaml."""
    67	    if not WHITELIST_PATH.exists():
    68	        return {}
    69	    with WHITELIST_PATH.open("r", encoding="utf-8") as fh:
    70	        doc = yaml.safe_load(fh) or {}
    71	    cases = doc.get("cases", [])
    72	    out: dict[str, dict[str, Any]] = {}
    73	    for entry in cases:
    74	        cid = entry.get("id")
    75	        if cid:
    76	            out[cid] = entry
    77	    return out
    78	
    79	
    80	def _load_gold_standard(case_id: str) -> dict[str, Any] | None:
    81	    """Read knowledge/gold_standards/{case_id}.yaml if present.
    82	
    83	    Two on-disk shapes are supported:
    84	        (A) Single document with top-level `observables: [{name, ref_value,
    85	            tolerance, ...}]` + `physics_contract: {...}`
    86	            (e.g. differential_heated_cavity, turbulent_flat_plate).
    87	        (B) Multi-document — each YAML doc pins one quantity with
    88	            top-level `quantity / reference_values / tolerance`; the
    89	            first doc typically carries `physics_contract`
    90	            (e.g. circular_cylinder_wake, lid_driven_cavity).
    91	
    92	    Both shapes are normalised to (A)'s schema before returning, so
    93	    downstream code only ever sees a single `observables: [...]`.
    94	    """
    95	    candidate = GOLD_STANDARDS_DIR / f"{case_id}.yaml"
    96	    if not candidate.exists():
    97	        return None
    98	    with candidate.open("r", encoding="utf-8") as fh:
    99	        docs = [d for d in yaml.safe_load_all(fh) if d]
   100	    if not docs:
   101	        return None
   102	
   103	    # Shape A — already has observables[] ⇒ return as-is.
   104	    if len(docs) == 1 and isinstance(docs[0].get("observables"), list):
   105	        return docs[0]
   106	
   107	    # Shape B — synthesise an observables[] by flattening each doc.
   108	    primary = docs[0]
   109	    observables: list[dict[str, Any]] = []
   110	    for doc in docs:
   111	        quantity = doc.get("quantity")
   112	        if not quantity:
   113	            continue
   114	        refs = doc.get("reference_values") or []
   115	        ref_value: float | None = None
   116	        unit = ""
   117	        # Scan each reference_values entry for the first non-zero scalar
   118	        # anchor under any known key. (First entry of a profile is often
   119	        # a trivial u_plus=0 at y_plus=0 — picking the next non-zero
   120	        # entry makes the contract engine produce meaningful PASS/FAIL
   121	        # instead of collapsing deviation to 0.)
   122	        scalar_keys = (
   123	            "value", "Cf", "f", "Nu", "u", "u_Uinf", "Cp", "Re_D", "St",
   124	            "u_plus",
   125	        )
   126	        if refs and isinstance(refs[0], dict):
   127	            unit = refs[0].get("unit", "") or ""
   128	        for entry in refs:
   129	            if not isinstance(entry, dict):
   130	                continue
   131	            for scalar_key in scalar_keys:
   132	                val = entry.get(scalar_key)
   133	                if isinstance(val, (int, float)) and float(val) != 0.0:
   134	                    ref_value = float(val)
   135	                    break
   136	            if ref_value is not None:
   137	                break
   138	        # Fallback: if every entry was zero, accept the first scalar we
   139	        # can find (even zero) to preserve prior behaviour.
   140	        if ref_value is None and refs and isinstance(refs[0], dict):
   141	            for scalar_key in scalar_keys:
   142	                val = refs[0].get(scalar_key)
   143	                if isinstance(val, (int, float)):
   144	                    ref_value = float(val)
   145	                    break
   146	        observables.append(
   147	            {
   148	                "name": quantity,
   149	                "ref_value": ref_value if ref_value is not None else 0.0,
   150	                "unit": unit,
   151	                "tolerance": doc.get("tolerance"),
   152	                "description": (refs[0].get("description") if refs and isinstance(refs[0], dict) else None),
   153	            }
   154	        )
   155	    return {
   156	        "observables": observables,
   157	        "physics_contract": primary.get("physics_contract") or {},
   158	        "source": primary.get("source"),
   159	        "literature_doi": primary.get("literature_doi"),
   160	        "schema_version": primary.get("schema_version"),
   161	        "case_id": primary.get("case_info", {}).get("id") or case_id,
   162	    }
   163	
   164	
   165	def _load_fixture_measurement(case_id: str) -> dict[str, Any] | None:
   166	    """Read the legacy single-run fixture if present.
   167	
   168	    Legacy path: ui/backend/tests/fixtures/{case_id}_measurement.yaml
   169	    This is the pre-multi-run layout and is still honored for back-compat.
   170	    If a multi-run directory exists at fixtures/runs/{case_id}/, those runs
   171	    are preferred (see _list_runs + _load_run_measurement).
   172	    """
   173	    candidate = FIXTURE_DIR / f"{case_id}_measurement.yaml"
   174	    if not candidate.exists():
   175	        return None
   176	    with candidate.open("r", encoding="utf-8") as fh:
   177	        return yaml.safe_load(fh)
   178	
   179	
   180	RUNS_DIR = FIXTURE_DIR / "runs"
   181	
   182	
   183	def _list_run_files(case_id: str) -> list[Path]:
   184	    """Return run fixture paths under fixtures/runs/{case_id}/ sorted by
   185	    run_id ascending. Empty list if the directory doesn't exist.
   186	    """
   187	    case_dir = RUNS_DIR / case_id
   188	    if not case_dir.is_dir():
   189	        return []
   190	    return sorted(case_dir.glob("*_measurement.yaml"))
   191	
   192	
   193	def _run_id_from_path(p: Path) -> str:
   194	    # lid_driven_cavity/reference_pass_measurement.yaml → reference_pass
   195	    return p.stem.removesuffix("_measurement")
   196	
   197	
   198	_CATEGORY_ORDER: dict[str, int] = {
   199	    "reference": 0,
   200	    "audit_real_run": 1,
   201	    "real_incident": 2,
   202	    "under_resolved": 3,
   203	    "wrong_model": 4,
   204	    "grid_convergence": 5,
   205	}
   206	
   207	
   208	def list_runs(case_id: str) -> list[RunDescriptor]:
   209	    """Enumerate curated + legacy runs for a case.
   210	
   211	    Ordering (pedagogical, stable across filesystem locales):
   212	    1. `reference` first — students see "what done right looks like"
   213	       at the top.
   214	    2. `real_incident` next — actual production measurement, auditable
   215	       reality.
   216	    3. `under_resolved` / `wrong_model` — teaching variants.
   217	    4. `grid_convergence` last — mesh-sweep runs live behind the Mesh
   218	       tab and don't belong in the Compare run-picker's first page of
   219	       attention.
   220	    Within a category, sort by run_id ascending (mesh_20 before
   221	    mesh_160 via zero-padded numeric comparison for `mesh_N` ids).
   222	    Legacy `{case_id}_measurement.yaml` is exposed as run_id='legacy'
   223	    only when the multi-run dir is empty.
   224	    """
   225	    runs: list[RunDescriptor] = []
   226	    for path in _list_run_files(case_id):
   227	        try:
   228	            with path.open("r", encoding="utf-8") as fh:
   229	                doc = yaml.safe_load(fh) or {}
   230	        except Exception:
   231	            continue
   232	        md = doc.get("run_metadata") or {}
   233	        run_id = md.get("run_id") or _run_id_from_path(path)
   234	        runs.append(
   235	            RunDescriptor(
   236	                run_id=run_id,
   237	                label_zh=md.get("label_zh") or run_id.replace("_", " "),
   238	                label_en=md.get("label_en", "") or "",
   239	                description_zh=md.get("description_zh", "") or "",
   240	                category=md.get("category", "reference"),
   241	                expected_verdict=md.get("expected_verdict", "UNKNOWN"),
   242	            )
   243	        )
   244	    if runs:
   245	        def _sort_key(r: RunDescriptor) -> tuple[int, int, str]:
   246	            cat_rank = _CATEGORY_ORDER.get(r.category, 99)
   247	            # Numeric-aware secondary sort for mesh_N ids so mesh_20 sits
   248	            # before mesh_160 instead of lexicographic (`mesh_160` < `mesh_20`).
   249	            if r.run_id.startswith("mesh_"):
   250	                try:
   251	                    n = int(r.run_id.split("_", 1)[1])
   252	                except ValueError:
   253	                    n = 0
   254	                return (cat_rank, n, r.run_id)
   255	            return (cat_rank, 0, r.run_id)
   256	
   257	        runs.sort(key=_sort_key)
   258	        return runs
   259	
   260	    legacy = _load_fixture_measurement(case_id)

