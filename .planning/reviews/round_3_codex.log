   423	def _normalize_satisfied(raw: Any) -> bool | Literal["partial"]:
   424	    """DEC-V61-046 round-3 R3-B1: carry the YAML tri-state through the API.
   425	
   426	    Accepts bool/int, strings `"true"/"false"/"yes"/"no"/"partial"/"partially"`,
   427	    and None/unknown. Unknowns map to `False` (fail-visible) rather than
   428	    silently truthy — matches the export-side `_precondition_marker`
   429	    policy from `ui/backend/routes/case_export.py`.
   430	    """
   431	    if isinstance(raw, bool):
   432	        return raw
   433	    if isinstance(raw, (int, float)) and not isinstance(raw, bool):
   434	        return bool(raw)
   435	    if isinstance(raw, str):
   436	        low = raw.strip().lower()
   437	        if low in ("partial", "partially"):
   438	            return "partial"
   439	        if low in ("true", "yes", "1"):
   440	            return True
   441	        if low in ("false", "no", "0"):
   442	            return False
   443	    return False
   444	
