+  satisfied: boolean | "partial";
   evidence_ref: string | null;
   consequence_if_unsatisfied: string | null;
 }
 
 export interface AuditConcern {
   concern_type: string;
   summary: string;
   detail: string | null;
   decision_refs: string[];
 }
 
