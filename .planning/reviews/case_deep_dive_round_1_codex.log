  1101	function ConvergenceSparkline({
  1102	  series,
  1103	  goldRef,
  1104	  tolPct,
  1105	  activeIdx,
  1106	}: {
  1107	  series: { idx: number; label: string; value: number | null | undefined; status: ContractStatus }[];
  1108	  goldRef: number | undefined;
  1109	  tolPct: number | undefined;
  1110	  activeIdx: number;
  1111	}) {
  1112	  const W = 600;
  1113	  const H = 180;
  1114	  const padX = 40;
  1115	  const padY = 20;
  1116	
  1117	  const values = series
  1118	    .map((s) => s.value)
  1119	    .filter((v): v is number => v != null && Number.isFinite(v));
  1120	  if (goldRef == null || !Number.isFinite(goldRef) || values.length === 0) {
  1121	    return (
  1122	      <div className="h-[180px] rounded border border-surface-800 bg-surface-950/40 p-3 text-[11px] text-surface-500">
  1123	        等待后端数据…
  1124	      </div>
  1125	    );
  1126	  }
  1127	  const allVals = [...values, goldRef];
  1128	  if (tolPct != null) {
  1129	    allVals.push(goldRef * (1 + tolPct), goldRef * (1 - tolPct));
  1130	  }
  1131	  const yMin = Math.min(...allVals);
  1132	  const yMax = Math.max(...allVals);
  1133	  const yRange = yMax - yMin || Math.abs(goldRef) * 0.2 || 1;
  1134	  const yPad = yRange * 0.15;
  1135	  const yLo = yMin - yPad;
  1136	  const yHi = yMax + yPad;
  1137	
  1138	  const xStep = series.length > 1 ? (W - 2 * padX) / (series.length - 1) : 0;
  1139	  const toX = (i: number) => padX + i * xStep;
  1140	  const toY = (v: number) => padY + (H - 2 * padY) * (1 - (v - yLo) / (yHi - yLo));
  1141	
  1142	  const goldY = toY(goldRef);
  1143	  const upperY = tolPct != null ? toY(goldRef * (1 + tolPct)) : null;
  1144	  const lowerY = tolPct != null ? toY(goldRef * (1 - tolPct)) : null;
  1145	
  1146	  const points = series
  1147	    .map((s) =>
  1148	      s.value == null || !Number.isFinite(s.value)
  1149	        ? null
  1150	        : `${toX(s.idx)},${toY(s.value)}`,
  1151	    )
  1152	    .filter((p): p is string => p != null)
  1153	    .join(" ");
  1154	
  1155	  const statusColor: Record<ContractStatus, string> = {
  1156	    PASS: "#4ade80",
  1157	    HAZARD: "#fbbf24",
  1158	    FAIL: "#f87171",
  1159	    UNKNOWN: "#9ca3af",
  1160	  };
  1161	
  1162	  return (
  1163	    <div className="rounded border border-surface-800 bg-surface-950/40 p-3">
  1164	      <svg viewBox={`0 0 ${W} ${H}`} className="w-full" role="img">
  1165	        {/* tolerance band */}
  1166	        {upperY != null && lowerY != null && (
  1167	          <rect
  1168	            x={padX - 6}
  1169	            y={Math.min(upperY, lowerY)}
  1170	            width={W - 2 * padX + 12}
  1171	            height={Math.abs(upperY - lowerY)}
  1172	            fill="#4ade80"
  1173	            opacity={0.08}
  1174	          />
  1175	        )}
  1176	        {/* gold line */}
  1177	        <line
  1178	          x1={padX - 6}
  1179	          x2={W - padX + 6}
  1180	          y1={goldY}
  1181	          y2={goldY}
  1182	          stroke="#4ade80"
  1183	          strokeWidth={1.4}
  1184	          strokeDasharray="4 3"
  1185	        />
  1186	        <text x={W - padX + 10} y={goldY + 3} fontSize="10" fill="#4ade80">
  1187	          gold {formatNumber(goldRef)}
  1188	        </text>
  1189	        {/* connecting line */}
  1190	        <polyline
  1191	          points={points}
  1192	          fill="none"
  1193	          stroke="#60a5fa"
  1194	          strokeWidth={1.5}
  1195	          opacity={0.6}
  1196	        />
  1197	        {/* density anchor points */}
  1198	        {series.map((s) => {
  1199	          if (s.value == null || !Number.isFinite(s.value)) return null;
  1200	          const cx = toX(s.idx);
  1201	          const cy = toY(s.value);
  1202	          const r = s.idx === activeIdx ? 6 : 4;
  1203	          return (
  1204	            <g key={s.idx}>
  1205	              <circle
  1206	                cx={cx}
  1207	                cy={cy}
  1208	                r={r}
  1209	                fill={statusColor[s.status]}
  1210	                stroke="#0a0e14"
  1211	                strokeWidth={1.5}
  1212	              />
  1213	              <text
  1214	                x={cx}
  1215	                y={H - 4}
  1216	                textAnchor="middle"
  1217	                fontSize="10"
  1218	                fill={s.idx === activeIdx ? "#e5e7eb" : "#6b7280"}
  1219	              >
  1220	                {s.label}
  1221	              </text>
  1222	            </g>
  1223	          );
  1224	        })}
  1225	      </svg>
  1226	    </div>
  1227	  );
  1228	}
  1229	
  1230	function formatNumber(v: number | undefined | null): string {
  1231	  if (v == null || !Number.isFinite(v)) return "—";
  1232	  const abs = Math.abs(v);
  1233	  if (abs === 0) return "0";
  1234	  if (abs < 0.001) return v.toExponential(2);
  1235	  if (abs < 1) return v.toFixed(4);
  1236	  if (abs < 100) return v.toFixed(3);
  1237	  return v.toFixed(1);
  1238	}
