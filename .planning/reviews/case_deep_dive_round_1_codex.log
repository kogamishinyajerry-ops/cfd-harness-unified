   550	    if (satisfied === "partial") return { glyph: "~", tone: "text-amber-300" };
   551	    if (satisfied === false) return { glyph: "✗", tone: "text-contract-fail" };
   552	    return { glyph: "✓", tone: "text-contract-pass" };
   553	  };
   554	
   555	  const verdictTone =
   556	    verdict.startsWith("SATISFIED") || verdict === "COMPATIBLE"
   557	      ? "text-contract-pass border-contract-pass/40 bg-contract-pass/10"
   558	      : verdict.startsWith("INCOMPATIBLE") ||
   559	        verdict.startsWith("INCOMPATIBLE_WITH_LITERATURE")
