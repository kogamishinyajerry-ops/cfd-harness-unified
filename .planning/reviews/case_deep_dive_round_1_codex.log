   505	// Physics-contract panel — surfaces the gold YAML's physics_contract block
   506	// (contract_status + preconditions with three-state satisfied markers) so a
   507	// reader sees the nuanced CFD-level verdict before the downstream PASS/HAZARD/
   508	// FAIL tile. Rendering is best-effort: if the backend hasn't returned the
   509	// ValidationReport yet we show a compact skeleton; if the case has no
   510	// physics_contract (shouldn't happen after DEC-V61-046 backfill) we hide.
   511	function PhysicsContractPanel({
   512	  report,
   513	}: {
   514	  report: ValidationReport | undefined;
   515	}) {
   516	  if (!report) {
   517	    return (
   518	      <section className="rounded-md border border-surface-800 bg-surface-900/30 px-4 py-3 text-[12px] text-surface-500">
   519	        正在从后端取回 physics contract…
   520	      </section>
   521	    );
   522	  }
   523	  const narrative = report.case.contract_status_narrative?.trim();
   524	  const preconds = report.preconditions ?? [];
   525	  if (!narrative && preconds.length === 0) {
   526	    return null;
   527	  }
   528	
   529	  // The contract_status string is often shaped "VERDICT — human detail".
   530	  // Split on the first em/en-dash or " - " so the verdict token can be
   531	  // highlighted while the detail stays as body text.
   532	  let verdict = narrative ?? "";
   533	  let detail = "";
   534	  if (narrative) {
   535	    const m = narrative.match(/^([A-Z_]+)(?:\s*[—\-–]\s*(.+))?$/s);
   536	    if (m) {
   537	      verdict = m[1];
   538	      detail = (m[2] ?? "").trim();
   539	    }
   540	  }
   541	  // Tri-state precondition marker, mirroring ui/backend/routes/case_export.py's
   542	  // [✓]/[~]/[✗] renderer so the student / reviewer sees the same characters
   543	  // across the downloadable contract md and the in-UI panel. DEC-V61-046
   544	  // round-3 R3-B1: the backend now delivers the raw tri-state via
   545	  // Precondition.satisfied ∈ { true, false, "partial" }, so we can render
   546	  // it directly instead of reconstructing from evidence text.
   547	  const mark = (
   548	    satisfied: Precondition["satisfied"],
