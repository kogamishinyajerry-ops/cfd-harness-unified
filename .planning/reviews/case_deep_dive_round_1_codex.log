  1325	// Pure-SVG residual chart (no chart lib dependency). Shows a decaying
  1326	// multi-residual hint like a real simpleFoam log would render.
  1327	function ResidualsPreview() {
  1328	  const SERIES = useMemo(() => {
  1329	    const makeSeries = (decay: number, noise: number, seed: number) => {
  1330	      const pts: [number, number][] = [];
  1331	      let val = 1;
  1332	      for (let i = 0; i <= 60; i++) {
  1333	        val *= decay;
  1334	        const jitter = Math.sin(i * 0.7 + seed) * noise * val;
  1335	        pts.push([i, Math.max(val + jitter, 1e-6)]);
  1336	      }
  1337	      return pts;
  1338	    };
  1339	    return [
  1340	      { key: "p", color: "#60a5fa", pts: makeSeries(0.9, 0.2, 0.1) },
  1341	      { key: "Ux", color: "#a78bfa", pts: makeSeries(0.91, 0.22, 1.3) },
  1342	      { key: "Uy", color: "#f472b6", pts: makeSeries(0.92, 0.18, 2.1) },
  1343	    ];
  1344	  }, []);
  1345	
  1346	  const W = 560;
  1347	  const H = 160;
  1348	  const PADL = 36;
  1349	  const PADR = 12;
  1350	  const PADT = 8;
  1351	  const PADB = 22;
  1352	
  1353	  const xToPx = (x: number) => PADL + (x / 60) * (W - PADL - PADR);
  1354	  const yToPx = (y: number) => {
  1355	    // log scale from 1 down to 1e-6
  1356	    const logY = Math.log10(Math.max(y, 1e-6));
  1357	    const frac = (0 - logY) / 6; // 0 at top, 1 at bottom
  1358	    return PADT + frac * (H - PADT - PADB);
  1359	  };
  1360	
  1361	  return (
  1362	    <svg viewBox={`0 0 ${W} ${H}`} className="w-full" aria-hidden>
  1363	      {/* log-grid horizontal lines at 1e0..1e-6 */}
  1364	      {[0, -1, -2, -3, -4, -5, -6].map((p) => (
  1365	        <g key={p}>
  1366	          <line
  1367	            x1={PADL}
  1368	            x2={W - PADR}
  1369	            y1={yToPx(Math.pow(10, p))}
  1370	            y2={yToPx(Math.pow(10, p))}
  1371	            stroke="currentColor"
  1372	            className="text-surface-800"
  1373	            strokeWidth="0.5"
  1374	          />
  1375	          <text
  1376	            x={PADL - 6}
  1377	            y={yToPx(Math.pow(10, p)) + 3}
  1378	            fontSize="10"
  1379	            textAnchor="end"
  1380	            fill="currentColor"
  1381	            className="mono text-surface-500"
  1382	          >
  1383	            1e{p}
  1384	          </text>
  1385	        </g>
  1386	      ))}
  1387	      {/* x-axis */}
  1388	      <line
  1389	        x1={PADL}
  1390	        x2={W - PADR}
  1391	        y1={H - PADB}
  1392	        y2={H - PADB}
  1393	        stroke="currentColor"
  1394	        className="text-surface-700"
  1395	        strokeWidth="1"
  1396	      />
  1397	      <text
  1398	        x={(W + PADL) / 2}
  1399	        y={H - 6}
  1400	        fontSize="10"
  1401	        textAnchor="middle"
  1402	        fill="currentColor"
  1403	        className="text-surface-500"
  1404	      >
  1405	        迭代步数
  1406	      </text>
  1407	      {/* series */}
  1408	      {SERIES.map((s) => (
  1409	        <g key={s.key}>
  1410	          <polyline
  1411	            fill="none"
  1412	            stroke={s.color}
  1413	            strokeWidth="1.4"
  1414	            points={s.pts.map(([x, y]) => `${xToPx(x)},${yToPx(y)}`).join(" ")}
  1415	            opacity="0.85"
  1416	          />
  1417	          <text
  1418	            x={xToPx(61)}
  1419	            y={yToPx(s.pts[s.pts.length - 1][1]) + 3}
  1420	            fontSize="10"
  1421	            fill={s.color}
  1422	            className="mono"
  1423	          >
  1424	            {s.key}
  1425	          </text>
  1426	        </g>
  1427	      ))}
  1428	    </svg>
  1429	  );
  1430	}
