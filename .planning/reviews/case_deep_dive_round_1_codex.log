   615	                          </span>
   616	                        </summary>
   617	                        <div className="mt-1 mono text-[10px] leading-relaxed text-surface-500">
   618	                          {p.evidence_ref}
   619	                        </div>
   620	                      </details>
   621	                    )}
   622	                    {p.consequence_if_unsatisfied && (
