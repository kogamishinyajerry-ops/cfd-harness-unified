   561	      : "text-amber-300 border-amber-700/40 bg-amber-950/20";
   562	
   563	  return (
   564	    <section>
   565	      <div className="mb-3 flex items-baseline justify-between">
   566	        <h2 className="card-title">物理契约 · Physics contract</h2>
   567	        <p className="text-[11px] text-surface-500">
   568	          来自 knowledge/gold_standards/*.yaml
   569	        </p>
   570	      </div>
   571	      {narrative && (
   572	        <div className={`rounded-md border px-4 py-3 ${verdictTone}`}>
   573	          <p className="mono text-[11px] uppercase tracking-wider opacity-80">
   574	            contract_status
   575	          </p>
   576	          <p className="mt-0.5 text-[15px] font-semibold leading-snug">
   577	            {verdict}
   578	          </p>
   579	          {detail && (
   580	            <p className="mt-2 text-[13px] leading-relaxed text-surface-200">
   581	              {detail}
   582	            </p>
   583	          )}
   584	        </div>
   585	      )}
   586	      {preconds.length > 0 && (
   587	        <div className="mt-4">
   588	          <p className="mb-2 text-[11px] uppercase tracking-wider text-surface-500">
   589	            preconditions · 标记 [✓] 满足 · [~] 部分 · [✗] 不满足
   590	          </p>
   591	          <ul className="space-y-2">
   592	            {preconds.map((p, i) => {
   593	              const m = mark(p.satisfied);
   594	              return (
   595	                <li
   596	                  key={i}
   597	                  className="flex gap-3 rounded-md border border-surface-800 bg-surface-900/40 px-3 py-2"
   598	                >
   599	                  <span className={`mono font-semibold ${m.tone}`}>[{m.glyph}]</span>
   600	                  <div className="flex-1 text-[13px] leading-relaxed text-surface-200">
   601	                    {p.condition}
   602	                    {/* DEC-V61-047 round-1 F6: evidence_ref 是 reviewer-grade
   603	                        文本（含文件路径、adapter 行号、attestor 术语），对
