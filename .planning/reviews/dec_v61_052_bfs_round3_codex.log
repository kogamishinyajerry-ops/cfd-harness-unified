# authoritative wall-shear from allPatches
ap = pv.read('reports/phase5_fields/backward_facing_step/20260423T094706Z/VTK/allPatches/allPatches_1500.vtk')
cent = np.asarray(ap.cell_centers().points)
tau = np.asarray(ap['wallShearStress'])[:,0]
mask = (cent[:,1] < 0.05) & (cent[:,0] > 0.05)
xs = cent[mask,0]; tx = tau[mask]
order = np.argsort(xs)
xs=xs[order]; tx=tx[order]
xr_ws = None
for j in range(1,len(xs)):
    t1,t2=tx[j-1],tx[j]
    if t1 > 0 and t2 <= 0:
        xr_ws = xs[j-1] - t1*(xs[j]-xs[j-1])/(t2-t1) if abs(t2-t1) > 1e-30 else xs[j-1]
        break
# near-wall Ux proxy from volume VTK used by generator
vtk = pv.read('reports/phase5_fields/backward_facing_step/20260423T094706Z/VTK/1500.vtk')
centv = np.asarray(vtk.cell_centers().points)
ux = np.asarray(vtk['U'])[:,0]
from collections import defaultdict
xg = defaultdict(list)
for i,(cx,cy,cz) in enumerate(centv):
    if 0.0 <= cy < 0.025:
        xg[round(float(cx),3)].append(float(ux[i]))
pairs = [(x, sum(v)/len(v)) for x,v in sorted(xg.items())]
xr_ux = None
for j in range(1,len(pairs)):
    x1,u1 = pairs[j-1]
    x2,u2 = pairs[j]
    if u1 < 0 <= u2 and x1 > 0:
        xr_ux = x1 - u1*(x2-x1)/(u2-u1) if abs(u2-u1)>1e-10 else x1
        break
print('xr_ws', xr_ws)
print('xr_ux', xr_ux)
print('pct_diff', abs(xr_ws-xr_ux)/xr_ws*100 if xr_ws and xr_ux else None)
