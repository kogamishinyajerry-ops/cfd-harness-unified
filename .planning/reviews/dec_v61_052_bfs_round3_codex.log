   319	def _load_sample_xy(path: Path, value_col: int = 1) -> tuple[np.ndarray, np.ndarray]:
   320	    """Load an OpenFOAM raw-xy sample file. Returns (coord, value) arrays.
   321	
   322	    OpenFOAM's lineUniform function object writes either 2-col files
   323	    (coord + single-field-scalar) or 5-col files (coord + U_x + U_y + U_z
   324	    + p) depending on fields requested. Col 0 is always the sampling axis
   325	    coordinate. For u_centerline (sampled along y, U_x is the observable)
   326	    value_col=1 is correct. For v_centerline (sampled along x, U_y is the
   327	    observable) value_col=2.
   328	
   329	    DEC-V61-050 batch 1: value_col parameter added so a single helper
   330	    services both LDC observables without duplicating parser code.
   331	    """
   332	    rows = []
   333	    for line in path.read_text(encoding="utf-8").splitlines():
   334	        s = line.strip()
   335	        if not s or s.startswith("#"):
   336	            continue
   337	        parts = s.split()
   338	        try:
   339	            if value_col >= len(parts):
   340	                continue
   341	            rows.append([float(parts[0]), float(parts[value_col])])
   342	        except (ValueError, IndexError):
   343	            continue
   344	    if not rows:
   345	        raise ReportError(f"empty sample: {path}")
   346	    arr = np.array(rows)
   347	    return arr[:, 0], arr[:, 1]
