p = Path('reports/phase5_fields/backward_facing_step/20260423T094706Z/VTK/allPatches/allPatches_1500.vtk')
mesh = pv.read(str(p))
cent = np.asarray(mesh.cell_centers().points)
tau = np.asarray(mesh['wallShearStress'])[:,0]
patch = np.asarray(mesh['patchID'])
mask = (cent[:,1] < 0.05) & (cent[:,0] > 0.05)
for idx in np.where(mask)[0][-5:]:
    print(int(idx), 'patchID', patch[idx], 'x', float(cent[idx,0]), 'y', float(cent[idx,1]), 'tau_x', float(tau[idx]))
# find crossing per current algorithm
xs = cent[mask,0]; tx = tau[mask]
order = np.argsort(xs)
xs = xs[order]; tx = tx[order]
for j in range(1,len(xs)):
    t1,t2=tx[j-1],tx[j]
    if t1>0 and t2<=0:
        xr = xs[j-1]-t1*(xs[j]-xs[j-1])/(t2-t1) if abs(t2-t1)>1e-30 else xs[j-1]
        print('crossing at', float(xr), 'between', float(xs[j-1]), float(xs[j]), 'taus', float(t1), float(t2))
        break
