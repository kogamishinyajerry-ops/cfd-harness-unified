from pathlib import Path
import numpy as np

VTK='reports/phase5_fields/backward_facing_step/20260423T082933Z/VTK/ldc_28188_1776932973089_1000.vtk'

def skip_ws(b,pos):
    while pos < len(b) and b[pos:pos+1] in (b'\\n', b'\\r', b' ', b'\\t'):
        pos += 1
    return pos

def read_line(b,pos):
    pos=skip_ws(b,pos)
    j=b.find(b'\\n',pos)
    if j<0: raise ValueError('no newline')
    line=b[pos:j].decode('ascii', errors='replace')
    return line, j+1

def dtype_for(t):
    return {'float':'>f4','double':'>f8','int':'>i4','unsigned_int':'>u4'}[t]

def size_for(t):
    return np.dtype(dtype_for(t)).itemsize

def parse_vtk(path):
    b=Path(path).read_bytes(); pos=0
    lines=[]
    for _ in range(4):
        line,pos=read_line(b,pos); lines.append(line)
    # points
    line,pos=read_line(b,pos)
    parts=line.split(); assert parts[0]=='POINTS', parts
    npts=int(parts[1]); typ=parts[2]
    nbytes=npts*3*size_for(typ)
    points=np.frombuffer(b, dtype=dtype_for(typ), count=npts*3, offset=pos).astype(float).reshape(npts,3)
    pos += nbytes
    line,pos=read_line(b,pos)
    parts=line.split(); assert parts[0]=='CELLS', parts[:3]
    ncells=int(parts[1]); csize=int(parts[2])
    arr=np.frombuffer(b, dtype='>i4', count=csize, offset=pos).astype(int)
    pos += csize*4
    cells=[]; k=0
    for _ in range(ncells):
        m=arr[k]; cells.append(arr[k+1:k+1+m].copy()); k+=1+m
    line,pos=read_line(b,pos)
    parts=line.split(); assert parts[0]=='CELL_TYPES', parts[:2]
    nct=int(parts[1])
    cell_types=np.frombuffer(b, dtype='>i4', count=nct, offset=pos).astype(int); pos += nct*4
    sections={}
    while True:
        pos=skip_ws(b,pos)
        if pos>=len(b): break
        line,pos=read_line(b,pos)
        parts=line.split()
        if not parts: continue
        if parts[0] in ('CELL_DATA','POINT_DATA'):
            sec=parts[0]; ntuples=int(parts[1])
            line,pos=read_line(b,pos)
            fp=line.split(); assert fp[0]=='FIELD', (line,pos)
            nfields=int(fp[2])
            fields={}
            for _ in range(nfields):
                line,pos=read_line(b,pos)
                p=line.split();
                name=p[0]; ncomp=int(p[1]); nt=int(p[2]); typ=p[3]
                count=ncomp*nt; nbytes=count*size_for(typ)
                data=np.frombuffer(b, dtype=dtype_for(typ), count=count, offset=pos).astype(float if typ in ('float','double') else int)
                pos += nbytes
                if ncomp>1: data=data.reshape(nt,ncomp)
                fields[name]=data
            sections[sec]=fields
        else:
            print('unknown line', line[:80], 'pos', pos); break
    return points,cells,cell_types,sections

points,cells,ct,sections=parse_vtk(VTK)
print('points', points.shape, 'cells', len(cells), 'cell_types unique', sorted(set(ct.tolist())))
print('bounds x y z', points[:,0].min(), points[:,0].max(), points[:,1].min(), points[:,1].max(), points[:,2].min(), points[:,2].max())
print('step void points x<0,y<1', int(((points[:,0]<0)&(points[:,1]<1)).sum()))
for sec,fields in sections.items():
