# compute cell center from cells too
centers=np.array([points[c].mean(axis=0) for c in cells])
print('center bounds', centers[:,0].min(), centers[:,0].max(), centers[:,1].min(), centers[:,1].max())
print('cells in void center x<0,y<1', int(((centers[:,0]<0)&(centers[:,1]<1)).sum()))
# Compare Cx Cy arrays
cf=sections.get('CELL_DATA',{})
if 'Cx' in cf:
    print('Cx diff max', np.max(np.abs(cf['Cx']-centers[:,0])), 'Cy diff max', np.max(np.abs(cf['Cy']-centers[:,1])))
