    24	# Each alias set should be defensible from published solver/postProcessing
    25	# conventions — do not paper over real physics mismatches here.
    26	CANONICAL_ALIASES: Dict[str, Tuple[str, ...]] = {
    27	    # Darcy friction factor: solver may emit "f" (single letter),
    28	    # "fDarcy" (OpenFOAM turbulence function object), or "fFanning" (4× smaller).
    29	    # Do NOT include fFanning here — unit conversion is not an alias.
    30	    "friction_factor":    ("f", "fDarcy", "darcy_f", "darcyFrictionFactor"),
    31	    # Skin friction: OpenFOAM wallShearStress function object typically yields "Cf".
    32	    "cf_skin_friction":   ("Cf", "cf", "skin_friction", "skinFriction"),
    33	    # Pressure coefficient: Cp / cp / p_coeff all seen in the wild.
    34	    "pressure_coefficient": ("Cp", "cp", "p_coeff", "pressureCoefficient"),
    35	    # Nusselt: averaged over a patch is often "Nu_avg" / "averageNu".
    36	    "nusselt_number":     ("Nu", "Nu_avg", "Nu_mean", "averageNu", "nu_avg"),
    37	    # Strouhal: sometimes derived post-run and named "St" or "strouhal".
    38	    "strouhal_number":    ("St", "strouhal", "shedding_St"),
    39	    # Reattachment length in BFS: case-specific shorthand.
    40	    "reattachment_length": ("Xr_over_H", "reattachment_x", "xr_H"),
    41	    # Lid-driven cavity u-profile: legacy sampleDict set name "uCenterline".
    42	    # (adapter already does this rename for LDC specifically — redundancy is safe
