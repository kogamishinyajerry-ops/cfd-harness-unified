cellU=sec['CELL_DATA']['U'][:,0]
pointU=sec['POINT_DATA']['U'][:,0]

def xr_from_pairs(x,u,desc):
    order=np.argsort(x); x=x[order]; u=u[order]
    # average duplicate x by exact/rounded groups
    xr=[]; ur=[]
    for xx in sorted(set(np.round(x,6))):
        mask=np.isclose(x,xx,atol=1e-7)
        xr.append(xx); ur.append(float(np.mean(u[mask])))
    x=np.array(xr); u=np.array(ur)
    hit=None
    for i in range(1,len(u)):
        if u[i-1] < 0 and u[i] >= 0:
            x1,x2=x[i-1],x[i]; u1,u2=u[i-1],u[i]
            hit=x1 - u1*(x2-x1)/(u2-u1)
            break
    neg=u[(x>=0)&(x<=6)]
    print('\\n',desc,'n',len(x),'xr',hit)
    print(' x0-6 min max absmax', float(np.min(neg)), float(np.max(neg)), float(np.max(np.abs(neg))))
    for target in [0,0.5,1,1.5,1.7256,2,3,3.95,4,5,6]:
