            data=np.frombuffer(b,dtype=dt(typ),count=ncpt*nt,offset=pos).astype(float if typ"'!='"'int' else int); pos += ncpt*nt*sz(typ)
            if ncpt>1: data=data.reshape(nt,ncpt)
            fields[name]=data
        sections[sec]=fields
    return pts,cells,sections

