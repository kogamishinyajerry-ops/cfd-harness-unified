    line,pos=read_line(b,pos); nct=int(line.split()[1]); pos+=nct*4
    sections={}
    while True:
        pos=skip_ws(b,pos)
        if pos>=len(b): break
        line,pos=read_line(b,pos); parts=line.split()
        if parts[0] not in ('CELL_DATA','POINT_DATA'): break
        sec=parts[0]
        line,pos=read_line(b,pos); nfields=int(line.split()[2])
        fields={}
        for _ in range(nfields):
