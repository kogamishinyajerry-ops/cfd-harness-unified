   161	function RunDistributionPill({ summary }: { summary: CaseIndexEntry["run_summary"] }) {
   162	  if (!summary || summary.total === 0) return null;
   163	  const counts = summary.verdict_counts;
   164	  const chips: { label: string; color: string }[] = [];
   165	  if (counts.PASS) chips.push({ label: `${counts.PASS} PASS`, color: "text-contract-pass" });
   166	  if (counts.HAZARD) chips.push({ label: `${counts.HAZARD} HAZARD`, color: "text-contract-hazard" });
   167	  if (counts.FAIL) chips.push({ label: `${counts.FAIL} FAIL`, color: "text-contract-fail" });
   168	  if (counts.UNKNOWN) chips.push({ label: `${counts.UNKNOWN} UNKNOWN`, color: "text-surface-500" });
   169	  return (
   170	    <div className="flex flex-wrap items-baseline gap-2 text-[11px]">
   171	      <span className="mono text-surface-400">{summary.total} runs ·</span>
   172	      {chips.map((c, i) => (
   173	        <span key={i} className={`mono ${c.color}`}>{c.label}</span>
   174	      ))}
   175	    </div>
   176	  );
   177	}
