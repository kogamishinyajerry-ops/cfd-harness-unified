  1144	function formatNumber(v: number | undefined | null): string {
  1145	  if (v == null || !Number.isFinite(v)) return "—";
  1146	  const abs = Math.abs(v);
  1147	  if (abs === 0) return "0";
  1148	  if (abs < 0.001) return v.toExponential(2);
  1149	  if (abs < 1) return v.toFixed(4);
  1150	  if (abs < 100) return v.toFixed(3);
  1151	  return v.toFixed(1);
  1152	}
