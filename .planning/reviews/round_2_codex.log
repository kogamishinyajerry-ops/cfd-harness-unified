   424	// Physics-contract panel — surfaces the gold YAML's physics_contract block
   425	// (contract_status + preconditions with three-state satisfied markers) so a
   426	// reader sees the nuanced CFD-level verdict before the downstream PASS/HAZARD/
   427	// FAIL tile. Rendering is best-effort: if the backend hasn't returned the
   428	// ValidationReport yet we show a compact skeleton; if the case has no
   429	// physics_contract (shouldn't happen after DEC-V61-046 backfill) we hide.
   430	function PhysicsContractPanel({
   431	  report,
   432	}: {
   433	  report: ValidationReport | undefined;
   434	}) {
   435	  if (!report) {
   436	    return (
   437	      <section className="rounded-md border border-surface-800 bg-surface-900/30 px-4 py-3 text-[12px] text-surface-500">
   438	        正在从后端取回 physics contract…
   439	      </section>
   440	    );
   441	  }
   442	  const narrative = report.case.contract_status_narrative?.trim();
   443	  const preconds = report.preconditions ?? [];
   444	  if (!narrative && preconds.length === 0) {
   445	    return null;
   446	  }
   447	
   448	  // The contract_status string is often shaped "VERDICT — human detail".
   449	  // Split on the first em/en-dash or " - " so the verdict token can be
   450	  // highlighted while the detail stays as body text.
   451	  let verdict = narrative ?? "";
   452	  let detail = "";
   453	  if (narrative) {
   454	    const m = narrative.match(/^([A-Z_]+)(?:\s*[—\-–]\s*(.+))?$/s);
   455	    if (m) {
   456	      verdict = m[1];
   457	      detail = (m[2] ?? "").trim();
   458	    }
   459	  }
   460	  // Three-state precondition marker, mirroring ui/backend/routes/case_export.py's
   461	  // [✓]/[~]/[✗] renderer so the student / reviewer sees the same characters
   462	  // across the downloadable contract md and the in-UI panel.
   463	  const mark = (satisfied: Precondition["satisfied"]): {
   464	    glyph: string;
   465	    tone: string;
   466	  } => {
   467	    // Precondition.satisfied is bool in the TS type, but the backend relays
   468	    // the YAML's string "partial"/"partially" as a truthy-bool lossy cast.
   469	    // Fall back to narrative-level detection: evidence_ref often contains
   470	    // "partial" / "satisfied_by_current_adapter: partial" when the YAML
   471	    // used that label. See DEC-V61-046 round-2 follow-up for a cleaner
   472	    // wire-level 3-state enum.
   473	    if (typeof satisfied === "string") {
   474	      const s = (satisfied as string).toLowerCase();
