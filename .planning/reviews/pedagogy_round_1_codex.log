  1134	function formatNumber(v: number | undefined | null): string {
  1135	  if (v == null || !Number.isFinite(v)) return "—";
  1136	  const abs = Math.abs(v);
  1137	  if (abs === 0) return "0";
  1138	  if (abs < 0.001) return v.toExponential(2);
  1139	  if (abs < 1) return v.toFixed(4);
  1140	  if (abs < 100) return v.toFixed(3);
  1141	  return v.toFixed(1);
  1142	}
