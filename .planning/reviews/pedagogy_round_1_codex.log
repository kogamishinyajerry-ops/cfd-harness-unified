  1192	        val *= decay;
  1193	        const jitter = Math.sin(i * 0.7 + seed) * noise * val;
  1194	        pts.push([i, Math.max(val + jitter, 1e-6)]);
  1195	      }
  1196	      return pts;
  1197	    };
  1198	    return [
  1199	      { key: "p", color: "#60a5fa", pts: makeSeries(0.9, 0.2, 0.1) },
  1200	      { key: "Ux", color: "#a78bfa", pts: makeSeries(0.91, 0.22, 1.3) },
  1201	      { key: "Uy", color: "#f472b6", pts: makeSeries(0.92, 0.18, 2.1) },
  1202	    ];
  1203	  }, []);
  1204	
  1205	  const W = 560;
  1206	  const H = 160;
  1207	  const PADL = 36;
  1208	  const PADR = 12;
  1209	  const PADT = 8;
  1210	  const PADB = 22;
  1211	
  1212	  const xToPx = (x: number) => PADL + (x / 60) * (W - PADL - PADR);
  1213	  const yToPx = (y: number) => {
  1214	    // log scale from 1 down to 1e-6
  1215	    const logY = Math.log10(Math.max(y, 1e-6));
  1216	    const frac = (0 - logY) / 6; // 0 at top, 1 at bottom
  1217	    return PADT + frac * (H - PADT - PADB);
  1218	  };
  1219	
  1220	  return (
  1221	    <svg viewBox={`0 0 ${W} ${H}`} className="w-full" aria-hidden>
  1222	      {/* log-grid horizontal lines at 1e0..1e-6 */}
  1223	      {[0, -1, -2, -3, -4, -5, -6].map((p) => (
  1224	        <g key={p}>
  1225	          <line
  1226	            x1={PADL}
  1227	            x2={W - PADR}
  1228	            y1={yToPx(Math.pow(10, p))}
  1229	            y2={yToPx(Math.pow(10, p))}
  1230	            stroke="currentColor"
  1231	            className="text-surface-800"
  1232	            strokeWidth="0.5"
  1233	          />
  1234	          <text
  1235	            x={PADL - 6}
  1236	            y={yToPx(Math.pow(10, p)) + 3}
  1237	            fontSize="10"
  1238	            textAnchor="end"
  1239	            fill="currentColor"
  1240	            className="mono text-surface-500"
  1241	          >
  1242	            1e{p}
  1243	          </text>
  1244	        </g>
  1245	      ))}

