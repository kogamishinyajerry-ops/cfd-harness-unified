  1004	
  1005	function ConvergenceSparkline({
  1006	  series,
  1007	  goldRef,
  1008	  tolPct,
  1009	  activeIdx,
  1010	}: {
  1011	  series: { idx: number; label: string; value: number | null | undefined; status: ContractStatus }[];
  1012	  goldRef: number | undefined;
  1013	  tolPct: number | undefined;
  1014	  activeIdx: number;
  1015	}) {
  1016	  const W = 600;
  1017	  const H = 180;
  1018	  const padX = 40;
  1019	  const padY = 20;
  1020	
  1021	  const values = series
  1022	    .map((s) => s.value)
  1023	    .filter((v): v is number => v != null && Number.isFinite(v));
  1024	  if (goldRef == null || !Number.isFinite(goldRef) || values.length === 0) {
  1025	    return (
  1026	      <div className="h-[180px] rounded border border-surface-800 bg-surface-950/40 p-3 text-[11px] text-surface-500">
  1027	        等待后端数据…
  1028	      </div>
  1029	    );
  1030	  }
  1031	  const allVals = [...values, goldRef];
  1032	  if (tolPct != null) {
  1033	    allVals.push(goldRef * (1 + tolPct), goldRef * (1 - tolPct));
  1034	  }
  1035	  const yMin = Math.min(...allVals);
  1036	  const yMax = Math.max(...allVals);
  1037	  const yRange = yMax - yMin || Math.abs(goldRef) * 0.2 || 1;
  1038	  const yPad = yRange * 0.15;
  1039	  const yLo = yMin - yPad;
  1040	  const yHi = yMax + yPad;
  1041	
  1042	  const xStep = series.length > 1 ? (W - 2 * padX) / (series.length - 1) : 0;
  1043	  const toX = (i: number) => padX + i * xStep;
  1044	  const toY = (v: number) => padY + (H - 2 * padY) * (1 - (v - yLo) / (yHi - yLo));
  1045	
  1046	  const goldY = toY(goldRef);
  1047	  const upperY = tolPct != null ? toY(goldRef * (1 + tolPct)) : null;
  1048	  const lowerY = tolPct != null ? toY(goldRef * (1 - tolPct)) : null;
  1049	
  1050	  const points = series
  1051	    .map((s) =>
  1052	      s.value == null || !Number.isFinite(s.value)
  1053	        ? null
  1054	        : `${toX(s.idx)},${toY(s.value)}`,
  1055	    )
  1056	    .filter((p): p is string => p != null)
  1057	    .join(" ");
  1058	
  1059	  const statusColor: Record<ContractStatus, string> = {
  1060	    PASS: "#4ade80",
  1061	    HAZARD: "#fbbf24",
  1062	    FAIL: "#f87171",
  1063	    UNKNOWN: "#9ca3af",
  1064	  };
  1065	
  1066	  return (
  1067	    <div className="rounded border border-surface-800 bg-surface-950/40 p-3">
  1068	      <svg viewBox={`0 0 ${W} ${H}`} className="w-full" role="img">
  1069	        {/* tolerance band */}
  1070	        {upperY != null && lowerY != null && (
  1071	          <rect
  1072	            x={padX - 6}
  1073	            y={Math.min(upperY, lowerY)}
  1074	            width={W - 2 * padX + 12}
  1075	            height={Math.abs(upperY - lowerY)}
  1076	            fill="#4ade80"
  1077	            opacity={0.08}
  1078	          />
  1079	        )}
  1080	        {/* gold line */}
  1081	        <line
  1082	          x1={padX - 6}
  1083	          x2={W - padX + 6}
  1084	          y1={goldY}
  1085	          y2={goldY}

