   439	      </section>
   440	    );
   441	  }
   442	  const narrative = report.case.contract_status_narrative?.trim();
   443	  const preconds = report.preconditions ?? [];
   444	  if (!narrative && preconds.length === 0) {
   445	    return null;
   446	  }
   447	
   448	  // The contract_status string is often shaped "VERDICT — human detail".
   449	  // Split on the first em/en-dash or " - " so the verdict token can be
   450	  // highlighted while the detail stays as body text.
   451	  let verdict = narrative ?? "";
   452	  let detail = "";
   453	  if (narrative) {
   454	    const m = narrative.match(/^([A-Z_]+)(?:\s*[—\-–]\s*(.+))?$/s);
   455	    if (m) {
   456	      verdict = m[1];
   457	      detail = (m[2] ?? "").trim();
   458	    }
   459	  }
   460	  // Tri-state precondition marker, mirroring ui/backend/routes/case_export.py's
   461	  // [✓]/[~]/[✗] renderer so the student / reviewer sees the same characters
   462	  // across the downloadable contract md and the in-UI panel. DEC-V61-046
   463	  // round-3 R3-B1: the backend now delivers the raw tri-state via
   464	  // Precondition.satisfied ∈ { true, false, "partial" }, so we can render
   465	  // it directly instead of reconstructing from evidence text.
   466	  const mark = (
   467	    satisfied: Precondition["satisfied"],
   468	  ): { glyph: string; tone: string } => {
   469	    if (satisfied === "partial") return { glyph: "~", tone: "text-amber-300" };
   470	    if (satisfied === false) return { glyph: "✗", tone: "text-contract-fail" };
   471	    return { glyph: "✓", tone: "text-contract-pass" };
   472	  };
   473	
   474	  const verdictTone =
   475	    verdict.startsWith("SATISFIED") || verdict === "COMPATIBLE"
   476	      ? "text-contract-pass border-contract-pass/40 bg-contract-pass/10"
   477	      : verdict.startsWith("INCOMPATIBLE") ||
   478	        verdict.startsWith("INCOMPATIBLE_WITH_LITERATURE")
   479	      ? "text-contract-fail border-contract-fail/40 bg-contract-fail/10"
   480	      : "text-amber-300 border-amber-700/40 bg-amber-950/20";
   481	
   482	  return (
   483	    <section>
   484	      <div className="mb-3 flex items-baseline justify-between">
   485	        <h2 className="card-title">物理契约 · Physics contract</h2>
   486	        <p className="text-[11px] text-surface-500">
   487	          来自 knowledge/gold_standards/*.yaml
   488	        </p>
