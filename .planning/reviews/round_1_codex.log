   440	
   441	def _make_audit_concerns(
   442	    gs_doc: dict[str, Any] | None,
   443	    measurement_doc: dict[str, Any] | None,
   444	) -> list[AuditConcern]:
   445	    out: list[AuditConcern] = []
   446	    # (1) Contract-status narrative from gold_standards → top-level concern.
   447	    if gs_doc:
   448	        status_narrative = (
   449	            (gs_doc.get("physics_contract") or {}).get("contract_status") or ""
   450	        ).strip()
   451	        if status_narrative:
   452	            out.append(
   453	                AuditConcern(
   454	                    concern_type="CONTRACT_STATUS",
   455	                    summary=(
   456	                        status_narrative.splitlines()[0][:240]
   457	                        if status_narrative
   458	                        else ""
   459	                    ),
   460	                    detail=status_narrative,
   461	                    decision_refs=_extract_decision_refs(status_narrative),
   462	                )
   463	            )
   464	    # (2) Measurement-level audit concerns (fixture or slice_metrics).
   465	    if measurement_doc:
   466	        for concern in measurement_doc.get("audit_concerns", []) or []:
   467	            out.append(
   468	                AuditConcern(
   469	                    concern_type=concern.get("concern_type", "UNKNOWN"),
   470	                    summary=concern.get("summary", ""),
   471	                    detail=concern.get("detail"),
   472	                    decision_refs=concern.get("decision_refs", []) or [],
   473	                )
   474	            )
   475	        # (3) DEC-V61-036 G1: synthesize MISSING_TARGET_QUANTITY concern when
   476	        # the extractor signalled it could not resolve the gold's quantity.
   477	        # Triggers:
   478	        #   - measurement.extraction_source == "no_numeric_quantity" (new post-DEC)
   479	        #   - measurement.extraction_source == "key_quantities_fallback" (legacy
   480	        #     fixtures — this was the silent-substitution bug marker itself)
   481	        #   - measurement.value is None (explicit missing)
   482	        # Surfacing as a first-class concern lets _derive_contract_status
   483	        # hard-FAIL and the UI display the schema failure separately from
   484	        # numeric deviations.
   485	        m = measurement_doc.get("measurement") or {}
   486	        src = m.get("extraction_source")
   487	        g1_miss = (
   488	            src == "no_numeric_quantity"
   489	            or src == "key_quantities_fallback"
   490	            or m.get("value") is None
   491	        )
   492	        if g1_miss:
   493	            gold_quantity = m.get("quantity") or "<unknown>"
   494	            out.append(
   495	                AuditConcern(
   496	                    concern_type="MISSING_TARGET_QUANTITY",
   497	                    summary=(
   498	                        f"Extractor could not locate gold quantity "
   499	                        f"'{gold_quantity}' in run key_quantities."
   500	                    ),
   501	                    detail=(
   502	                        "DEC-V61-036 G1: the case-specific extractor did not "
   503	                        "emit the gold standard's target quantity and the "
   504	                        "result_comparator alias lookup also missed. Prior "
   505	                        "behavior silently substituted the first numeric "
   506	                        "key_quantities entry — that PASS-washing path is now "
   507	                        "closed. Measurement.value = None, contract_status = FAIL."
   508	                    ),
   509	                    decision_refs=["DEC-V61-036"],
   510	                )
   511	            )
   512	    return out
   513	
   514	
   515	def _extract_decision_refs(text: str) -> list[str]:
   516	    """Pull DEC-ADWM-00N / DEC-V61-00N tokens out of narrative text."""
   517	    import re
   518	
   519	    return sorted(set(re.findall(r"DEC-(?:ADWM|V61)-\d{3}", text)))
