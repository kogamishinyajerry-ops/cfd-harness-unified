     1	"""Shared 3-point one-sided wall-gradient stencil.
     2	
     3	DEC-V61-042: previously, each of the three Nu-emitting cases (DHC, RBC,
     4	impinging_jet) used its own 1-point finite-difference between two
     5	interior cells to approximate d(T)/d(normal) at the wall. That is
     6	1st-order accurate at the midpoint of the two cells — NOT at the wall —
     7	and systematically misreads the gradient by 30-50% for an
     8	exponential-like thermal boundary layer on coarse meshes.
     9	
    10	This module provides a single 2nd-order one-sided stencil that uses the
    11	wall value from the BC itself plus the two nearest interior cell-centre
    12	values. The stencil is the standard Fornberg non-uniform-spacing formula.
    13	
    14	It also enforces a BC contract: if the wall BC is `fixedGradient`, the
    15	helper returns the BC value directly (the gradient IS the BC — a stencil
    16	over interior cells is a self-consistency mistake, not a measurement).
    17	Any other BC type raises `BCContractViolation` so callers fail closed
    18	rather than silently falling back to a wrong number.
    19	"""
    20	
    21	from __future__ import annotations
    22	
    23	from dataclasses import dataclass
    24	from typing import Literal, Optional, Sequence, Tuple
    25	
    26	
    27	class BCContractViolation(Exception):
    28	    """Raised when wall-gradient extraction is attempted under inputs
    29	    that cannot yield a physically meaningful wall gradient.
    30	
    31	    Examples:
    32	      - `fixedGradient` BC with `bc_gradient` not provided (the BC IS
    33	        the answer; a stencil over interior cells would shadow it).
    34	      - Unknown BC type (callers must either extend the stencil's
    35	        awareness or use a different extractor).
    36	      - Fewer than 2 interior cells supplied.
    37	      - Non-monotonic wall-normal ordering (wall not strictly below
    38	        both interior coords).
    39	    """
    40	
    41	
    42	@dataclass(frozen=True)
    43	class WallGradientStencil:
    44	    """Non-uniform 3-point one-sided stencil for f'(wall).
    45	
    46	    With wall at ``x_w`` and two interior cell-centres at ``x_1 < x_2``,
    47	    spacing ``h_1 = x_1 - x_w`` and ``h_2 = x_2 - x_w``:
    48	
    49	        f'(x_w) = -(h_1 + h_2)/(h_1 h_2)   * f(x_w)
    50	                + h_2 / (h_1 (h_2 - h_1))  * f(x_1)
    51	                - h_1 / (h_2 (h_2 - h_1))  * f(x_2)
    52	
    53	    The formula is O(h^2) accurate for smooth f and reduces to the
    54	    textbook uniform-spacing stencil (-3,4,-1)/(2h) when h_2 = 2*h_1.
    55	
    56	    `bc_type` is advisory — the caller's extractor already knows what
    57	    the wall BC is from the generator. Passing it here lets us fail
    58	    closed if the contract is violated.
    59	    """
    60	
    61	    wall_coord: float
    62	    wall_value: float
    63	    coords: Tuple[float, float]  # cell-centre coords, sorted ascending
    64	    values: Tuple[float, float]
    65	    bc_type: Literal["fixedValue", "fixedGradient"]
    66	    bc_gradient: Optional[float] = None
    67	
    68	    def compute(self) -> float:
    69	        if self.bc_type == "fixedGradient":
    70	            if self.bc_gradient is None:
    71	                raise BCContractViolation(
    72	                    "fixedGradient BC declared but bc_gradient is None; the BC "
    73	                    "itself is the source of truth for wall gradient — a stencil "
    74	                    "over interior cells would silently shadow it."
    75	                )
    76	            return float(self.bc_gradient)
    77	
    78	        if self.bc_type != "fixedValue":
    79	            raise BCContractViolation(
    80	                f"Unsupported wall BC type {self.bc_type!r}; "
    81	                "extend WallGradientStencil or use a different extractor."
    82	            )
    83	
    84	        h1 = self.coords[0] - self.wall_coord
    85	        h2 = self.coords[1] - self.wall_coord
    86	        if h1 <= 0.0 or h2 <= h1:
    87	            raise BCContractViolation(
    88	                f"Non-monotonic wall-normal layout: wall_coord={self.wall_coord}, "
    89	                f"coords={self.coords}; required wall < coords[0] < coords[1]."
    90	            )
    91	        c_w = -(h1 + h2) / (h1 * h2)
    92	        c_1 = h2 / (h1 * (h2 - h1))
    93	        c_2 = -h1 / (h2 * (h2 - h1))
    94	        return (
    95	            c_w * self.wall_value
    96	            + c_1 * self.values[0]
    97	            + c_2 * self.values[1]
    98	        )
    99	
   100	
   101	def extract_wall_gradient(
   102	    wall_coord: float,
   103	    wall_value: float,
   104	    coords: Sequence[float],
   105	    values: Sequence[float],
   106	    *,
   107	    bc_type: Literal["fixedValue", "fixedGradient"],
   108	    bc_gradient: Optional[float] = None,
   109	) -> float:
   110	    """Compute f'(wall) from wall BC + two nearest interior cells.
   111	
   112	    Picks the two interior cells nearest to `wall_coord` and applies
   113	    `WallGradientStencil`. Callers pass all interior cells in the
   114	    layer; this function handles selection + ordering.
   115	
   116	    Raises `BCContractViolation` when the inputs cannot yield a
   117	    physically meaningful gradient.
   118	    """
   119	    if len(coords) != len(values):
   120	        raise BCContractViolation(
   121	            f"coords/values length mismatch: {len(coords)} vs {len(values)}"
   122	        )
   123	    if len(coords) < 2:
   124	        raise BCContractViolation(
   125	            f"wall-gradient requires ≥2 interior cells, got {len(coords)}"
   126	        )
   127	    paired = sorted(zip(coords, values), key=lambda p: abs(p[0] - wall_coord))
   128	    (c0, v0), (c1, v1) = paired[0], paired[1]
   129	    ordered = sorted(((c0, v0), (c1, v1)), key=lambda p: p[0] - wall_coord)
   130	    stencil = WallGradientStencil(
   131	        wall_coord=wall_coord,
   132	        wall_value=wall_value,
   133	        coords=(ordered[0][0], ordered[1][0]),
   134	        values=(ordered[0][1], ordered[1][1]),
   135	        bc_type=bc_type,
   136	        bc_gradient=bc_gradient,
   137	    )
   138	    return stencil.compute()

