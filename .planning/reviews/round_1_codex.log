   694	            <td><span class="status-pill {verdict_pill}">{escape(state.verdict)}</span><br>{escape(state.overall)}</td>
   695	            <td><span class="status-pill {contract_pill}">{escape(state.contract_class)}</span><br>{escape(state.hazard)}</td>
   696	            <td>{escape(state.measurement)}</td>
   697	            <td>{escape(state.next_step)}</td>
   698	          </tr>
   699	        """
   700	
   701	    def _render_case_card(self, state: DashboardCaseState) -> str:
   702	        verdict_pill = self._pill_class_for_verdict(state.verdict)
   703	        contract_pill = self._pill_class_for_contract(state.contract_class)
   704	        return f"""
   705	        <article class="case-card">
   706	          <div class="case-meta">
   707	            <div>
   708	              <div class="label">Case</div>
   709	              <h3>{escape(state.spec.title)}</h3>
   710	              <div class="case-subtitle">{escape(state.spec.subtitle)}</div>
   711	            </div>
   712	            <div class="pill-row">
   713	              <span class="status-pill {verdict_pill}">{escape(state.verdict)}</span>
   714	              <span class="status-pill {contract_pill}">{escape(self._short_label(state.contract_class))}</span>
   715	            </div>
   716	          </div>
   717	          <p>{escape(state.spec.focus)}</p>
   718	          <div class="case-callout"><strong>当前观测：</strong> {escape(state.measurement)}</div>
   719	          <div class="case-callout"><strong>风险说明：</strong> {escape(state.hazard)}</div>
   720	          <div class="case-callout"><strong>下一步：</strong> {escape(state.next_step)}</div>
   721	          <div class="pill-row">
   722	            <span class="pill">{escape(state.lane_label)}</span>
   723	            <span class="pill">{escape(state.reference)}</span>
   724	          </div>
   725	          <p class="artifact-link"><a href="{escape(state.gold_path)}">gold standard</a> · <a href="{escape(state.report_path)}">runtime report</a> · <a href="{escape(state.deep_link_path)}">deep evidence</a></p>
   726	        </article>
   727	        """
   728	
   729	    def _load_case(self, spec: DashboardCaseSpec) -> DashboardCaseState:
   730	        gold_path = KNOWLEDGE_ROOT / "gold_standards" / spec.gold_file
   731	        gold = self._load_gold_standard(gold_path)
   732	        report_path = REPORTS_ROOT / spec.report_case_id / "auto_verify_report.yaml"
   733	        report = self._load_optional_yaml(report_path) or {}
   734	        verdict = str(report.get("verdict") or "NO_RUNTIME_REPORT")
   735	        overall = str((report.get("gold_standard_comparison") or {}).get("overall") or "NO_RUNTIME_REPORT")
   736	        raw_status = str((gold.get("physics_contract") or {}).get("contract_status") or "UNKNOWN")
   737	        contract_class = self._normalize_contract_class(raw_status)
   738	        reference = str(gold.get("source") or self._whitelist_reference(spec.whitelist_id) or "[DATA MISSING]")
   739	        measurement = self._measurement(spec, report)
   740	        hazard = self._hazard(spec, report, raw_status)
   741	        lane = self._lane(spec, contract_class, verdict)
   742	        lane_label = {
   743	            "demo": "Physics-backed demo",
   744	            "watch": "Caveat-required",
   745	            "block": "Governance / structural blocker",
   746	        }[lane]
   747	        deep_link_path = self._deep_link_path(spec)
   748	        return DashboardCaseState(
   749	            spec=spec,
   750	            reference=reference,
   751	            verdict=verdict,
   752	            overall=overall,
   753	            contract_status=raw_status,
   754	            contract_class=contract_class,
   755	            measurement=measurement,
   756	            hazard=hazard,
   757	            lane=lane,
   758	            lane_label=lane_label,
   759	            next_step=spec.next_step,
   760	            gold_path=self._relative_link(gold_path),

