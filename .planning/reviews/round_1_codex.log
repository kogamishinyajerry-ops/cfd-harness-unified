   628	}) {
   629	  // Compute a display range that includes gold, both tolerance bounds,
   630	  // and measured — with sensible margin. Clamp width to avoid division
   631	  // by zero for PASS cases where measured ≈ gold.
   632	  const values = [lower, upper, goldValue, measured].filter(
   633	    (v): v is number => v !== null && Number.isFinite(v),
   634	  );
   635	  const rawMin = Math.min(...values);
   636	  const rawMax = Math.max(...values);
   637	  const span = Math.max(rawMax - rawMin, Math.abs(goldValue) * 0.3, 0.01);
   638	  const padding = span * 0.2;
   639	  const displayMin = rawMin - padding;
   640	  const displayMax = rawMax + padding;
   641	  const toPct = (v: number) =>
   642	    ((v - displayMin) / (displayMax - displayMin)) * 100;
   643	
   644	  const goldX = toPct(goldValue);
   645	  const lowerX = toPct(lower);
   646	  const upperX = toPct(upper);
   647	  const measuredX = measured !== null ? toPct(measured) : null;
   648	  const measuredInside = measured !== null && measured >= lower && measured <= upper;
   649	
   650	  return (
   651	    <div className="relative mt-1">
   652	      {/* Track */}
   653	      <div className="relative h-2 rounded-full bg-surface-800">
