   617	function ToleranceBand({
   618	  goldValue,
   619	  lower,
   620	  upper,
   621	  measured,
   622	}: {
   623	  goldValue: number;
   624	  tolerancePct: number;
   625	  lower: number;
   626	  upper: number;
