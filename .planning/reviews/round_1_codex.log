    73	            decision_id=c.decision_id,
    74	            title=c.title,
    75	            column=c.column,
    76	            autonomous=c.autonomous,
    77	            github_pr_url=c.github_pr_url,
    78	            notion_url=c.notion_url,
    79	        )
    80	        for c in sorted(decisions_snap.cards, key=lambda c: str(c.timestamp))
    81	    ]
    82	    summary: dict[str, int] = {
    83	        "total_cases": len(cases),
    84	        "pass_cases": sum(1 for c in cases if c.contract_status == "PASS"),
    85	        "hazard_cases": sum(1 for c in cases if c.contract_status == "HAZARD"),
    86	        "fail_cases": sum(1 for c in cases if c.contract_status == "FAIL"),
    87	        "unknown_cases": sum(1 for c in cases if c.contract_status == "UNKNOWN"),
    88	        "open_gates": sum(1 for g in decisions_snap.gate_queue if g.state == "OPEN"),
    89	        "closed_gates": sum(1 for g in decisions_snap.gate_queue if g.state == "CLOSED"),
    90	        "accepted_decisions": decisions_snap.counts.get("Accepted", 0),
    91	        "closed_decisions": decisions_snap.counts.get("Closed", 0),
