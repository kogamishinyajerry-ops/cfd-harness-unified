    77	function RunDistributionPill({ summary }: { summary: CaseIndexEntry["run_summary"] }) {
    78	  if (!summary || summary.total === 0) return null;
    79	  const counts = summary.verdict_counts;
    80	  const chips: { label: string; color: string }[] = [];
    81	  if (counts.PASS) chips.push({ label: `${counts.PASS} PASS`, color: "text-contract-pass" });
    82	  if (counts.HAZARD) chips.push({ label: `${counts.HAZARD} HAZARD`, color: "text-contract-hazard" });
    83	  if (counts.FAIL) chips.push({ label: `${counts.FAIL} FAIL`, color: "text-contract-fail" });
    84	  if (counts.UNKNOWN) chips.push({ label: `${counts.UNKNOWN} UNKNOWN`, color: "text-surface-500" });
    85	  return (
    86	    <div className="flex flex-wrap items-baseline gap-2 text-[11px]">
    87	      <span className="mono text-surface-400">{summary.total} runs ·</span>
    88	      {chips.map((c, i) => (
    89	        <span key={i} className={`mono ${c.color}`}>{c.label}</span>
    90	      ))}
    91	    </div>
    92	  );
    93	}
