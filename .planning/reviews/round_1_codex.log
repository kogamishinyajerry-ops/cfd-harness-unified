    21	STATE_FILE = REPO_ROOT / ".planning" / "STATE.md"
    22	
    23	
    24	@dataclass(slots=True)
    25	class DashboardTimelineEvent:
    26	    date: str
    27	    decision_id: str
    28	    title: str
    29	    column: str
    30	    autonomous: bool
    31	    github_pr_url: str | None
    32	    notion_url: str | None
    33	
    34	
    35	@dataclass(slots=True)
    36	class DashboardSnapshot:
    37	    cases: list[CaseIndexEntry] = field(default_factory=list)
    38	    gate_queue: list[GateQueueItem] = field(default_factory=list)
    39	    timeline: list[DashboardTimelineEvent] = field(default_factory=list)
    40	    summary: dict[str, int] = field(default_factory=dict)
    41	    current_phase: str = ""
    42	    autonomous_governance_counter: int | None = None
    43	
    44	
    45	def _extract_current_phase() -> tuple[str, int | None]:
    46	    """Scrape current_phase + autonomous_governance counter from STATE.md."""
    47	    if not STATE_FILE.exists():
    48	        return ("", None)
    49	    text = STATE_FILE.read_text(encoding="utf-8", errors="ignore")
    50	    phase = ""
    51	    counter: int | None = None
    52	    for line in text.splitlines():
    53	        s = line.strip()
    54	        if s.startswith("current_phase:") and not phase:
    55	            phase = s.split("current_phase:", 1)[-1].strip().strip("*`")
    56	        if "autonomous_governance" in s and counter is None:
    57	            # Look for "N of 10" / "counter = N" / "counter: N"
    58	            import re as _re
    59	            m = _re.search(r"(\d{1,2})\s*(?:/\s*10|of\s*10|slots)", s)
    60	            if m:
    61	                counter = int(m.group(1))
    62	            elif "= 2" in s or "=2" in s:
    63	                counter = 2
    64	    return (phase, counter)
    65	
    66	
    67	def build_dashboard() -> DashboardSnapshot:
    68	    cases = list_cases()
    69	    decisions_snap = list_decisions()
