    86	class Check:
    87	    """A single pre-flight finding. level ∈ {pass, warn, fail}."""
    88	
    89	    def __init__(self, name: str, level: str, detail: str, evidence: Optional[dict] = None) -> None:
    90	        self.name = name
    91	        self.level = level
    92	        self.detail = detail
    93	        self.evidence = evidence or {}
    94	
    95	    def format(self) -> str:
    96	        color = {"pass": GREEN, "warn": AMBER, "fail": RED}.get(self.level, "")
    97	        tag = {"pass": "GREEN", "warn": "AMBER", "fail": "RED  "}.get(self.level, "?????")
    98	        return f"  {color}{tag}{RESET}  {self.name}: {self.detail}"
