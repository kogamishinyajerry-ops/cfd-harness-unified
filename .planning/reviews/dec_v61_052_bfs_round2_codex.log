   100	
   101	def _load_gold(case_id: str) -> Optional[dict]:
   102	    path = _GOLD_ROOT / f"{case_id}.yaml"
   103	    if not path.is_file():
   104	        return None
   105	    try:
   106	        # Multi-doc YAML — the physics_contract lives in the first doc.
   107	        docs = list(yaml.safe_load_all(path.read_text(encoding="utf-8")))
   108	        return next((d for d in docs if isinstance(d, dict) and "physics_contract" in d), None)
   109	    except yaml.YAMLError:
   110	        return None
   111	
   112	
   113	def _check_gold_status(case_id: str) -> Check:
   114	    doc = _load_gold(case_id)
   115	    if doc is None:
   116	        return Check("gold YAML", "warn",
   117	                    f"no gold YAML found at knowledge/gold_standards/{case_id}.yaml")
   118	    contract = doc.get("physics_contract", {})
   119	    status = contract.get("contract_status", "UNKNOWN")
   120	    lowered = str(status).lower()
   121	    if "hazard" in lowered or "fail" in lowered or "not_satisfied" in lowered:
   122	        return Check("gold contract_status", "fail",
   123	                    f"gold YAML self-documents hazard: {status[:120]}",
   124	                    evidence={"contract_status": status})
   125	    if "partial" in lowered or "compatible" in lowered:
   126	        return Check("gold contract_status", "warn",
   127	                    f"gold YAML: {status[:120]}",
   128	                    evidence={"contract_status": status})
   129	    return Check("gold contract_status", "pass", status[:80])
   130	
   131	
   132	def _pick_fixture_dir(case_id: str) -> Optional[Path]:
   133	    case_dir = _FIELDS_ROOT / case_id
   134	    if not case_dir.is_dir():
   135	        return None
   136	    candidates = [p for p in case_dir.iterdir() if p.is_dir() and p.name[0].isdigit()]
   137	    if not candidates:
   138	        return None
   139	    return sorted(candidates)[-1]
