/bin/zsh -lc "python3.11 - <<'PY'
import pyvista as pv
import numpy as np
from pathlib import Path
for rel in ['reports/phase5_fields/backward_facing_step/20260423T091828Z/VTK/allPatches/allPatches_1500.vtk','reports/phase5_fields/backward_facing_step/20260423T091828Z/VTK/ldc_32849_1776935908397_1500.vtk']:
    mesh=pv.read(rel)
    print('\\n', rel)
    centers=mesh.cell_centers().points
    wss=np.asarray(mesh.cell_data['wallShearStress'])
    U=np.asarray(mesh.cell_data['U'])
    print('n_cells', mesh.n_cells, 'wss shape', wss.shape, 'wss tx min/max', float(np.nanmin(wss[:,0])), float(np.nanmax(wss[:,0])))
    mask=(centers[:,1] < 0.01) & (centers[:,0] > 0.05)
    print('floor cells', int(mask.sum()), 'x range', (float(centers[mask,0].min()) if mask.any() else None, float(centers[mask,0].max()) if mask.any() else None))
    if mask.any():
        data=sorted(zip(centers[mask,0], wss[mask,0], U[mask,0]))
        # Sign crossing t1<0 t2>=0
        xr=None
        for (x1,t1,u1),(x2,t2,u2) in zip(data, data[1:]):
            if t1 < 0 and t2 >= 0:
                xr=x1 - t1*(x2-x1)/(t2-t1)
                print('wss crossing', xr, 'bracket', (x1,t1),(x2,t2))
                break
        xr2=None
        for (x1,t1,u1),(x2,t2,u2) in zip(data, data[1:]):
            if u1 < 0 and u2 >= 0:
                xr2=x1 - u1*(x2-x1)/(u2-u1)
                print('U crossing on floor patch/cell', xr2, 'bracket', (x1,u1),(x2,u2))
