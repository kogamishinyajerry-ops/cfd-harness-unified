   306	            (f"{quantity}_y", "y"),
   307	            # DEC-V61-036c G2: plane_channel u+/y+ DNS profile. Gold has
   308	            # `y_plus` as the reference axis; the adapter emits
   309	            # `u_mean_profile_y_plus` (or its alias `y_plus`) as the
   310	            # actual axis. Without this candidate, axis resolution fell
   311	            # through to positional matching and the comparator silently
   312	            # did not honestly compare u+ against y+.
   313	            (f"{quantity}_y_plus", "y_plus"),
   314	            ("y_plus", "y_plus"),
   315	            (f"{quantity}_x", "x"),
   316	            (f"{quantity}_x", "x_over_c"),
   317	            (f"{quantity}_x", "x_D"),
   318	            (f"{quantity}_x", "x_H"),
