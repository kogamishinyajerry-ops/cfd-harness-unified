   321	            # Pre-existing gap (not introduced by G2), fixed here.
   322	            (f"{quantity}_x", "r_over_d"),
   323	            (f"{quantity}_x", "r_D"),
   324	            (f"{quantity}_x", "r"),
   325	        ]
