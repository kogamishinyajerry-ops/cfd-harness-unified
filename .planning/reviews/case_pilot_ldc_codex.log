   339	    @staticmethod
   340	    def _interp1d(xs: List[float], ys: List[float], x_target: float) -> float:
   341	        """线性插值。xs 必须单调递增。"""
   342	        if x_target <= xs[0]:
   343	            return ys[0]
   344	        if x_target >= xs[-1]:
   345	            return ys[-1]
   346	        for k in range(len(xs) - 1):
   347	            if xs[k] <= x_target <= xs[k + 1]:
   348	                if xs[k + 1] == xs[k]:
   349	                    return ys[k]
   350	                frac = (x_target - xs[k]) / (xs[k + 1] - xs[k])
   351	                return ys[k] + frac * (ys[k + 1] - ys[k])
   352	        return ys[-1]

