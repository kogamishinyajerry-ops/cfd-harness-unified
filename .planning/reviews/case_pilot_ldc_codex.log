    79	  // the page is a description of a result, not a chapter the student
    80	  // can follow.
    81	  // Schema:
    82	  //   workflow_steps_zh: ordered array of {step, command?, detail}.
    83	  //     Each step is one line of a reproducibility runbook. command is
    84	  //     the literal OpenFOAM or shell command (optional — some steps
    85	  //     are "edit this file" not "run this utility"). detail is 1-3
    86	  //     sentences of Chinese explaining what happens and what to
    87	  //     inspect after that step.
    88	  //   troubleshooting_zh: array of {symptom, likely_cause, fix} triples
    89	  //     covering the 4-6 highest-likelihood failure modes for this
    90	  //     specific case. Ordered by likelihood (most common first).
    91	  // ======================================================================
    92	  workflow_steps_zh: {
    93	    step: string;
    94	    command?: string;
    95	    detail: string;
    96	  }[];
    97	  troubleshooting_zh: {
    98	    symptom: string;
    99	    likely_cause: string;
   100	    fix: string;
