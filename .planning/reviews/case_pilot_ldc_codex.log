   281	        })
   282	    if len(rows) < 2:
   283	        return rows, "insufficient mesh data"
   284	    devs = [r["dev_pct"] for r in rows]
   285	    monotone = all(devs[i] >= devs[i + 1] for i in range(len(devs) - 1))
   286	    note = "单调递减 ✓" if monotone else "非严格单调 — 检查 fixture"
   287	    return rows, note
