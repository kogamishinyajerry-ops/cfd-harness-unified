  7937	        x_tol = 0.6 * dx_typical  # strictly narrower than one full cell width
  7938	
  7939	        y_groups: Dict[float, List[float]] = defaultdict(list)
  7940	
  7941	        for i in range(len(cxs)):
  7942	            if abs(cxs[i] - x_target) < x_tol:
  7943	                yr = round(cys[i], 4)
  7944	                y_groups[yr].append(u_vecs[i][0])  # Ux component
  7945	
  7946	        if not y_groups:
  7947	            return key_quantities
  7948	
  7949	        # 建立 [y_norm, avg_Ux] profile，插值到 Ghia 1982 位置
  7950	        ghia_y = [0.0000, 0.0625, 0.1250, 0.1875, 0.2500, 0.3125, 0.3750,
  7951	                  0.4375, 0.5000, 0.5625, 0.6250, 0.6875, 0.7500, 0.8125,
  7952	                  0.8750, 0.9375, 1.0000]
  7953	
  7954	        sorted_y = sorted(y_groups.keys())
  7955	        profile = [(yr / 0.1, sum(y_groups[yr]) / len(y_groups[yr])) for yr in sorted_y]
  7956	
  7957	        # 线性插值到 Ghia y 位置
  7958	        u_centerline = []
  7959	        for g_y in ghia_y:
  7960	            p_below = None
  7961	            p_above = None
  7962	            for p_y, p_u in profile:
  7963	                if p_y <= g_y:
  7964	                    p_below = (p_y, p_u)
  7965	                if p_y >= g_y and p_above is None:
  7966	                    p_above = (p_y, p_u)
  7967	            if p_below and p_above and p_above[0] != p_below[0]:
