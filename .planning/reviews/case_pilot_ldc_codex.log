   644	            # Auto-pick the 2D plane with non-degenerate variance so that
   645	            # cases meshed in x-z (NACA0012) or y-z still produce a contour.
   646	            ax1, ax2, vel1, vel2, _, _ = _pick_2d_plane(Cx, Cy, Cz, U)
