  1235	function ConvergenceSparkline({
  1236	  series,
  1237	  goldRef,
  1238	  tolPct,
  1239	  activeIdx,
  1240	}: {
  1241	  series: { idx: number; label: string; value: number | null | undefined; status: ContractStatus }[];
  1242	  goldRef: number | undefined;
  1243	  tolPct: number | undefined;
  1244	  activeIdx: number;
  1245	}) {
  1246	  const W = 600;
  1247	  const H = 180;
  1248	  const padX = 40;
  1249	  const padY = 20;
  1250	
  1251	  const values = series
  1252	    .map((s) => s.value)
  1253	    .filter((v): v is number => v != null && Number.isFinite(v));
  1254	  if (goldRef == null || !Number.isFinite(goldRef) || values.length === 0) {
  1255	    return (
  1256	      <div className="h-[180px] rounded border border-surface-800 bg-surface-950/40 p-3 text-[11px] text-surface-500">
  1257	        等待后端数据…
  1258	      </div>
  1259	    );
  1260	  }
  1261	  const allVals = [...values, goldRef];
  1262	  if (tolPct != null) {
  1263	    allVals.push(goldRef * (1 + tolPct), goldRef * (1 - tolPct));
  1264	  }
  1265	  const yMin = Math.min(...allVals);
  1266	  const yMax = Math.max(...allVals);
  1267	  const yRange = yMax - yMin || Math.abs(goldRef) * 0.2 || 1;
  1268	  const yPad = yRange * 0.15;
  1269	  const yLo = yMin - yPad;
  1270	  const yHi = yMax + yPad;
  1271	
  1272	  const xStep = series.length > 1 ? (W - 2 * padX) / (series.length - 1) : 0;
  1273	  const toX = (i: number) => padX + i * xStep;
  1274	  const toY = (v: number) => padY + (H - 2 * padY) * (1 - (v - yLo) / (yHi - yLo));
  1275	
  1276	  const goldY = toY(goldRef);
  1277	  const upperY = tolPct != null ? toY(goldRef * (1 + tolPct)) : null;
  1278	  const lowerY = tolPct != null ? toY(goldRef * (1 - tolPct)) : null;
  1279	
  1280	  const points = series
  1281	    .map((s) =>
  1282	      s.value == null || !Number.isFinite(s.value)
  1283	        ? null
  1284	        : `${toX(s.idx)},${toY(s.value)}`,
  1285	    )
  1286	    .filter((p): p is string => p != null)
  1287	    .join(" ");
  1288	
  1289	  const statusColor: Record<ContractStatus, string> = {
  1290	    PASS: "#4ade80",
  1291	    HAZARD: "#fbbf24",
  1292	    FAIL: "#f87171",
  1293	    UNKNOWN: "#9ca3af",
  1294	  };
  1295	
  1296	  return (
  1297	    <div className="rounded border border-surface-800 bg-surface-950/40 p-3">
  1298	      <svg viewBox={`0 0 ${W} ${H}`} className="w-full" role="img">
  1299	        {/* tolerance band */}
  1300	        {upperY != null && lowerY != null && (
  1301	          <rect
  1302	            x={padX - 6}
  1303	            y={Math.min(upperY, lowerY)}
  1304	            width={W - 2 * padX + 12}
  1305	            height={Math.abs(upperY - lowerY)}
  1306	            fill="#4ade80"
  1307	            opacity={0.08}
  1308	          />
  1309	        )}
  1310	        {/* gold line */}
  1311	        <line
  1312	          x1={padX - 6}
  1313	          x2={W - padX + 6}
  1314	          y1={goldY}
  1315	          y2={goldY}
  1316	          stroke="#4ade80"
  1317	          strokeWidth={1.4}
  1318	          strokeDasharray="4 3"
  1319	        />
  1320	        <text x={W - padX + 10} y={goldY + 3} fontSize="10" fill="#4ade80">
  1321	          gold {formatNumber(goldRef)}
  1322	        </text>
  1323	        {/* connecting line */}
  1324	        <polyline
  1325	          points={points}
  1326	          fill="none"
  1327	          stroke="#60a5fa"
  1328	          strokeWidth={1.5}
  1329	          opacity={0.6}
  1330	        />
  1331	        {/* density anchor points */}
  1332	        {series.map((s) => {
  1333	          if (s.value == null || !Number.isFinite(s.value)) return null;
  1334	          const cx = toX(s.idx);
  1335	          const cy = toY(s.value);
  1336	          const r = s.idx === activeIdx ? 6 : 4;
  1337	          return (
  1338	            <g key={s.idx}>
  1339	              <circle
  1340	                cx={cx}
  1341	                cy={cy}
  1342	                r={r}
  1343	                fill={statusColor[s.status]}
  1344	                stroke="#0a0e14"
  1345	                strokeWidth={1.5}
  1346	              />
  1347	              <text
  1348	                x={cx}
  1349	                y={H - 4}
  1350	                textAnchor="middle"
  1351	                fontSize="10"
  1352	                fill={s.idx === activeIdx ? "#e5e7eb" : "#6b7280"}
  1353	              >
  1354	                {s.label}
  1355	              </text>
  1356	            </g>
  1357	          );
  1358	        })}
  1359	      </svg>
  1360	    </div>
  1361	  );
  1362	}
  1363	
  1364	function formatNumber(v: number | undefined | null): string {
  1365	  if (v == null || !Number.isFinite(v)) return "—";
  1366	  const abs = Math.abs(v);
  1367	  if (abs === 0) return "0";
  1368	  if (abs < 0.001) return v.toExponential(2);
  1369	  if (abs < 1) return v.toFixed(4);
  1370	  if (abs < 100) return v.toFixed(3);

