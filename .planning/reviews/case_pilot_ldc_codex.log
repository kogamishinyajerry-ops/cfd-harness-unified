  1459	// Pure-SVG residual chart (no chart lib dependency). Shows a decaying
  1460	// multi-residual hint like a real simpleFoam log would render.
  1461	function ResidualsPreview() {
  1462	  const SERIES = useMemo(() => {
  1463	    const makeSeries = (decay: number, noise: number, seed: number) => {
  1464	      const pts: [number, number][] = [];
  1465	      let val = 1;
  1466	      for (let i = 0; i <= 60; i++) {
  1467	        val *= decay;
  1468	        const jitter = Math.sin(i * 0.7 + seed) * noise * val;
  1469	        pts.push([i, Math.max(val + jitter, 1e-6)]);
  1470	      }
  1471	      return pts;
  1472	    };
  1473	    return [
  1474	      { key: "p", color: "#60a5fa", pts: makeSeries(0.9, 0.2, 0.1) },
  1475	      { key: "Ux", color: "#a78bfa", pts: makeSeries(0.91, 0.22, 1.3) },
  1476	      { key: "Uy", color: "#f472b6", pts: makeSeries(0.92, 0.18, 2.1) },
  1477	    ];
  1478	  }, []);
  1479	
  1480	  const W = 560;
  1481	  const H = 160;
  1482	  const PADL = 36;
  1483	  const PADR = 12;
  1484	  const PADT = 8;
  1485	  const PADB = 22;
  1486	
  1487	  const xToPx = (x: number) => PADL + (x / 60) * (W - PADL - PADR);
  1488	  const yToPx = (y: number) => {
  1489	    // log scale from 1 down to 1e-6
  1490	    const logY = Math.log10(Math.max(y, 1e-6));
  1491	    const frac = (0 - logY) / 6; // 0 at top, 1 at bottom
  1492	    return PADT + frac * (H - PADT - PADB);
  1493	  };
  1494	
  1495	  return (
  1496	    <svg viewBox={`0 0 ${W} ${H}`} className="w-full" aria-hidden>
  1497	      {/* log-grid horizontal lines at 1e0..1e-6 */}
  1498	      {[0, -1, -2, -3, -4, -5, -6].map((p) => (
  1499	        <g key={p}>
  1500	          <line
  1501	            x1={PADL}
  1502	            x2={W - PADR}
  1503	            y1={yToPx(Math.pow(10, p))}
  1504	            y2={yToPx(Math.pow(10, p))}
  1505	            stroke="currentColor"
  1506	            className="text-surface-800"
  1507	            strokeWidth="0.5"
  1508	          />
  1509	          <text
  1510	            x={PADL - 6}
  1511	            y={yToPx(Math.pow(10, p)) + 3}
  1512	            fontSize="10"
  1513	            textAnchor="end"
  1514	            fill="currentColor"
  1515	            className="mono text-surface-500"
  1516	          >
  1517	            1e{p}
  1518	          </text>
  1519	        </g>
  1520	      ))}
  1521	      {/* x-axis */}
  1522	      <line
  1523	        x1={PADL}
  1524	        x2={W - PADR}
  1525	        y1={H - PADB}
  1526	        y2={H - PADB}
  1527	        stroke="currentColor"
  1528	        className="text-surface-700"
  1529	        strokeWidth="1"
  1530	      />
  1531	      <text
  1532	        x={(W + PADL) / 2}
  1533	        y={H - 6}
  1534	        fontSize="10"
  1535	        textAnchor="middle"
  1536	        fill="currentColor"
  1537	        className="text-surface-500"
  1538	      >
  1539	        迭代步数
  1540	      </text>
  1541	      {/* series */}
  1542	      {SERIES.map((s) => (
  1543	        <g key={s.key}>
  1544	          <polyline
  1545	            fill="none"
  1546	            stroke={s.color}
  1547	            strokeWidth="1.4"
  1548	            points={s.pts.map(([x, y]) => `${xToPx(x)},${yToPx(y)}`).join(" ")}
  1549	            opacity="0.85"
  1550	          />
  1551	          <text
  1552	            x={xToPx(61)}
  1553	            y={yToPx(s.pts[s.pts.length - 1][1]) + 3}
  1554	            fontSize="10"
  1555	            fill={s.color}
  1556	            className="mono"
  1557	          >
  1558	            {s.key}
  1559	          </text>
  1560	        </g>
  1561	      ))}
  1562	    </svg>
  1563	  );
