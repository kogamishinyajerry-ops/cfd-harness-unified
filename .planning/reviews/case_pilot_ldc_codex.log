   240	def render_profile_png(
   241	    case_id: str,
   242	    artifact_dir: Path,
   243	    renders_dir: Path,
   244	) -> Path:
   245	    """Matplotlib PNG: sim U_x(y) solid line + Ghia 1982 scatter markers."""
   246	    latest = _latest_sample_iter(artifact_dir)
   247	    xy = latest / "uCenterline.xy"
   248	    y_sim, u_sim = _load_sample_xy(xy)
   249	
   250	    # LDC is stored in physical coords (convertToMeters 0.1 → y ∈ [0, 0.1]).
   251	    # Normalize to y_star ∈ [0, 1] for Ghia comparison.
   252	    y_norm = y_sim / max(y_sim.max(), 1e-12)
   253	
   254	    y_gold, u_gold, citation = _load_gold_ldc()
   255	
   256	    fig, ax = plt.subplots()
   257	    ax.plot(u_sim, y_norm, color="#1f77b4", label="simpleFoam (sim)")
   258	    ax.scatter(u_gold, y_gold, color="#d62728", s=36, zorder=5,
   259	               label="Ghia 1982 (Table I, Re=100)", edgecolor="white", linewidth=0.8)
   260	    ax.axvline(0, color="gray", linewidth=0.5, linestyle="--", alpha=0.5)
   261	    ax.set_xlabel(r"$U_x$ / $U_{\mathrm{lid}}$")
   262	    ax.set_ylabel(r"$y\,/\,L$")
   263	    ax.set_title(f"{case_id} — U centerline profile vs Ghia 1982")
   264	    ax.legend(loc="upper left", frameon=False)
   265	    ax.text(0.02, 0.02, citation[:80] + ("..." if len(citation) > 80 else ""),
   266	            transform=ax.transAxes, fontsize=8, color="gray", style="italic")
   267	    out = renders_dir / "profile_u_centerline.png"
   268	    fig.savefig(out)
   269	    plt.close(fig)
   270	    return out
