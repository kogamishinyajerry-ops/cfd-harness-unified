    50	def _lookup_with_alias(
    51	    key_quantities: Dict[str, Any],
    52	    canonical: str,
    53	) -> Tuple[Optional[Any], Optional[str]]:
    54	    """Return (value, key_used). Canonical name wins; fall through aliases.
    55	
    56	    Returns (None, None) when no match — caller should report the *canonical*
    57	    name in error messages so users see what gold expected, not what adapter emitted.
    58	    """
    59	    direct = key_quantities.get(canonical)
    60	    if direct is not None:
    61	        return direct, canonical
    62	    for alias in CANONICAL_ALIASES.get(canonical, ()):
    63	        if alias in key_quantities:
    64	            value = key_quantities[alias]
    65	            if value is not None:
    66	                logger.debug(
    67	                    "ResultComparator: resolved %r via alias %r", canonical, alias
    68	                )
    69	                return value, alias
    70	    return None, None
