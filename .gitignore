# Python
__pycache__/
*.py[cod]
*.so
.Python
*.egg-info/
dist/
build/
.eggs/

# Testing
.coverage
htmlcov/
.pytest_cache/
.tox/

# Virtual environments
venv/
.venv/
env/

# IDE
.idea/
.vscode/
