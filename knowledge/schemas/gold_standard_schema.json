{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://cfd-harness.example.com/schemas/gold_standard_schema.json",
  "title": "CFD Gold Standard Schema",
  "description": "Validates both legacy multi-document Gold Standard YAML files and structured Phase 8 alias files.",
  "oneOf": [
    {
      "$ref": "#/$defs/LegacyGoldStandardFile"
    },
    {
      "$ref": "#/$defs/StructuredGoldStandardFile"
    }
  ],
  "$defs": {
    "Tolerance": {
      "oneOf": [
        {
          "type": "number",
          "minimum": 0
        },
        {
          "type": "object",
          "required": [
            "mode"
          ],
          "properties": {
            "mode": {
              "type": "string",
              "enum": [
                "relative",
                "absolute",
                "hybrid",
                "RELATIVE",
                "ABSOLUTE",
                "HYBRID"
              ]
            },
            "value": {
              "type": "number",
              "minimum": 0
            },
            "relative": {
              "type": "number",
              "minimum": 0
            },
            "absolute": {
              "type": "number",
              "minimum": 0
            },
            "absolute_floor": {
              "type": "number",
              "minimum": 0
            },
            "min_coverage": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            }
          },
          "additionalProperties": true,
          "anyOf": [
            {
              "required": [
                "value"
              ]
            },
            {
              "required": [
                "relative"
              ]
            },
            {
              "required": [
                "absolute"
              ]
            }
          ]
        }
      ]
    },
    "Relationships": {
      "type": "object",
      "properties": {
        "solver_reuse": {
          "type": "string",
          "description": "Case ID for a solver-compatible reference case."
        },
        "geometry_similarity": {
          "type": "object",
          "properties": {
            "reference_case": {
              "type": "string"
            },
            "similarity_type": {
              "type": "string",
              "enum": [
                "SCALED",
                "TOPOLOGICAL",
                "WALL-MODELLED",
                "SAME_CLASS"
              ]
            },
            "scale_factor": {
              "type": "number"
            }
          },
          "required": [
            "reference_case",
            "similarity_type"
          ],
          "additionalProperties": true
        },
        "physics_analogy": {
          "type": "object",
          "properties": {
            "reference_case": {
              "type": "string"
            },
            "analogy_basis": {
              "type": "string"
            },
            "matched_dimensionless_group": {
              "type": "string"
            }
          },
          "required": [
            "reference_case",
            "analogy_basis"
          ],
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    "LegacyObservable": {
      "type": "object",
      "required": [
        "quantity",
        "reference_values",
        "source"
      ],
      "anyOf": [
        {
          "required": ["tolerance"]
        },
        {
          "required": ["position_tolerance", "psi_tolerance"]
        }
      ],
      "properties": {
        "quantity": {
          "type": "string",
          "minLength": 1
        },
        "reference_values": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "minProperties": 1
          }
        },
        "tolerance": {
          "$ref": "#/$defs/Tolerance"
        },
        "position_tolerance": {
          "$ref": "#/$defs/Tolerance"
        },
        "psi_tolerance": {
          "$ref": "#/$defs/Tolerance"
        },
        "source": {
          "type": "string",
          "minLength": 1
        },
        "literature_doi": {
          "type": "string"
        },
        "doi": {
          "type": "string"
        },
        "mesh_info": {
          "type": "object",
          "additionalProperties": true
        },
        "solver_info": {
          "type": "object",
          "additionalProperties": true
        },
        "case_info": {
          "type": "object",
          "properties": {
            "id": {
              "type": "string"
            },
            "Re": {
              "type": ["number", "string"]
            },
            "Re_tau": {
              "type": ["number", "string"]
            },
            "Ra": {
              "type": ["number", "string"]
            },
            "Pr": {
              "type": ["number", "string"]
            },
            "flow_type": {
              "type": "string",
              "enum": [
                "INTERNAL",
                "EXTERNAL",
                "NATURAL_CONVECTION"
              ]
            },
            "steady_state": {
              "type": "string",
              "enum": [
                "STEADY",
                "TRANSIENT"
              ]
            }
          },
          "additionalProperties": true
        },
        "relationships": {
          "$ref": "#/$defs/Relationships"
        }
      },
      "additionalProperties": true
    },
    "LegacyGoldStandardFile": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/LegacyObservable"
      }
    },
    "StructuredObservable": {
      "type": "object",
      "required": [
        "name",
        "ref_value",
        "tolerance"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string"
        },
        "ref_value": {
          "oneOf": [
            {
              "type": "number"
            },
            {
              "type": "object",
              "minProperties": 1
            },
            {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "object",
                "minProperties": 1
              }
            }
          ]
        },
        "unit": {
          "type": "string"
        },
        "tolerance": {
          "$ref": "#/$defs/Tolerance"
        }
      },
      "additionalProperties": true
    },
    "StructuredGoldStandardFile": {
      "type": "object",
      "required": [
        "case_id",
        "source",
        "observables"
      ],
      "properties": {
        "schema_version": {
          "type": "integer"
        },
        "case_id": {
          "type": "string",
          "minLength": 1
        },
        "legacy_case_id": {
          "type": "string"
        },
        "legacy_source_file": {
          "type": "string"
        },
        "legacy_case_ids": {
          "type": "array",
          "items": { "type": "string" }
        },
        "legacy_source_files": {
          "type": "array",
          "items": { "type": "string" }
        },
        "note": {
          "type": "string"
        },
        "physics_contract": {
          "type": "object",
          "additionalProperties": true
        },
        "source": {
          "type": "string",
          "minLength": 1
        },
        "literature_doi": {
          "type": "string"
        },
        "case_info": {
          "type": "object",
          "additionalProperties": true
        },
        "relationships": {
          "$ref": "#/$defs/Relationships"
        },
        "observables": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/StructuredObservable"
          }
        }
      },
      "additionalProperties": true
    }
  }
}
